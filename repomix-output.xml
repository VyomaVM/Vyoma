  36:     let ctrl_c = async {
  37:         let _ = tokio::signal::ctrl_c().await;
  38:     };
  39:     #[cfg(unix)]
  40:     let terminate = async {
  41:         let _ = tokio::signal::unix::signal(tokio::signal::unix::SignalKind::terminate())
  42:             .expect("failed to install signal handler")
  43:             .recv()
  44:             .await;
  45:     };
  46:     #[cfg(not(unix))]
  47:     let terminate = std::future::pending::<()>();
  48:     tokio::select! {
  49:         _ = ctrl_c => {},
  50:         _ = terminate => {},
  51:     }
  52:     info!("Signal received, starting graceful shutdown...");
  53:     let ids: Vec<String> = {
  54:         let map = state.vms.lock().unwrap();
  55:         map.keys().cloned().collect()
  56:     };
  57:     if !ids.is_empty() {
  58:         info!("Cleaning up {} active VMs...", ids.len());
  59:         for id in ids {
  60:             let vm_arc = {
  61:                 let mut map = state.vms.lock().unwrap();
  62:                 map.remove(&id)
  63:             };
  64:             if let Some(vm_mutex) = vm_arc {
  65:                 let mut vm = vm_mutex.lock().await;
  66:                 vm.cleanup(&state.cni_manager).await;
  67:             }
  68:         }
  69:     }
  70:     info!("Graceful shutdown complete.");
  71: }
