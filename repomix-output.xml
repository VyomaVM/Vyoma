1026: #### 4.1.1 Device Mapper — Replace subprocess calls
1027: 
1028: ```rust
1029: // crates/ignite-storage/src/dm.rs
1030: 
1031: use devicemapper::{DmOptions, DmName, DevId, Segment, LinearDev, SnapshotDev};
1032: 
1033: pub struct DmSnapshots {
1034:     dm: DM,
1035: }
1036: 
1037: impl DmSnapshots {
1038:     pub fn new() -> Result<Self> {
1039:         Ok(Self { dm: DM::new()? })
1040:     }
1041: 
1042:     /// Create a snapshot of base_dev, writing changes to cow_dev
1043:     pub fn create_snapshot(
1044:         &self,
1045:         name: &str,
1046:         base_dev: &Path,      // loop device of base ext4
1047:         cow_dev: &Path,       // loop device of sparse COW file
1048:     ) -> Result<DmDevice> {
1049:         let dm_name = DmName::new(name)?;
1050:         
1051:         // Origin target wraps the read-only base
1052:         let origin = LinearDev::setup(
1053:             &self.dm,
1054:             &DmName::new(&format!("{}-origin", name))?,
1055:             None,
1056:             vec![Segment::new(base_dev, Sector(0), device_size(base_dev)?)],
1057:         )?;
1058:         
1059:         // Snapshot combines origin + COW
1060:         let snap = SnapshotDev::setup(
1061:             &self.dm,
1062:             &dm_name,
1063:             None,
1064:             &origin,
1065:             cow_dev,
1066:             true,  // persistent=true
1067:         )?;
1068:         
1069:         Ok(DmDevice { name: name.to_string(), path: snap.path()? })
1070:     }
1071: 
1072:     pub fn remove_snapshot(&self, name: &str) -> Result<()> {
1073:         self.dm.device_remove(&DevId::Name(DmName::new(name)?), &DmOptions::default())?;
1074:         Ok(())
1075:     }
1076: }
1077: ```
