<file path="crates/ignite-core/src/proxy.rs">
 1: use tokio::net::{TcpListener, TcpStream};
 2: use tokio::task::JoinHandle;
 3: use tracing::{info, error, debug};
 4: use std::net::SocketAddr;
 5: pub struct ProxyManager;
 6: impl ProxyManager {
 7:     pub fn start_proxy(host_port: u16, vm_ip: String, vm_port: u16) -> JoinHandle<()> {
 8:         tokio::spawn(async move {
 9:             info!("Starting TCP Proxy: 0.0.0.0:{} -> {}:{}", host_port, vm_ip, vm_port);
10:             let addr = SocketAddr::from(([0, 0, 0, 0], host_port));
11:             let listener = match TcpListener::bind(addr).await {
12:                 Ok(l) => l,
13:                 Err(e) => {
14:                     error!("Proxy bind error on port {}: {}", host_port, e);
15:                     return;
16:                 }
17:             };
18:             loop {
19:                 match listener.accept().await {
20:                     Ok((mut inbound, addr)) => {
21:                         debug!("Proxy: Pending connection from {}", addr);
22:                         let vm_addr = format!("{}:{}", vm_ip, vm_port);
23:                         tokio::spawn(async move {
24:                             match TcpStream::connect(&vm_addr).await {
25:                                 Ok(mut outbound) => {
26:                                     if let Err(e) = tokio::io::copy_bidirectional(&mut inbound, &mut outbound).await {
27:                                         debug!("Proxy transfer ended/error: {}", e);
28:                                     }
29:                                 }
30:                                 Err(e) => {
31:                                     error!("Proxy failed to connect to VM {}: {}", vm_addr, e);
32:                                 }
33:                             }
34:                         });
35:                     }
36:                     Err(e) => {
37:                         error!("Proxy accept error: {}", e);
38:                     }
39:                 }
40:             }
41:         })
42:     }
43: }
</file>

