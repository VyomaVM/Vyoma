 591: pub async fn restore_vm(
 592:     State(state): State<AppState>,
 593:     Json(payload): Json<RestoreRequest>,
 594: ) -> Result<Json<RunResponse>, (StatusCode, String)> {
 595:     info!(
 596:         "Request to restore VM from snapshot: {}",
 597:         payload.snapshot_path
 598:     );
 599:     let home = dirs::home_dir().ok_or((StatusCode::INTERNAL_SERVER_ERROR, "No home dir".into()))?;
 600:     let ignite_root = home.join(".ignite");
 601:     let images_root = ignite_root.join("images");
 602:     let vms_root = ignite_root.join("vms");
 603:     let safe_image_name = "alpine_latest";
 604:     let image_store_path = images_root.join(&safe_image_name);
 605:     let base_image_file = image_store_path.join("base.ext4");
 606:     let vm_id = uuid::Uuid::new_v4().to_string();
 607:     let vm_dir = vms_root.join(&vm_id);
 608:     std::fs::create_dir_all(&vm_dir)
 609:         .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 610:     let cow_file = vm_dir.join("diff.cow");
 611:     info!("Restoring disk state from {}", payload.cow_path);
 612:     std::fs::copy(&payload.cow_path, &cow_file).map_err(|e| {
 613:         (
 614:             StatusCode::INTERNAL_SERVER_ERROR,
 615:             format!("Failed to copy COW file: {}", e),
 616:         )
 617:     })?;
 618:     let base_loop = StorageManager::setup_loop_device(&base_image_file).map_err(|e| {
 619:         (
 620:             StatusCode::INTERNAL_SERVER_ERROR,
 621:             format!("Loop base: {}", e),
 622:         )
 623:     })?;
 624:     let cow_loop = StorageManager::setup_loop_device(&cow_file).map_err(|e| {
 625:         (
 626:             StatusCode::INTERNAL_SERVER_ERROR,
 627:             format!("Loop cow: {}", e),
 628:         )
 629:     })?;
 630:     let dm_name = format!("ign-{}", vm_id);
 631:     let size_mb = 2048;
 632:     let size_sectors = size_mb * 1024 * 1024 / 512;
 633:     let dm_path = StorageManager::create_dm_snapshot(&dm_name, &base_loop, &cow_loop, size_sectors)
 634:         .map_err(|e| {
 635:             (
 636:                 StatusCode::INTERNAL_SERVER_ERROR,
 637:                 format!("DM create: {}", e),
 638:             )
 639:         })?;
 640:     let bridge_name = "ign0";
 641:     let bridge_cidr = "172.16.0.1/24";
 642:     let tap_name = format!("tap{}", &vm_id[0..8]);
 643:     NetworkManager::setup_tap(&tap_name, bridge_name).map_err(|e| {
 644:         (
 645:             StatusCode::INTERNAL_SERVER_ERROR,
 646:             format!("TAP setup: {}", e),
 647:         )
 648:     })?;
 649:     let random_octet = rand::random::<u8>();
 650:     let safe_octet = std::cmp::max(2, std::cmp::min(254, random_octet));
 651:     let vm_ip = format!("172.16.0.{}", safe_octet);
 652:     let socket_path = format!("/tmp/firecracker_{}.socket", vm_id);
 653:     let mut vmm = VmmManager::new(&socket_path);
 654:     if let Err(e) = vmm.start_daemon("bin/firecracker", None, state.rootless) {
 655:         return Err((
 656:             StatusCode::INTERNAL_SERVER_ERROR,
 657:             format!("Failed to start FC: {}", e),
 658:         ));
 659:     }
 660:     if let Err(e) = vmm
 661:         .load_snapshot(&payload.snapshot_path, &payload.mem_path)
 662:         .await
 663:     {
 664:         let _ = vmm.kill();
 665:         return Err((
 666:             StatusCode::INTERNAL_SERVER_ERROR,
 667:             format!("Load snapshot: {}", e),
 668:         ));
 669:     }
 670:     if let Err(e) = vmm.add_drive("rootfs", &dm_path, true).await {
 671:         let _ = vmm.kill();
 672:         return Err((
 673:             StatusCode::INTERNAL_SERVER_ERROR,
 674:             format!("Add drive: {}", e),
 675:         ));
 676:     }
 677:     if let Err(e) = vmm.add_network_interface("eth0", &tap_name, None).await {
 678:         let _ = vmm.kill();
 679:         return Err((StatusCode::INTERNAL_SERVER_ERROR, format!("Add net: {}", e)));
 680:     }
 681:     if let Err(e) = vmm.resume_instance().await {
 682:         let _ = vmm.kill();
 683:         return Err((
 684:             StatusCode::INTERNAL_SERVER_ERROR,
 685:             format!("Resume instance: {}", e),
 686:         ));
 687:     }
 688:     let proxy_tasks = Vec::new();
 689:     let instance = VmInstance {
 690:         vmm,
 691:         id: vm_id.clone(),
 692:         tap_name: tap_name.clone(),
 693:         dm_name: dm_name.clone(),
 694:         slirp: None,
 695:         loop_devices: vec![base_loop, cow_loop],
 696:         cow_file_path: cow_file.to_string_lossy().to_string(),
 697:         ip_address: vm_ip.clone(),
 698:         proxy_tasks,
 699:         fs_managers: Vec::new(),
 700:         cgroup_path: None,
 701:         netns_path: None,
 702:         config_ports: vec![],
 703:         config_volumes: vec![],
 704:         hostname: None,
 705:         labels: HashMap::new(),
 706:         base_image_path: String::new(),
 707:         vcpu: 1,
 708:         mem_size_mib: 512,
 709:     };
 710:     {
 711:         let mut vms = state.vms.lock().unwrap();
 712:         vms.insert(vm_id.clone(), Arc::new(TokioMutex::new(instance)));
 713:     }
 714:     Ok(Json(RunResponse {
 715:         vm_id,
 716:         status: "Restored".to_string(),
 717:         ip_address: vm_ip,
 718:     }))
 719: }
