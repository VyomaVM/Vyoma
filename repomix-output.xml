<file path="scripts/build_deb.sh">
 1: set -e
 2: VERSION="1.0.0"
 3: ARCH="amd64"
 4: PKG_NAME="ignite"
 5: WORK_DIR="target/debian/${PKG_NAME}_${VERSION}_${ARCH}"
 6: echo "Building Ignite v${VERSION} for Debian..."
 7: cargo build --release --bin ignited --bin ign
 8: mkdir -p "${WORK_DIR}/usr/bin"
 9: mkdir -p "${WORK_DIR}/etc/systemd/system"
10: mkdir -p "${WORK_DIR}/DEBIAN"
11: echo "Fetching dependencies..."
12: if [ ! -f "firecracker" ]; then
13:     wget -q -O firecracker.tgz https://github.com/firecracker-microvm/firecracker/releases/download/v1.7.0/firecracker-v1.7.0-x86_64.tgz
14:     tar -xzf firecracker.tgz
15:     mv release-v1.7.0-x86_64/firecracker-v1.7.0-x86_64 firecracker
16:     chmod +x firecracker
17: fi
18: if [ ! -f "virtiofsd" ]; then
19:     echo "Fetching virtiofsd..."
20:     wget -q -O virtiofsd.zip "https://gitlab.com/virtio-fs/virtiofsd/-/releases/v1.11.1/downloads/virtiofsd-v1.11.1-x86_64-musl.zip"
21:     unzip -q virtiofsd.zip
22:     mv virtiofsd virtiofsd_bin
23:     chmod +x virtiofsd_bin
24: fi
25: mkdir -p "${WORK_DIR}/usr/libexec/ignite"
26: cp target/release/ignited "${WORK_DIR}/usr/bin/"
27: cp target/release/ign "${WORK_DIR}/usr/bin/"
28: cp firecracker "${WORK_DIR}/usr/bin/firecracker"
29: cp virtiofsd_bin "${WORK_DIR}/usr/libexec/ignite/virtiofsd"
30: cp packaging/systemd/ignited.service "${WORK_DIR}/etc/systemd/system/"
31: cat <<EOF > "${WORK_DIR}/DEBIAN/control"
32: Package: ${PKG_NAME}
33: Version: ${VERSION}
34: Section: admin
35: Priority: optional
36: Architecture: ${ARCH}
37: Depends: libc6, openssl, ca-certificates
38: Maintainer: Subeshrock <subesh.rock.3@gmail.com>
39: Description: Ignite - MicroVM Ecosystem
40:  Docker-like experience for Firecracker MicroVMs.
41:  Includes Daemon, CLI, and Web UI.
42: EOF
43: cat <<EOF > "${WORK_DIR}/DEBIAN/postinst"
44: if ! getent group ignite > /dev/null 2>&1; then
45:     groupadd --system ignite
46: fi
47: if ! getent passwd ignite > /dev/null 2>&1; then
48:     useradd --system --shell /usr/sbin/nologin --gid ignite ignite
49: fi
