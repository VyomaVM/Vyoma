 53:         self.process.as_ref().map(|p| p.id())
 54:     }
 55:     pub fn try_wait(&mut self) -> Result<Option<std::process::ExitStatus>> {
 56:         if let Some(child) = self.process.as_mut() {
 57:             child.try_wait().map_err(|e| anyhow!("Failed to wait on child: {}", e))
 58:         } else {
 59:             Ok(None)
 60:         }
 61:     }
 62:     /// Spawns the Firecracker process in a background thread/process.
 63:     /// Optionally runs inside a network namespace.
 64:     pub fn start_daemon(&mut self, binary_path: &str, netns: Option<&str>, rootless: bool) -> Result<()> {
 65:         info!("Starting Firecracker at {} (Socket: {}, NetNS: {:?}, Rootless: {})", binary_path, self.socket_path, netns, rootless);
 66:         // Ensure socket doesn't exist
 67:         if Path::new(&self.socket_path).exists() {
 68:             std::fs::remove_file(&self.socket_path)?;
 69:         }
 70:         let mut child = if rootless {
 71:              Command::new("unshare")
 72:                 .arg("-r")
 73:                 .arg("-n")
 74:                 .arg(binary_path)
 75:                 .arg("--api-sock")
 76:                 .arg(&self.socket_path)
 77:                 .stdout(Stdio::piped())
 78:                 .stderr(Stdio::piped())
 79:                 .spawn()
 80:                 .map_err(|e| anyhow!("Failed to spawn firecracker with unshare: {}", e))?
 81:         } else if let Some(ns) = netns {
 82:              Command::new("sudo")
 83:                 .arg("ip")
 84:                 .arg("netns")
 85:                 .arg("exec")
 86:                 .arg(ns)
 87:                 .arg(binary_path)
 88:                 .arg("--api-sock")
 89:                 .arg(&self.socket_path)
 90:                 .stdout(Stdio::piped())
 91:                 .stderr(Stdio::piped())
 92:                 .spawn()
 93:                 .map_err(|e| anyhow!("Failed to spawn firecracker in netns: {}", e))?
 94:         } else {
 95:              Command::new(binary_path)
 96:                 .arg("--api-sock")
 97:                 .arg(&self.socket_path)
 98:                 .stdout(Stdio::piped())
 99:                 .stderr(Stdio::piped())
100:                 .spawn()
101:                 .map_err(|e| anyhow!("Failed to spawn firecracker: {}", e))?
102:         };
103:         let stdout = child.stdout.take().ok_or(anyhow!("Failed to capture stdout"))?;
104:         let stderr = child.stderr.take().ok_or(anyhow!("Failed to capture stderr"))?;
105:         let tx_out = self.log_sender.clone();
106:         let tx_err = self.log_sender.clone();
107:         thread::spawn(move || {
108:             let reader = BufReader::new(stdout);
109:             for line in reader.lines() {
110:                 if let Ok(l) = line {
111:                     let _ = tx_out.send(format!("[STDOUT] {}", l));
112:                 }
113:             }
114:         });
115:         thread::spawn(move || {
116:             let reader = BufReader::new(stderr);
117:             for line in reader.lines() {
118:                 if let Ok(l) = line {
119:                     let _ = tx_err.send(format!("[STDERR] {}", l));
120:                 }
121:             }
122:         });
123:         self.process = Some(child);
124:         self.wait_for_socket(Duration::from_secs(2))?;
125:         Ok(())
126:     }
127:     fn wait_for_socket(&self, timeout: Duration) -> Result<()> {
128:         let start = std::time::Instant::now();
129:         while start.elapsed() < timeout {
130:             if Path::new(&self.socket_path).exists() {
131:                 return Ok(());
132:             }
133:             std::thread::sleep(Duration::from_millis(50));
134:         }
135:         Err(anyhow!("Timed out waiting for Firecracker socket"))
136:     }
