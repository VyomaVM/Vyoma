 109: pub async fn run_vm(
 110:     State(state): State<AppState>,
 111:     Json(payload): Json<RunRequest>,
 112: ) -> Result<Json<RunResponse>, (StatusCode, String)> {
 113:     info!("Received request to run image: {}", payload.image);
 114:     // 1. Setup Directories
 115:     let home = dirs::home_dir().ok_or((StatusCode::INTERNAL_SERVER_ERROR, "No home dir".into()))?;
 116:     let ignite_root = home.join(".ignite");
 117:     let images_root = ignite_root.join("images");
 118:     let vms_root = ignite_root.join("vms");
 119:     std::fs::create_dir_all(&images_root)
 120:         .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 121:     std::fs::create_dir_all(&vms_root)
 122:         .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 123:     // Helper to parse CNI IP
 124:     fn parse_cni_ip(res: &serde_json::Value) -> anyhow::Result<String> {
 125:         let ips = res
 126:             .get("ips")
 127:             .and_then(|v| v.as_array())
 128:             .ok_or(anyhow::anyhow!("No IPs in CNI result"))?;
 129:         let first = ips.first().ok_or(anyhow::anyhow!("Empty IP list"))?;
 130:         let addr = first
 131:             .get("address")
 132:             .and_then(|v| v.as_str())
 133:             .ok_or(anyhow::anyhow!("No address field"))?;
 134:         // addr is CIDR (e.g. 172.16.0.5/24). Split it.
 135:         let ip = addr.split('/').next().unwrap_or(addr);
 136:         Ok(ip.to_string())
 137:     }
 138:     // 2. Pull Image & Prepare Base
 139:     let base_image_file = ensure_image_locally(&payload.image).await?;
 140:     let base_image_path_str = base_image_file.to_string_lossy().to_string();
 141:     info!("Using base image at {:?}", base_image_file);
 142:     // 3. VM Specific Setup
 143:     let vm_id = uuid::Uuid::new_v4().to_string();
 144:     let vm_dir = vms_root.join(&vm_id);
 145:     std::fs::create_dir_all(&vm_dir)
 146:         .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 147:     // Initialize Git Repo for Time Travel
 148:     if let Err(e) = git_init(&vm_dir) {
 149:         error!("Failed to init git repo in {:?}: {}", vm_dir, e);
 150:     }
 151:     // Storage Setup
 152:     let (dm_path, loop_devices, cow_file_str) = if state.rootless {
 153:         // Rootless: Simple Copy (No DM/Loop)
 154:         let vm_disk = vm_dir.join("disk.ext4");
 155:         info!("Rootless: Copying base image to {:?}", vm_disk);
 156:         std::fs::copy(&base_image_file, &vm_disk).map_err(|e| {
 157:             (
 158:                 StatusCode::INTERNAL_SERVER_ERROR,
 159:                 format!("Rootless copy: {}", e),
 160:             )
 161:         })?;
 162:         // We use the disk file as the "dm_path" (Firecracker treats it as root block device)
 163:         (
 164:             vm_disk.to_string_lossy().to_string(),
 165:             Vec::new(),
 166:             vm_disk.to_string_lossy().to_string(),
 167:         )
 168:     } else {
 169:         // Privileged: DM Snapshot (COW)
 170:         let cow_file = vm_dir.join("diff.cow");
 171:         let size_mb = 2048;
 172:         StorageManager::create_cow_file(&cow_file, size_mb)
 173:             .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 174:         let base_loop = StorageManager::setup_loop_device(&base_image_file).map_err(|e| {
 175:             (
 176:                 StatusCode::INTERNAL_SERVER_ERROR,
 177:                 format!("Loop base: {}", e),
 178:             )
 179:         })?;
 180:         let cow_loop = StorageManager::setup_loop_device(&cow_file).map_err(|e| {
 181:             (
 182:                 StatusCode::INTERNAL_SERVER_ERROR,
 183:                 format!("Loop cow: {}", e),
 184:             )
 185:         })?;
 186:         let dm_name = format!("ign-{}", vm_id);
 187:         let size_sectors = size_mb * 1024 * 1024 / 512;
 188:         let dm_path =
 189:             StorageManager::create_dm_snapshot(&dm_name, &base_loop, &cow_loop, size_sectors)
 190:                 .map_err(|e| {
 191:                     (
 192:                         StatusCode::INTERNAL_SERVER_ERROR,
 193:                         format!("DM create: {}", e),
 194:                     )
 195:                 })?;
 196:         (
 197:             dm_path,
 198:             vec![base_loop, cow_loop],
 199:             cow_file.to_string_lossy().to_string(),
 200:         )
 201:     };
 202:     // Legacy bindings for compilation compatibility if needed
 203:     let dm_name = if state.rootless {
 204:         "rootless".to_string()
 205:     } else {
 206:         format!("ign-{}", vm_id)
 207:     };
 208:     // Network Setup
 209:     let (vm_ip, tap_name, netns_path_final) = if state.rootless {
 210:         // Rootless (Slirp4netns)
 211:         // IP is handled by Slirp (usually 10.0.2.15)
 212:         // TAP name is just a label for VmInstance, inside NetNS it is "tap0"
 213:         ("10.0.2.15".to_string(), "tap0".to_string(), None)
 214:     } else {
 215:         // Network (CNI Integration)
 216:         // 1. Create NetNS
 217:         let netns_name = format!("vm-{}", vm_id);
 218:         let netns_path = format!("/var/run/netns/{}", netns_name);
 219:         // Ensure /var/run/netns exists
 220:         std::fs::create_dir_all("/var/run/netns")
 221:             .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 222:         // Create netns: ip netns add <name> (Requires root, which we have)
 223:         let _ = Command::new("ip")
 224:             .args(&["netns", "add", &netns_name])
 225:             .output()
 226:             .map_err(|e| {
 227:                 (
 228:                     StatusCode::INTERNAL_SERVER_ERROR,
 229:                     format!("Failed to create netns: {}", e),
 230:                 )
 231:             })?;
 232:         // 2. Call CNI ADD
 233:         let ifname = "eth0";
 234:         let cni_result = state
 235:             .cni_manager
 236:             .add(None, &vm_id, &netns_path, ifname)
 237:             .map_err(|e| {
 238:                 (
 239:                     StatusCode::INTERNAL_SERVER_ERROR,
 240:                     format!("CNI ADD failed: {}", e),
 241:                 )
 242:             })?;
 243:         // 3. Parse Result to get IP
 244:         let ip = parse_cni_ip(&cni_result).unwrap_or_else(|e| {
 245:             error!("Failed to parse CNI IP: {}", e);
 246:             "172.16.0.0".to_string()
 247:         });
 248:         info!("CNI assigned IP: {}", ip);
 249:         // Legacy Tap Name (Host Side for Hybrid)
 250:         let tap_legacy = format!("tap{}", &vm_id[0..8]);
 251:         (ip, tap_legacy, Some(netns_path))
 252:     };
 253:     // 3.5 Cgroups
 254:     let cgroup_path = match state.cgroups.create_vm_cgroup(&vm_id) {
 255:         Ok(p) => Some(p),
 256:         Err(e) => {
 257:             error!("Failed to create cgroup: {}", e);
 258:             None
 259:         }
 260:     };
 261:     if let Some(_) = &cgroup_path {
 262:         // vCPU limit (if payload.vcpu > 0)
 263:         // Assume VCPU 1 = 100%
 264:         let quota = payload.vcpu * 100; // 1 vCPU = 100%
 265:         if let Err(e) = state.cgroups.set_cpu_limit(&vm_id, quota) {
 266:             error!("Failed to set cpu limit: {}", e);
 267:         }
 268:         let mem_bytes = (payload.mem_size_mib as u64) * 1024 * 1024;
 269:         if let Err(e) = state.cgroups.set_memory_limit(&vm_id, mem_bytes) {
 270:             error!("Failed to set memory limit: {}", e);
 271:         }
 272:     }
 273:     // 3.6 Start Port Proxies
 274:     let mut proxy_tasks = Vec::new();
 275:     if !state.rootless {
 276:         for mapping in &payload.ports {
 277:             let handle =
 278:                 ProxyManager::start_proxy(mapping.host_port, vm_ip.clone(), mapping.vm_port);
 279:             proxy_tasks.push(handle);
 280:         }
 281:     } else {
 282:         info!("Rootless: Skipping ProxyManager. Ports are mapped by slirp4netns.");
 283:     }
 284:     let boot_args = format!("console=ttyS0 reboot=k panic=1 pci=off root=/dev/vda rw ip={}::{}:255.255.255.0:{}:eth0:off:{} init=/bin/sh",
 285:         vm_ip, "172.16.0.1", vm_id, "172.16.0.1");
 286:     // "ip=<client-ip>:<server-ip>:<gw-ip>:<netmask>:<hostname>:<device>:<autoconf>:<dns0-ip>"
 287:     // Correct kernel format: ip=172.16.0.X::172.16.0.1:255.255.255.0:myvm:eth0:off:172.16.0.1
 288:     // 4. Firecracker VMM
 289:     let socket_path = format!("/tmp/firecracker_{}.socket", vm_id);
 290:     let mut vmm = VmmManager::new(&socket_path);
 291:     // Kernel path: bin/vmlinux (relative to CWD of daemon)
 292:     let kernel_path = "bin/vmlinux";
 293:     if !std::path::Path::new(kernel_path).exists() {
 294:         return Err((
 295:             StatusCode::INTERNAL_SERVER_ERROR,
 296:             "Kernel binary (bin/vmlinux) not found".into(),
 297:         ));
 298:     }
 299:     let mut slirp_mgr = None;
 300:     if state.rootless {
 301:         // Rootless Start
 302:         info!("Spawning Firecracker in Rootless Mode (unshare -r -n)...");
 303:         if let Err(e) = vmm.start_daemon("bin/firecracker", None, true) {
 304:             return Err((
 305:                 StatusCode::INTERNAL_SERVER_ERROR,
 306:                 format!("Failed to start FC (Rootless): {}", e),
 307:             ));
 308:         }
 309:         // Get PID for Slirp
 310:         let pid = vmm
 311:             .get_pid()
 312:             .ok_or((StatusCode::INTERNAL_SERVER_ERROR, "FC PID not found".into()))?;
 313:         // Spawn Slirp
 314:         let socket_path = vm_dir.join("slirp.sock");
 315:         let mut slirp =
 316:             ignite_core::slirp::SlirpManager::new(socket_path.to_string_lossy().as_ref());
 317:         if let Err(e) = slirp.spawn(pid, "tap0", &payload.ports) {
 318:             let _ = vmm.kill();
 319:             return Err((
 320:                 StatusCode::INTERNAL_SERVER_ERROR,
 321:                 format!("Failed to start slirp: {}", e),
 322:             ));
 323:         }
 324:         slirp_mgr = Some(slirp);
 325:         // Config FC
 326:         if let Err(e) = vmm.set_boot_source(kernel_path, &boot_args).await {
 327:             let _ = vmm.kill();
 328:             return Err((
 329:                 StatusCode::INTERNAL_SERVER_ERROR,
 330:                 format!("Boot source: {}", e),
 331:             ));
 332:         }
 333:         if let Err(e) = vmm.add_drive("rootfs", &dm_path, true).await {
 334:             let _ = vmm.kill();
 335:             return Err((
 336:                 StatusCode::INTERNAL_SERVER_ERROR,
 337:                 format!("Add drive: {}", e),
 338:             ));
 339:         }
 340:         // Network: Interface inside NetNS is "tap0" created by Slirp
 341:         if let Err(e) = vmm.add_network_interface("eth0", "tap0", None).await {
 342:             let _ = vmm.kill();
 343:             return Err((
 344:                 StatusCode::INTERNAL_SERVER_ERROR,
 345:                 format!("Add net (rootless): {}", e),
 346:             ));
 347:         }
 348:     } else {
 349:         // Root/CNI Start (Hybrid Mode)
 350:         if let Err(e) = vmm.start_daemon("bin/firecracker", None, false) {
 351:             return Err((
 352:                 StatusCode::INTERNAL_SERVER_ERROR,
 353:                 format!("Failed to start FC: {}", e),
 354:             ));
 355:         }
 356:         // Config
 357:         if let Err(e) = vmm.set_boot_source(kernel_path, &boot_args).await {
 358:             let _ = vmm.kill();
 359:             return Err((
 360:                 StatusCode::INTERNAL_SERVER_ERROR,
 361:                 format!("Boot source: {}", e),
 362:             ));
 363:         }
 364:         if let Err(e) = vmm.add_drive("rootfs", &dm_path, true).await {
 365:             let _ = vmm.kill();
 366:             return Err((
 367:                 StatusCode::INTERNAL_SERVER_ERROR,
 368:                 format!("Add drive: {}", e),
 369:             ));
 370:         }
 371:         // Network: Interface on Host is `tap_name`
 372:         if let Err(e) = vmm.add_network_interface("eth0", &tap_name, None).await {
 373:             let _ = vmm.kill();
 374:             return Err((StatusCode::INTERNAL_SERVER_ERROR, format!("Add net: {}", e)));
 375:         }
 376:     }
 377:     // Add Volumes
 378:     let mut fs_managers = Vec::new();
 379:     for (idx, vol) in payload.volumes.iter().enumerate() {
 380:         let tag = format!("vol{}", idx);
 381:         let socket_path = vm_dir.join(format!("fs_{}.sock", idx));
 382:         let mut fs_mgr = VirtioFsManager::new(&tag, socket_path.to_string_lossy().as_ref());
 383:         // Start virtiofsd
 384:         if let Err(e) = fs_mgr.start(&vol.host_path) {
 385:             let _ = vmm.kill();
 386:             return Err((
 387:                 StatusCode::INTERNAL_SERVER_ERROR,
 388:                 format!("Failed to start virtiofsd for {}: {}", vol.host_path, e),
 389:             ));
 390:         }
 391:         // Add to FC
 392:         if let Err(e) = vmm
 393:             .add_file_system(&tag, socket_path.to_string_lossy().as_ref(), &tag)
 394:             .await
 395:         {
 396:             let _ = vmm.kill();
 397:             let _ = fs_mgr.kill();
 398:             return Err((StatusCode::INTERNAL_SERVER_ERROR, format!("Add fs: {}", e)));
 399:         }
 400:         fs_managers.push(fs_mgr);
 401:     }
 402:     if let Err(e) = vmm
 403:         .set_machine_config(payload.vcpu, payload.mem_size_mib)
 404:         .await
 405:     {
 406:         let _ = vmm.kill();
 407:         return Err((
 408:             StatusCode::INTERNAL_SERVER_ERROR,
 409:             format!("Machine config: {}", e),
 410:         ));
 411:     }
 412:     if let Err(e) = vmm.start_instance().await {
 413:         let _ = vmm.kill();
 414:         return Err((
 415:             StatusCode::INTERNAL_SERVER_ERROR,
 416:             format!("Start instance: {}", e),
 417:         ));
 418:     }
 419:     // Success - Store State
 420:     let instance = VmInstance {
 421:         vmm,
 422:         id: vm_id.clone(),
 423:         tap_name: if state.rootless {
 424:             String::new()
 425:         } else {
 426:             tap_name.to_string()
 427:         },
 428:         dm_name: dm_name.clone(),
 429:         loop_devices,
 430:         cow_file_path: cow_file_str,
 431:         ip_address: vm_ip.clone(),
 432:         proxy_tasks,
 433:         fs_managers,
 434:         slirp: slirp_mgr,
 435:         cgroup_path,
 436:         netns_path: netns_path_final,
 437:         config_ports: payload.ports.clone(),
 438:         config_volumes: payload.volumes.clone(),
 439:         hostname: payload.hostname.clone(),
 440:         labels: payload.labels.clone(),
 441:         base_image_path: base_image_path_str,
 442:         vcpu: payload.vcpu,
 443:         mem_size_mib: payload.mem_size_mib,
 444:     };
 445:     instance.save_state().map_err(|e| {
 446:         (
 447:             StatusCode::INTERNAL_SERVER_ERROR,
 448:             format!("Failed to save state: {}", e),
 449:         )
 450:     })?;
 451:     {
 452:         let mut vms = state.vms.lock().unwrap();
 453:         vms.insert(vm_id.clone(), Arc::new(TokioMutex::new(instance)));
 454:     }
 455:     let _ = state.events_tx.send(serde_json::json!({
 456:         "type": "vm_start",
 457:         "id": vm_id,
 458:         "name": payload.labels.get("ignite.service").unwrap_or(&vm_id)
 459:     }).to_string());
 460:     Ok(Json(RunResponse {
 461:         vm_id,
 462:         status: "Running".to_string(),
 463:         ip_address: vm_ip,
 464:     }))
 465: }
 466: pub async fn stop_vm(
 467:     State(state): State<AppState>,
 468:     Path(id): Path<String>,
 469: ) -> Result<String, (StatusCode, String)> {
 470:     info!("Request to stop VM: {}", id);
 471:     let vm_arc = {
 472:         let mut vms = state.vms.lock().unwrap();
 473:         vms.remove(&id)
 474:     };
 475:     if let Some(vm_mutex) = vm_arc {
 476:         let mut vm = vm_mutex.lock().await;
 477:         vm.cleanup(&state.cni_manager).await;
 478:         let _ = state.events_tx.send(serde_json::json!({
 479:             "type": "vm_stop",
 480:             "id": id
 481:         }).to_string());
 482:         Ok(format!("VM {} stopped and cleaned up", id))
 483:     } else {
 484:         Err((StatusCode::NOT_FOUND, "VM not found".to_string()))
 485:     }
 486: }
 487: pub async fn pause_vm(
 488:     State(state): State<AppState>,
 489:     Path(id): Path<String>,
 490: ) -> Result<String, (StatusCode, String)> {
 491:     info!("Request to pause VM: {}", id);
 492:     let vm_arc = {
