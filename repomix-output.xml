<file path="crates/ignite-core/src/cgroups.rs">
 1: use anyhow::Result;
 2: use std::fs;
 3: use std::path::Path;
 4: use tracing::info;
 5: pub struct CgroupManager {
 6:     root_path: String,
 7: }
 8: impl CgroupManager {
 9:     pub fn new() -> Self {
10:         Self {
11:             root_path: "/sys/fs/cgroup/ignite.slice".to_string(),
12:         }
13:     }
14:     pub fn init(&self) -> Result<()> {
15:         let path = Path::new(&self.root_path);
16:         if !path.exists() {
17:             info!("Creating root cgroup slice: {}", self.root_path);
18:             fs::create_dir_all(path)?;
19:             let controllers_path = Path::new("/sys/fs/cgroup/cgroup.controllers");
20:             let available = fs::read_to_string(controllers_path).unwrap_or_default();
21:             let mut subtree_control = String::new();
22:             if available.contains("cpu") { subtree_control.push_str("+cpu "); }
23:             if available.contains("memory") { subtree_control.push_str("+memory "); }
24:             if available.contains("io") { subtree_control.push_str("+io "); }
25:             let control_path = path.join("cgroup.subtree_control");
26:             if control_path.exists() {
27:                  fs::write(control_path, subtree_control.trim())?;
28:             }
29:         }
30:         Ok(())
31:     }
32:     pub fn create_vm_cgroup(&self, vm_id: &str) -> Result<String> {
33:         let vm_cgroup_path = Path::new(&self.root_path).join(format!("ignite-{}", vm_id));
34:         if !vm_cgroup_path.exists() {
35:             fs::create_dir_all(&vm_cgroup_path)?;
36:         }
37:         Ok(vm_cgroup_path.to_string_lossy().to_string())
38:     }
39:     pub fn set_cpu_limit(&self, vm_id: &str, vcpu_percentage: u32) -> Result<()> {
40:         let path = Path::new(&self.root_path).join(format!("ignite-{}", vm_id));
41:         let period = 100000;
42:         let quota = vcpu_percentage * 1000;
43:         let file_path = path.join("cpu.max");
44:         fs::write(file_path, format!("{} {}", quota, period))?;
45:         Ok(())
46:     }
47:     pub fn set_memory_limit(&self, vm_id: &str, bytes: u64) -> Result<()> {
48:         let path = Path::new(&self.root_path).join(format!("ignite-{}", vm_id));
49:         let file_path = path.join("memory.max");
50:         fs::write(file_path, bytes.to_string())?;
51:         Ok(())
52:     }
53:     pub fn add_process(&self, vm_id: &str, pid: u32) -> Result<()> {
54:         let path = Path::new(&self.root_path).join(format!("ignite-{}", vm_id));
55:         let file_path = path.join("cgroup.procs");
56:         fs::write(file_path, pid.to_string())?;
57:         Ok(())
58:     }
59:     pub fn remove_vm_cgroup(&self, vm_id: &str) -> Result<()> {
60:          let path = Path::new(&self.root_path).join(format!("ignite-{}", vm_id));
61:          if path.exists() {
62:              fs::remove_dir(&path)?;
63:          }
64:          Ok(())
65:     }
66:     pub fn get_oom_kill_count(&self, vm_id: &str) -> Result<u64> {
67:         let path = Path::new(&self.root_path).join(format!("ignite-{}", vm_id)).join("memory.events");
68:         if !path.exists() {
69:              return Ok(0);
70:         }
71:         let content = fs::read_to_string(path)?;
72:         for line in content.lines() {
73:             if line.starts_with("oom_kill ") {
74:                  if let Some(val_str) = line.split_whitespace().nth(1) {
75:                      return Ok(val_str.parse().unwrap_or(0));
76:                  }
77:             }
78:         }
79:         Ok(0)
80:     }
81: }
