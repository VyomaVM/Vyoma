1908: ### 6.2 Hibernation — State-to-Disk, All Resources Released
1909: 
1910: **Crate**: `crates/ignited/src/vm_manager.rs`  
1911: **Priority**: P1
1912: 
1913: ```rust
1914: pub async fn hibernate_vm(&self, vm_id: &str) -> Result<HibernationInfo> {
1915:     let state = self.get_running_vm(vm_id)?;
1916:     
1917:     // 1. Firecracker snapshot (CPU + memory state to files)
1918:     let hib_dir = hibernation_dir().join(vm_id);
1919:     std::fs::create_dir_all(&hib_dir)?;
1920:     
1921:     self.fc_client.pause_vm(&state.fc_socket).await?;
1922:     self.fc_client.create_snapshot(
1923:         &state.fc_socket,
1924:         &hib_dir.join("vm.snap"),
1925:         &hib_dir.join("vm.mem"),
1926:         SnapshotType::Full,
1927:     ).await?;
1928:     
1929:     // 2. Stop the Firecracker process (releases vCPUs and memory)
1930:     let _ = state.fc_process.kill();
1931:     state.fc_process.wait()?;
1932:     
1933:     // 3. Detach TAP device (releases network slot)
1934:     //    Keep the TAP device OBJECT so we can re-attach; but disable it
1935:     Command::new("ip").args(["link", "set", &state.tap_device, "down"]).status()?;
1936:     
1937:     // 4. Release IP back to IPAM (optional — keep IP for fast resume)
1938:     //    For hibernation we KEEP the IP reserved so VM resumes with same address
1939:     
1940:     // 5. Update WAL state
1941:     self.wal.commit_state(vm_id, &VmState {
1942:         status: VmStatus::Hibernated {
1943:             hib_dir: hib_dir.clone(),
1944:             snap_path: hib_dir.join("vm.snap"),
1945:             mem_path: hib_dir.join("vm.mem"),
1946:         },
1947:         ..state.clone()
1948:     })?;
1949:     
1950:     // 6. Remove from in-memory VM map (resources truly freed)
1951:     self.vms.lock().await.remove(vm_id);
1952:     
1953:     Ok(HibernationInfo {
1954:         vm_id: vm_id.to_string(),
1955:         hib_dir,
1956:         preserved_ip: state.ip,
1957:     })
1958: }
1959: 
1960: pub async fn resume_vm_from_hibernation(&self, vm_id: &str) -> Result<()> {
1961:     let state = self.wal.get_state(vm_id)?;
1962:     
1963:     let VmStatus::Hibernated { snap_path, mem_path, .. } = &state.status else {
1964:         return Err(anyhow!("VM {} is not hibernated", vm_id));
1965:     };
1966:     
1967:     // 1. Re-enable TAP device
1968:     Command::new("ip").args(["link", "set", &state.tap_device, "up"]).status()?;
1969:     
1970:     // 2. Start new Firecracker process
1971:     let fc_socket = new_fc_socket_path(vm_id);
1972:     let fc_process = spawn_firecracker(vm_id, &fc_socket)?;
1973:     
1974:     // 3. Load snapshot (Firecracker resumes from exact state)
1975:     self.fc_client.load_snapshot(
1976:         &fc_socket,
1977:         snap_path,
1978:         mem_path,
1979:         &state.tap_device,
1980:         &state.dm_device_path,
1981:     ).await?;
1982:     
1983:     // 4. Resume execution
1984:     self.fc_client.resume_vm(&fc_socket).await?;
1985:     
1986:     // 5. Update WAL
1987:     self.wal.commit_state(vm_id, &VmState {
1988:         status: VmStatus::Running { pid: fc_process.id(), fc_socket },
1989:         ..state
1990:     })?;
1991:     
1992:     self.vms.lock().await.insert(vm_id.to_string(), Arc::new(fc_process));
1993:     
1994:     Ok(())
1995: }
1996: ```
