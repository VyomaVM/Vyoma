 869: #### 3.6.1 Complete Teardown Sequence
 870: 
 871: ```rust
 872: // crates/ignited/src/vm_manager.rs
 873: 
 874: pub async fn destroy_vm(&self, vm_id: &str) -> Result<()> {
 875:     let state = self.get_state(vm_id)?;
 876:     
 877:     // 1. Ensure VM is stopped
 878:     if state.status == VmStatus::Running { .. } {
 879:         self.stop_vm(vm_id).await?;
 880:     }
 881:     
 882:     // 2. Kill virtiofsd processes for this VM
 883:     for vol in &state.volumes {
 884:         if let Some(pid) = vol.virtiofsd_pid {
 885:             let _ = signal::kill(Pid::from_raw(pid as i32), Signal::SIGTERM);
 886:         }
 887:     }
 888:     
 889:     // 3. Remove Device Mapper snapshot
 890:     if let Some(dm_name) = &state.dm_device_name {
 891:         Command::new("dmsetup").args(["remove", dm_name]).status()?;
 892:     }
 893:     
 894:     // 4. Detach loop device for COW file  
 895:     if let Some(loop_dev) = &state.cow_loop_dev {
 896:         Command::new("losetup").args(["-d", loop_dev]).status()?;
 897:     }
 898:     
 899:     // 5. Delete COW file
 900:     if let Some(cow_path) = &state.cow_path {
 901:         let _ = std::fs::remove_file(cow_path);
 902:     }
 903:     
 904:     // 6. Delete TAP device
 905:     if let Some(tap_name) = &state.tap_device {
 906:         Command::new("ip")
 907:             .args(["link", "delete", tap_name])
 908:             .status()?;
 909:     }
 910:     
 911:     // 7. Release IP back to IPAM pool
 912:     self.ipam.release(&state.ip)?;
 913:     
 914:     // 8. Remove Firecracker socket and working directory
 915:     if let Some(fc_dir) = &state.firecracker_dir {
 916:         let _ = std::fs::remove_dir_all(fc_dir);
 917:     }
 918:     
 919:     // 9. Remove from WAL and in-memory state
 920:     self.wal.remove_state(vm_id)?;
 921:     self.vms.lock().await.remove(vm_id);
 922:     
 923:     Ok(())
 924: }
 925: ```
