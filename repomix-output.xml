<file path="crates/ignite-core/src/fs.rs">
 1: use anyhow::{anyhow, Result};
 2: use std::process::{Command, Child};
 3: use std::path::Path;
 4: use tracing::info;
 5: #[derive(Debug)]
 6: pub struct VirtioFsManager {
 7:     process: Option<Child>,
 8:     socket_path: String,
 9:     tag: String,
10: }
11: impl VirtioFsManager {
12:     pub fn new(tag: &str, socket_path: &str) -> Self {
13:         Self {
14:             tag: tag.to_string(),
15:             socket_path: socket_path.to_string(),
16:             process: None,
17:         }
18:     }
19:     pub fn start(&mut self, source_path: &str) -> Result<()> {
20:         info!("Starting virtiofsd for tag {} on socket {}", self.tag, self.socket_path);
21:         if Path::new(&self.socket_path).exists() {
22:             std::fs::remove_file(&self.socket_path)?;
23:         }
24:         let binary = if Path::new("bin/virtiofsd").exists() {
25:             "bin/virtiofsd"
26:         } else {
27:             "virtiofsd"
28:         };
29:         let child = Command::new(binary)
30:             .arg(format!("--socket-path={}", self.socket_path))
31:             .arg(format!("--shared-dir={}", source_path))
32:             .arg("--sandbox=none")
33:             .arg("--seccomp=none")
34:             .spawn()
35:             .map_err(|e| anyhow!("Failed to spawn virtiofsd (is it installed?): {}", e))?;
36:         self.process = Some(child);
37:         let loop_delay = std::time::Duration::from_millis(50);
38:         for _ in 0..20 {
39:             if Path::new(&self.socket_path).exists() {
40:                 return Ok(());
41:             }
42:             std::thread::sleep(loop_delay);
43:         }
44:         Err(anyhow!("Timed out waiting for virtiofsd socket"))
45:     }
46:     pub fn kill(&mut self) -> Result<()> {
47:         if let Some(mut child) = self.process.take() {
48:             info!("Killing virtiofsd for tag {}", self.tag);
49:             child.kill()?;
50:             child.wait()?;
51:         }
52:         if Path::new(&self.socket_path).exists() {
53:             let _ = std::fs::remove_file(&self.socket_path);
54:         }
55:         Ok(())
56:     }
57:     pub fn try_wait(&mut self) -> Result<Option<std::process::ExitStatus>> {
58:         if let Some(child) = self.process.as_mut() {
59:              child.try_wait().map_err(|e| anyhow!("Failed to wait on child: {}", e))
60:         } else {
61:              Ok(None)
62:         }
63:     }
64: }
65: impl Drop for VirtioFsManager {
66:     fn drop(&mut self) {
67:         let _ = self.kill();
68:     }
69: }
</file>

<file path="crates/ignite-core/src/oci.rs">
  1: use anyhow::{anyhow, Result};
  2: use reqwest::Client;
  3: use serde::Deserialize;
  4: use std::collections::HashMap;
  5: use tracing::{debug, info};
  6: const DOCKER_REGISTRY_V2: &str = "https://registry-1.docker.io/v2";
  7: const DOCKER_AUTH_URL: &str = "https://auth.docker.io/token";
  8: pub struct OciManager {
  9:     client: Client,
 10:     token_cache: HashMap<String, String>,
 11: }
 12: #[derive(Deserialize, Debug)]
 13: struct TokenResponse {
 14:     token: String,
 15: }
 16: #[derive(Deserialize, Debug)]
 17: #[serde(untagged)]
 18: #[allow(dead_code)]
 19: enum ManifestResponse {
 20:     List(ManifestList),
 21:     V2(ManifestV2),
 22: }
 23: #[derive(Deserialize, Debug, Clone)]
 24: pub struct ManifestList {
 25:     pub manifests: Vec<ManifestDescriptor>,
 26: }
 27: #[derive(Deserialize, Debug, Clone)]
 28: pub struct ManifestDescriptor {
 29:     pub digest: String,
 30:     pub platform: Platform,
 31: }
 32: #[derive(Deserialize, Debug, Clone)]
 33: pub struct Platform {
 34:     pub architecture: String,
 35:     pub os: String,
 36: }
 37: #[derive(Deserialize, Debug, Clone)]
 38: #[allow(dead_code)]
 39: pub struct ManifestV2 {
 40:     pub config: ConfigDescriptor,
 41:     pub layers: Vec<LayerDescriptor>,
 42: }
 43: #[derive(Deserialize, Debug, Clone)]
 44: #[allow(dead_code)]
 45: pub struct ConfigDescriptor {
 46:     pub digest: String,
 47: }
 48: #[derive(Deserialize, Debug, Clone)]
 49: pub struct LayerDescriptor {
 50:     pub digest: String,
 51: }
 52: #[derive(Deserialize, Debug)]
 53: struct DockerConfig {
 54:     auths: HashMap<String, DockerAuth>,
 55: }
 56: #[derive(Deserialize, Debug)]
 57: struct DockerAuth {
 58:     auth: String,
 59: }
 60: impl OciManager {
 61:     fn load_docker_creds(&self, registry: &str) -> Option<(String, String)> {
 62:         let home = dirs::home_dir()?;
 63:         let config_path = home.join(".docker").join("config.json");
 64:         if !config_path.exists() {
 65:             return None;
 66:         }
 67:         let content = std::fs::read_to_string(config_path).ok()?;
 68:         let config: DockerConfig = serde_json::from_str(&content).ok()?;
 69:         let keys_to_try = vec![
 70:             registry.to_string(),
 71:             format!("https://{}", registry),
 72:             "https://index.docker.io/v1/".to_string(),
 73:         ];
 74:         use base64::prelude::*;
 75:         for key in keys_to_try {
 76:             if let Some(auth_entry) = config.auths.get(&key) {
 77:                 if let Ok(decoded_bytes) = BASE64_STANDARD.decode(&auth_entry.auth) {
 78:                     if let Ok(decoded_str) = String::from_utf8(decoded_bytes) {
 79:                         if let Some((u, p)) = decoded_str.split_once(':') {
 80:                             return Some((u.to_string(), p.to_string()));
 81:                         }
 82:                     }
 83:                 }
 84:             }
 85:         }
 86:         None
 87:     }
 88:     pub fn new() -> Self {
 89:         Self {
 90:             client: Client::new(),
 91:             token_cache: HashMap::new(),
 92:         }
 93:     }
 94:     async fn fetch_token(&self, realm: &str, service: Option<&str>, scope: Option<&str>, registry_host: &str) -> Result<String> {
 95:         let mut url = realm.to_string();
 96:         let mut query = vec![];
 97:         if let Some(s) = service { query.push(format!("service={}", s)); }
 98:         if let Some(s) = scope { query.push(format!("scope={}", s)); }
 99:         if !query.is_empty() {
100:              url = format!("{}?{}", url, query.join("&"));
101:         }
102:         let mut req = self.client.get(&url);
103:         if let Some((user, pass)) = self.load_docker_creds(registry_host) {
104:              info!("Using authenticated access for {}", registry_host);
105:              req = req.basic_auth(user, Some(pass));
106:         }
107:         let resp = req.send().await?;
108:         if !resp.status().is_success() {
109:              return Err(anyhow!("Token request failed for {}: {}", registry_host, resp.status()));
110:         }
111:         let token_resp: TokenResponse = resp.json().await?;
112:         Ok(token_resp.token)
113:     }
114:     pub async fn pull_manifest(&mut self, image: &str) -> Result<String> {
115:         let (registry, repository, tag) = self.parse_image_ref(image);
116:         let proto = if registry.starts_with("localhost") { "http" } else { "https" };
117:         let manifest_url = format!("{}://{}/v2/{}/manifests/{}", proto, registry, repository, tag);
118:         info!("Fetching manifest from: {}", manifest_url);
119:         let cache_key = format!("{}/{}", registry, repository);
120:         let token = self.token_cache.get(&cache_key).cloned();
121:         let mut req = self.client.get(&manifest_url)
122:             .header("Accept", "application/vnd.docker.distribution.manifest.v2+json, application/vnd.oci.image.manifest.v1+json, application/vnd.oci.image.index.v1+json, application/vnd.docker.distribution.manifest.list.v2+json");
123:         if let Some(t) = &token {
124:              req = req.header("Authorization", format!("Bearer {}", t));
125:         }
126:         let resp = req.send().await?;
127:         let resp = if resp.status() == reqwest::StatusCode::UNAUTHORIZED {
128:              debug!("401 Unauthorized. Attempting auth negotiation...");
129:              let auth_header = resp.headers().get("www-authenticate")
130:                  .ok_or_else(|| anyhow!("401 Unauthorized but missing Www-Authenticate header"))?
131:                  .to_str()?;
132:              let realm = extract_field(auth_header, "realm").ok_or_else(|| anyhow!("Missing realm"))?;
133:              let service = extract_field(auth_header, "service");
134:              let scope = extract_field(auth_header, "scope");
135:              let new_token = self.fetch_token(&realm, service.as_deref(), scope.as_deref(), &registry).await?;
136:              self.token_cache.insert(cache_key.clone(), new_token.clone());
137:              self.client.get(&manifest_url)
138:                  .header("Authorization", format!("Bearer {}", new_token))
139:                  .header("Accept", "application/vnd.docker.distribution.manifest.v2+json, application/vnd.oci.image.manifest.v1+json, application/vnd.oci.image.index.v1+json, application/vnd.docker.distribution.manifest.list.v2+json")
140:                  .send().await?
141:         } else {
142:              resp
143:         };
144:         if !resp.status().is_success() {
145:              return Err(anyhow!("Failed to fetch manifest: {}", resp.status()));
146:         }
147:         let content_type = resp.headers().get("content-type")
148:             .and_then(|h| h.to_str().ok())
149:             .unwrap_or("unknown")
150:             .to_string();
151:         let body = resp.text().await?;
152:         if content_type.contains("list") || content_type.contains("index") {
153:              info!("Received Manifest List/Index. Resolving for linux/amd64...");
154:              let list: ManifestList = serde_json::from_str(&body)?;
155:              let target = list.manifests.iter().find(|m|
156:                  (m.platform.architecture == "amd64" || m.platform.architecture == "x86_64")
157:                  && m.platform.os == "linux"
158:              ).ok_or_else(|| anyhow!("No linux/amd64 manifest found in list"))?;
159:              info!("Resolved linux/amd64 digest: {}", target.digest);
160:              let resolved_url = format!("{}://{}/v2/{}/manifests/{}", proto, registry, repository, target.digest);
161:              let mut req = self.client.get(&resolved_url)
162:                   .header("Accept", "application/vnd.docker.distribution.manifest.v2+json, application/vnd.oci.image.manifest.v1+json");
163:              if let Some(t) = self.token_cache.get(&cache_key) {
164:                   req = req.header("Authorization", format!("Bearer {}", t));
165:              }
166:              let resolved_resp = req.send().await?;
167:              return Ok(resolved_resp.text().await?);
168:          }
169:         Ok(body)
170:     }
171:     pub async fn pull_layer(&mut self, image: &str, digest: &str) -> Result<Vec<u8>> {
172:         let (registry, repository, _) = self.parse_image_ref(image);
173:         let proto = if registry.contains("localhost") { "http" } else { "https" };
174:         let layer_url = format!("{}://{}/v2/{}/blobs/{}", proto, registry, repository, digest);
175:         info!("Fetching layer blob: {}", digest);
176:         let cache_key = format!("{}/{}", registry, repository);
177:         let token = self.token_cache.get(&cache_key).cloned();
178:         let mut req = self.client.get(&layer_url);
179:         if let Some(t) = &token {
180:              req = req.header("Authorization", format!("Bearer {}", t));
181:         }
182:         let resp = req.send().await?;
183:         let resp = if resp.status() == reqwest::StatusCode::UNAUTHORIZED {
184:              debug!("Layer 401. Refreshing token...");
185:              let auth_header = resp.headers().get("www-authenticate")
186:                  .ok_or_else(|| anyhow!("401 but no Www-Authenticate"))?
187:                  .to_str()?;
188:              let realm = extract_field(auth_header, "realm").ok_or_else(|| anyhow!("Missing realm"))?;
189:              let service = extract_field(auth_header, "service");
190:              let scope = extract_field(auth_header, "scope");
191:              let new_token = self.fetch_token(&realm, service.as_deref(), scope.as_deref(), &registry).await?;
192:              self.token_cache.insert(cache_key, new_token.clone());
193:              self.client.get(&layer_url)
194:                  .header("Authorization", format!("Bearer {}", new_token))
195:                  .send().await?
196:         } else {
197:              resp
198:         };
199:         if !resp.status().is_success() {
200:              return Err(anyhow!("Failed to fetch layer {}: {}", digest, resp.status()));
201:         }
202:         let bytes = resp.bytes().await?;
203:         Ok(bytes.to_vec())
204:     }
205:     fn parse_image_ref(&self, image: &str) -> (String, String, String) {
206:         let (rest, tag) = if let Some((r, t)) = image.rsplit_once(':') {
207:              (r, t)
208:         } else {
209:              (image, "latest")
210:         };
211:         let (registry, repository) = if let Some((reg, repo)) = rest.split_once('/') {
212:             if reg.contains('.') || (reg.contains(':') && !reg.contains("docker.io")) || reg == "localhost" {
213:                 (reg, repo)
214:             } else {
215:                 ("registry-1.docker.io", rest)
216:             }
217:         } else {
218:             ("registry-1.docker.io", rest)
219:         };
220:         let final_repo = if registry == "registry-1.docker.io" && !repository.contains('/') {
221:              format!("library/{}", repository)
222:         } else {
223:              repository.to_string()
224:         };
225:         let final_reg = if registry == "docker.io" { "registry-1.docker.io" } else { registry };
226:         (final_reg.to_string(), final_repo, tag.to_string())
227:     }
228:     pub fn parse_layers(&self, manifest_json: &str) -> Result<Vec<String>> {
229:         let v2: ManifestV2 = serde_json::from_str(manifest_json)
230:             .map_err(|e| anyhow!("Failed to parse Manifest V2: {}", e))?;
231:         Ok(v2.layers.iter().map(|l| l.digest.clone()).collect())
232:     }
233: }
234: fn extract_field(header: &str, key: &str) -> Option<String> {
235:     let key_eq = format!("{}=", key);
236:     header.split(',')
237:         .find_map(|p| {
238:             let mut part = p.trim();
239:             if part.to_lowercase().starts_with("bearer ") {
240:                 part = &part[7..].trim();
241:             }
242:             if part.starts_with(&key_eq) {
243:                 part.split('"').nth(1).map(|s| s.to_string())
244:             } else {
245:                 None
246:             }
247:         })
248: }
</file>

<file path="crates/ignite-core/src/slirp.rs">
 1: use anyhow::{Result, anyhow};
 2: use std::process::{Command, Child};
 3: use std::path::Path;
 4: use tracing::{info, error};
 5: #[derive(Debug)]
 6: pub struct SlirpManager {
 7:     process: Option<Child>,
 8:     socket_path: String,
 9: }
10: impl SlirpManager {
11:     pub fn new(socket_path: &str) -> Self {
12:         Self {
13:             process: None,
14:             socket_path: socket_path.to_string(),
15:         }
16:     }
17:     pub fn check_available() -> Result<()> {
18:         let status = Command::new("slirp4netns").arg("--version").output();
19:         match status {
20:             Ok(o) if o.status.success() => Ok(()),
21:             _ => Err(anyhow!("slirp4netns not found. Please install it for rootless networking.")),
22:         }
23:     }
24:     pub fn spawn(&mut self, target_pid: u32, interface_name: &str, ports: &[crate::api::PortMapping]) -> Result<()> {
25:         info!("Starting slirp4netns for PID {} with {} ports", target_pid, ports.len());
26:         let mut cmd = Command::new("slirp4netns");
27:         cmd.arg("--configure")
28:            .arg("--mtu=65520")
29:            .arg("--disable-host-loopback")
30:            .arg("--api-socket").arg(&self.socket_path);
31:         for port in ports {
32:             cmd.arg(format!("--publish={}:{}", port.host_port, port.vm_port));
33:         }
34:         let child = cmd
35:             .arg(target_pid.to_string())
36:             .arg(interface_name)
37:             .spawn()
38:             .map_err(|e| anyhow!("Failed to spawn slirp4netns: {}", e))?;
39:         self.process = Some(child);
40:         Ok(())
41:     }
42:     pub fn kill(&mut self) {
43:         if let Some(mut child) = self.process.take() {
44:             let _ = child.kill();
45:             let _ = child.wait();
46:         }
47:     }
48: }
49: impl Drop for SlirpManager {
50:     fn drop(&mut self) {
51:         self.kill();
52:     }
53: }
</file>

