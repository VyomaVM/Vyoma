 754: pub async fn list_vms(State(state): State<AppState>) -> Json<ListResponse> {
 755:     let instances: Vec<Arc<TokioMutex<VmInstance>>> = {
 756:         let vms_map = state.vms.lock().unwrap();
 757:         vms_map.values().cloned().collect()
 758:     };
 759:     let mut summaries = Vec::new();
 760:     for arc_inst in instances {
 761:         let inst = arc_inst.lock().await;
 762:         summaries.push(VmSummary {
 763:             id: inst.id.clone(),
 764:             ip_address: inst.ip_address.clone(),
 765:             hostname: inst.hostname.clone(),
 766:             labels: inst.labels.clone(),
 767:             base_image_path: inst.base_image_path.clone(),
 768:             vcpu: inst.vcpu,
 769:             mem_size_mib: inst.mem_size_mib,
 770:         });
 771:     }
