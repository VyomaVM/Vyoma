 69: impl VmInstance {
 70:     pub fn save_state(&self) -> anyhow::Result<()> {
 71:         let state = VmState {
 72:             id: self.id.clone(),
 73:             tap_name: self.tap_name.clone(),
 74:             dm_name: self.dm_name.clone(),
 75:             loop_devices: self.loop_devices.clone(),
 76:             cow_file_path: self.cow_file_path.clone(),
 77:             ip_address: self.ip_address.clone(),
 78:             cgroup_path: self.cgroup_path.clone(),
 79:             netns_path: self.netns_path.clone(),
 80:             ports: self.config_ports.clone(),
 81:             volumes: self.config_volumes.clone(),
 82:             hostname: self.hostname.clone(),
 83:             labels: self.labels.clone(),
 84:             base_image_path: self.base_image_path.clone(),
 85:             vcpu: self.vcpu,
 86:             mem_size_mib: self.mem_size_mib,
 87:         };
 88:         let home = dirs::home_dir().ok_or_else(|| anyhow::anyhow!("No home dir"))?;
 89:         let vm_dir = home.join(".ignite").join("vms").join(&self.id);
 90:         if !vm_dir.exists() {
 91:             std::fs::create_dir_all(&vm_dir)?;
 92:         }
 93:         let state_path = vm_dir.join("state.json");
 94:         let f = std::fs::File::create(state_path)?;
 95:         serde_json::to_writer_pretty(f, &state)?;
 96:         Ok(())
 97:     }
 98:     pub async fn cleanup(&mut self, cni_manager: &ignite_core::cni::CniManager) {
 99:         info!("Cleaning up VM resources for {}", self.id);
100:         if let Err(e) = self.vmm.kill() {
101:             error!("Failed to kill VMM: {}", e);
102:         }
103:         if let Some(netns) = &self.netns_path {
104:             if let Err(e) = cni_manager.del(None, &self.id, netns, "eth0") {
105:                 error!("CNI DEL failed: {}", e);
106:             }
107:             let netns_name = format!("vm-{}", self.id);
108:             let _ = Command::new("ip")
109:                 .args(&["netns", "delete", &netns_name])
110:                 .output();
111:         }
112:         if !self.tap_name.is_empty() {
113:             if let Err(e) = NetworkManager::remove_interface(&self.tap_name) {
114:                 error!("Failed to remove TAP {}: {}", self.tap_name, e);
115:             }
116:         }
117:         if let Err(e) = StorageManager::remove_dm_device(&self.dm_name) {
118:             error!("Failed to remove DM {}: {}", self.dm_name, e);
119:         }
120:         for dev in &self.loop_devices {
121:             if let Err(e) = StorageManager::detach_loop_device(dev) {
122:                 error!("Failed to detach loop {}: {}", dev, e);
123:             }
124:         }
125:         if std::path::Path::new(&self.cow_file_path).exists() {
126:             let _ = std::fs::remove_file(&self.cow_file_path);
127:         }
128:         for task in &self.proxy_tasks {
129:             task.abort();
130:         }
131:         if let Some(_path) = &self.cgroup_path {
132:             let cm = CgroupManager::new();
133:             if let Err(e) = cm.remove_vm_cgroup(&self.id) {
134:                 error!("Failed to remove cgroup for {}: {}", self.id, e);
135:             }
136:         }
137:     }
138: }
