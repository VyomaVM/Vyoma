 158: #[tokio::main]
 159: async fn main() -> Result<()> {
 160:     tracing_subscriber::fmt::init();
 161:     let cli = Cli::parse();
 162:     let client = Client::new();
 163:     let daemon_url = &cli.address;
 164:     match cli.command {
 165:         Commands::Pull { image } => {
 166:             info!("Requesting to pull image: {}", image);
 167:             let resp = client
 168:                 .post(format!("{}/pull", daemon_url))
 169:                 .json(&serde_json::json!({ "image": image }))
 170:                 .send()
 171:                 .await;
 172:             handle_simple_response(resp, daemon_url).await?;
 173:         }
 174:         Commands::Run {
 175:             image,
 176:             vcpu,
 177:             memory,
 178:             ports,
 179:             volumes,
 180:             hostname,
 181:             labels,
 182:         } => {
 183:             info!("Requesting to run image: {}", image);
 184:             let mut port_mappings = Vec::new();
 185:             for p in ports {
 186:                 let parts: Vec<&str> = p.split(':').collect();
 187:                 if parts.len() != 2 {
 188:                     error!("Invalid port format: {}. Use host:vm (e.g., 8080:80)", p);
 189:                     return Ok(());
 190:                 }
 191:                 let host_port = parts[0]
 192:                     .parse::<u16>()
 193:                     .map_err(|_| anyhow::anyhow!("Invalid host port: {}", parts[0]))?;
 194:                 let vm_port = parts[1]
 195:                     .parse::<u16>()
 196:                     .map_err(|_| anyhow::anyhow!("Invalid vm port: {}", parts[1]))?;
 197:                 port_mappings.push(PortMapping { host_port, vm_port });
 198:             }
 199:             let mut volume_mounts = Vec::new();
 200:             for v in volumes {
 201:                 let parts: Vec<&str> = v.split(':').collect();
 202:                 if parts.len() != 2 {
 203:                     error!(
 204:                         "Invalid volume format: {}. Use host:vm (e.g., /foo:/bar)",
 205:                         v
 206:                     );
 207:                     return Ok(());
 208:                 }
 209:                 volume_mounts.push(VolumeMount {
 210:                     host_path: parts[0].to_string(),
 211:                     vm_path: parts[1].to_string(),
 212:                     read_only: false,
 213:                 });
 214:             }
 215:             let mut label_map = HashMap::new();
 216:             for l in labels {
 217:                 if let Some((k, v)) = l.split_once('=') {
 218:                     label_map.insert(k.to_string(), v.to_string());
 219:                 } else {
 220:                     label_map.insert(l.clone(), "".to_string());
 221:                 }
 222:             }
 223:             let payload = RunRequest {
 224:                 image,
 225:                 vcpu,
 226:                 mem_size_mib: memory,
 227:                 ports: port_mappings,
 228:                 volumes: volume_mounts,
 229:                 hostname,
 230:                 labels: label_map,
 231:             };
 232:             let resp = client
 233:                 .post(format!("{}/run", daemon_url))
 234:                 .json(&payload)
 235:                 .send()
 236:                 .await;
 237:             handle_response(resp, daemon_url).await?;
 238:         }
 239:         Commands::Stop { id } => {
 240:             info!("Requesting to stop VM: {}", id);
 241:             let resp = client
