  6: #[derive(Clone, Debug, Serialize, Deserialize)]
  7: pub struct NodeInfo {
  8:     pub id: String,
  9:     pub ip: String,
 10:     pub role: String,
 11:     pub subnet_id: u8,
 12: }
 13: #[derive(Clone)]
 14: pub struct ClusterManager {
 15:     pub self_node: Arc<Mutex<Option<NodeInfo>>>,
 16:     pub peers: Arc<Mutex<HashMap<String, NodeInfo>>>,
 17:     pub subnet_allocator: Arc<Mutex<u8>>,
 18: }
 19: fn get_outbound_ip() -> String {
 20:     match std::net::UdpSocket::bind("0.0.0.0:0") {
 21:         Ok(s) => match s.connect("8.8.8.8:80") {
 22:             Ok(_) => s.local_addr().map(|a| a.ip().to_string()).unwrap_or("127.0.0.1".to_string()),
 23:             Err(_) => "127.0.0.1".to_string(),
 24:         },
 25:         Err(_) => "127.0.0.1".to_string(),
 26:     }
 27: }
 28: impl ClusterManager {
 29:     pub fn new() -> Self {
 30:         Self {
 31:             self_node: Arc::new(Mutex::new(None)),
 32:             peers: Arc::new(Mutex::new(HashMap::new())),
 33:             subnet_allocator: Arc::new(Mutex::new(1)),
 34:         }
 35:     }
 36:     pub fn init(&self) -> String {
 37:         let id = uuid::Uuid::new_v4().to_string();
 38:         let node = NodeInfo {
 39:             id: id.clone(),
 40:             ip: get_outbound_ip(),
 41:             role: "seed".to_string(),
 42:             subnet_id: 1,
 43:         };
 44:         *self.self_node.lock().unwrap() = Some(node.clone());
 45:         self.peers.lock().unwrap().insert(id.clone(), node.clone());
 46:         *self.subnet_allocator.lock().unwrap() = 2;
 47:         info!("Swarm Initialized. Node ID: {} (Subnet 10.42.1.0/24)", id);
 48:         self.setup_local_networking(1);
 49:         id
 50:     }
 51:     pub async fn join(&self, seed_ip: &str) -> anyhow::Result<()> {
 52:         let id = uuid::Uuid::new_v4().to_string();
 53:         let my_ip = get_outbound_ip();
 54:         let req_node = NodeInfo {
 55:             id: id.clone(),
 56:             ip: my_ip,
 57:             role: "worker".to_string(),
 58:             subnet_id: 0,
 59:         };
 60:         info!("Joining swarm at {}...", seed_ip);
 61:         let client = reqwest::Client::new();
 62:         let url = format!("http://{}:3000/swarm/register", seed_ip);
 63:         let resp = client.post(&url)
 64:             .json(&req_node)
 65:             .send()
 66:             .await?;
 67:         if !resp.status().is_success() {
 68:             return Err(anyhow::anyhow!("Failed to join swarm: {}", resp.status()));
 69:         }
 70:         #[derive(Deserialize)]
 71:         struct RegisterResponse {
 72:             assigned: NodeInfo,
 73:             peers: Vec<NodeInfo>,
 74:         }
 75:         let body: RegisterResponse = resp.json().await?;
 76:         let assigned_node = body.assigned;
 77:         let peers = body.peers;
 78:         info!("Joined Swarm! Assigned Subnet: 10.42.{}.0/24", assigned_node.subnet_id);
 79:         *self.self_node.lock().unwrap() = Some(assigned_node.clone());
 80:         self.setup_local_networking(assigned_node.subnet_id);
 81:         {
 82:             let mut p = self.peers.lock().unwrap();
 83:             for peer in peers {
 84:                 p.insert(peer.id.clone(), peer.clone());
 85:                 if peer.id != assigned_node.id {
 86:                    self.establish_route(&peer);
 87:                 }
 88:             }
 89:         }
 90:         Ok(())
 91:     }
 92:     pub fn handle_registration(&self, mut node: NodeInfo) -> (NodeInfo, Vec<NodeInfo>) {
 93:         let mut peers = self.peers.lock().unwrap();
 94:         if let Some(existing) = peers.get(&node.id) {
 95:             return (existing.clone(), peers.values().cloned().collect());
 96:         }
 97:         let mut alloc = self.subnet_allocator.lock().unwrap();
 98:         node.subnet_id = *alloc;
 99:         *alloc += 1;
100:         info!("Registered Node {} -> Subnet {}", node.id, node.subnet_id);
101:         peers.insert(node.id.clone(), node.clone());
102:         self.establish_route(&node);
103:         (node, peers.values().cloned().collect())
104:     }
105:     #[allow(dead_code)]
106:     pub fn add_node_notify(&self, node: NodeInfo) {
107:         let mut peers = self.peers.lock().unwrap();
108:         if !peers.contains_key(&node.id) {
109:              info!("Discovered Node {} (Subnet {})", node.id, node.subnet_id);
110:              self.establish_route(&node);
111:              peers.insert(node.id.clone(), node);
112:         }
113:     }
114:     pub fn list_nodes(&self) -> Vec<NodeInfo> {
115:         self.peers.lock().unwrap().values().cloned().collect()
116:     }
117:     fn setup_local_networking(&self, subnet_id: u8) {
118:         let subnet = format!("10.42.{}.0/24", subnet_id);
119:         let bridge_ip = format!("10.42.{}.1", subnet_id);
120:         let home = dirs::home_dir().expect("No home dir");
121:         let cni_config_dir = home.join(".ignite").join("cni").join("net.d");
122:         let bridge_conf = cni_config_dir.join("10-ignite-bridge.conf");
123:         let conf = serde_json::json!({
124:             "cniVersion": "0.4.0",
125:             "name": "ignite-net",
126:             "type": "bridge",
127:             "bridge": "ign0",
128:             "isGateway": true,
129:             "ipMasq": true,
130:             "ipam": {
131:                 "type": "host-local",
132:                 "subnet": subnet,
133:                 "routes": [ { "dst": "0.0.0.0/0" } ]
134:             }
135:         });
136:         if let Ok(f) = std::fs::File::create(&bridge_conf) {
137:             serde_json::to_writer_pretty(f, &conf).unwrap();
138:         }
139:         self.ensure_vxlan_device();
140:     }
141:     fn ensure_vxlan_device(&self) {
142:         let if_name = "ign-vxlan";
143:         let output = Command::new("ip").args(&["link", "show", if_name]).output();
144:         if let Ok(o) = output {
145:             if o.status.success() { return; }
146:         }
147:         info!("Creating VXLAN device {}", if_name);
148:         let _ = Command::new("ip")
149:             .args(&["link", "add", if_name, "type", "vxlan", "id", "42", "dstport", "4789", "external"])
150:             .output();
151:         let _ = Command::new("ip")
152:             .args(&["link", "set", if_name, "up"])
153:             .output();
154:     }
155:     fn establish_route(&self, peer: &NodeInfo) {
156:         let peer_subnet = format!("10.42.{}.0/24", peer.subnet_id);
157:         let if_name = "ign-vxlan";
158:         info!("Adding route to {} via VXLAN -> {}", peer_subnet, peer.ip);
159:         let res = Command::new("ip")
160:             .args(&[
161:                 "route", "add", &peer_subnet,
162:                 "encap", "vxlan", "id", "42", "dst", &peer.ip,
163:                 "dev", if_name
164:             ])
165:             .output();
166:         if let Err(e) = res {
167:             error!("Failed to add route: {}", e);
168:         } else {
169:              let out = res.unwrap();
170:              if !out.status.success() {
171:                   warn!("Route add failed (maybe exists): {}", String::from_utf8_lossy(&out.stderr));
172:              }
173:         }
174:     }
175: }
