202:         Ok(body)
203:     }
204:     pub async fn pull_layer(&mut self, image: &str, digest: &str) -> Result<Vec<u8>> {
205:         let (registry, repository, _) = self.parse_image_ref(image);
206:         let proto = if registry.contains("localhost") { "http" } else { "https" };
207:         let layer_url = format!("{}://{}/v2/{}/blobs/{}", proto, registry, repository, digest);
208:         info!("Fetching layer blob: {}", digest);
209:         let cache_key = format!("{}/{}", registry, repository);
210:         let token = self.token_cache.get(&cache_key).cloned();
211:         let mut req = self.client.get(&layer_url);
212:         if let Some(t) = &token {
213:              req = req.header("Authorization", format!("Bearer {}", t));
214:         }
215:         let resp = req.send().await?;
216:         let resp = if resp.status() == reqwest::StatusCode::UNAUTHORIZED {
217:              debug!("Layer 401. Refreshing token...");
218:              let auth_header = resp.headers().get("www-authenticate")
219:                  .ok_or_else(|| anyhow!("401 but no Www-Authenticate"))?
220:                  .to_str()?;
221:              let realm = extract_field(auth_header, "realm").ok_or_else(|| anyhow!("Missing realm"))?;
222:              let service = extract_field(auth_header, "service");
223:              let scope = extract_field(auth_header, "scope");
224:              let new_token = self.fetch_token(&realm, service.as_deref(), scope.as_deref(), &registry).await?;
225:              self.token_cache.insert(cache_key, new_token.clone());
226:              self.client.get(&layer_url)
227:                  .header("Authorization", format!("Bearer {}", new_token))
228:                  .send().await?
229:         } else {
230:              resp
231:         };
232:         if !resp.status().is_success() {
233:              return Err(anyhow!("Failed to fetch layer {}: {}", digest, resp.status()));
234:         }
235:         let bytes = resp.bytes().await?;
236:         Ok(bytes.to_vec())
237:     }
238:     fn parse_image_ref(&self, image: &str) -> (String, String, String) {
239:         let (rest, tag) = if let Some((r, t)) = image.rsplit_once(':') {
240:              (r, t)
241:         } else {
242:              (image, "latest")
243:         };
244:         let (registry, repository) = if let Some((reg, repo)) = rest.split_once('/') {
245:             if reg.contains('.') || (reg.contains(':') && !reg.contains("docker.io")) || reg == "localhost" {
246:                 (reg, repo)
247:             } else {
248:                 ("registry-1.docker.io", rest)
249:             }
250:         } else {
251:             ("registry-1.docker.io", rest)
252:         };
253:         let final_repo = if registry == "registry-1.docker.io" && !repository.contains('/') {
254:              format!("library/{}", repository)
255:         } else {
256:              repository.to_string()
257:         };
258:         let final_reg = if registry == "docker.io" { "registry-1.docker.io" } else { registry };
259:         (final_reg.to_string(), final_repo, tag.to_string())
260:     }
261:     pub fn parse_layers(&self, manifest_json: &str) -> Result<Vec<String>> {
262:         let v2: ManifestV2 = serde_json::from_str(manifest_json)
263:             .map_err(|e| anyhow!("Failed to parse Manifest V2: {}", e))?;
264:         Ok(v2.layers.iter().map(|l| l.digest.clone()).collect())
265:     }
266:     pub fn parse_config_digest(&self, manifest_json: &str) -> Result<String> {
267:         let v2: ManifestV2 = serde_json::from_str(manifest_json)
268:             .map_err(|e| anyhow!("Failed to parse Manifest V2: {}", e))?;
269:         Ok(v2.config.digest)
270:     }
271:     pub async fn pull_config_blob(&mut self, image: &str, digest: &str) -> Result<OciImageConfig> {
272:         let blob = self.pull_layer(image, digest).await?;
273:         let full_config: OciConfigBlob = serde_json::from_slice(&blob)
274:             .map_err(|e| anyhow!("Failed to parse OCI config blob: {}", e))?;
275:         Ok(full_config.config)
276:     }
277: }
278: fn extract_field(header: &str, key: &str) -> Option<String> {
279:     let key_eq = format!("{}=", key);
280:     header.split(',')
281:         .find_map(|p| {
282:             let mut part = p.trim();
283:             if part.to_lowercase().starts_with("bearer ") {
284:                 part = &part[7..].trim();
285:             }
286:             if part.starts_with(&key_eq) {
287:                 part.split('"').nth(1).map(|s| s.to_string())
288:             } else {
289:                 None
290:             }
291:         })
292: }
