1756: #### 5.6.1 Docker Hub → VMIF Bridge
1757: 
1758: ```rust
1759: // crates/ignite-image/src/hub_bridge.rs
1760: 
1761: /// Convert a Docker Hub OCI image to VMIF format.
1762: /// This is the core of the "Ignite Hub bridge" feature.
1763: /// Called once per image tag; result cached forever.
1764: pub async fn convert_docker_hub_to_vmif(
1765:     image_ref: &str,
1766:     kernel_ref: Option<&str>,
1767: ) -> Result<VmifManifest> {
1768:     // 1. Pull OCI layers from Docker Hub
1769:     let oci_client = OciClient::new();
1770:     let (manifest, config, layers) = oci_client.pull_all(image_ref).await?;
1771:     
1772:     // 2. Unpack layers into staging directory (existing layer flattening logic)
1773:     let staging_dir = temp_dir();
1774:     unpack_layers(&layers, &staging_dir).await?;
1775:     
1776:     // 3. Convert ext4 → squashfs for better compression + read-only semantics
1777:     let sqfs_path = staging_dir.join("rootfs.sqfs");
1778:     Command::new("mksquashfs")
1779:         .args([staging_dir.to_str().unwrap(), sqfs_path.to_str().unwrap(),
1780:                "-comp", "zstd", "-Xcompression-level", "9"])
1781:         .status()?;
1782:     
1783:     // 4. Build ignite.toml metadata
1784:     let vmif = VmifManifest {
1785:         schema_version: 1,
1786:         created: chrono::Utc::now().to_rfc3339(),
1787:         arch: "amd64".to_string(),
1788:         kernel: kernel_ref.map(str::to_string),
1789:         rootfs: sha256_of_file(&sqfs_path)?,
1790:         config: parse_oci_config(&config)?,
1791:         labels: manifest.annotations.unwrap_or_default(),
1792:         size_bytes: file_size(&sqfs_path)?,
1793:     };
1794:     
1795:     Ok(vmif)
1796: }
1797: ```
