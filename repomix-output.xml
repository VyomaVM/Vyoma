49:         let file_path = path.join("memory.max");
50:         fs::write(file_path, bytes.to_string())?;
51:         Ok(())
52:     }
53:     pub fn add_process(&self, vm_id: &str, pid: u32) -> Result<()> {
54:         let path = Path::new(&self.root_path).join(format!("ignite-{}", vm_id));
55:         let file_path = path.join("cgroup.procs");
56:         fs::write(file_path, pid.to_string())?;
