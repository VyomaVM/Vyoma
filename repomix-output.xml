  1: use serde::{Deserialize, Serialize};
  2: use std::collections::{HashMap, HashSet};
  3: use std::fs;
  4: use std::path::Path;
  5: use anyhow::Result;
  6: #[derive(Debug, Clone, Serialize, Deserialize)]
  7: pub struct IgniteCompose {
  8:     pub version: String,
  9:     pub services: HashMap<String, Service>,
 10: }
 11: #[derive(Debug, Clone, Serialize, Deserialize)]
 12: #[serde(untagged)]
 13: pub enum BuildSource {
 14:     Path(String),
 15:     Config(BuildConfig),
 16: }
 17: #[derive(Debug, Clone, Serialize, Deserialize)]
 18: pub struct BuildConfig {
 19:     pub context: String,
 20:     pub ignitefile: Option<String>,
 21: }
 22: #[derive(Debug, Clone, Serialize, Deserialize)]
 23: pub struct Service {
 24:     pub image: Option<String>,
 25:     pub build: Option<BuildSource>,
 26:     pub cpus: Option<u32>,
 27:     pub memory: Option<u32>,
 28:     pub ports: Option<Vec<String>>,
 29:     pub volumes: Option<Vec<String>>,
 30:     pub environment: Option<HashMap<String, String>>,
 31:     pub command: Option<String>,
 32:     pub depends_on: Option<Vec<String>>,
 33: }
 34: impl IgniteCompose {
 35:     pub fn from_file<P: AsRef<Path>>(path: P) -> Result<Self> {
 36:         let content = fs::read_to_string(path)?;
 37:         let compose: IgniteCompose = serde_yaml::from_str(&content)?;
 38:         Ok(compose)
 39:     }
 40:     pub fn from_str(content: &str) -> Result<Self> {
 41:         let compose: IgniteCompose = serde_yaml::from_str(content)?;
 42:         Ok(compose)
 43:     }
 44:     pub fn start_order(&self) -> Result<Vec<(String, Service)>> {
 45:         let mut order = Vec::new();
 46:         let mut visited = HashSet::new();
 47:         let mut visiting = HashSet::new();
 48:         let mut keys: Vec<_> = self.services.keys().collect();
 49:         keys.sort();
 50:         for name in keys {
 51:             self.visit(name, &mut visited, &mut visiting, &mut order)?;
 52:         }
 53:         Ok(order)
 54:     }
 55:     fn visit(&self, name: &String, visited: &mut HashSet<String>, visiting: &mut HashSet<String>, order: &mut Vec<(String, Service)>) -> Result<()> {
 56:         if visited.contains(name) { return Ok(()); }
 57:         if visiting.contains(name) { return Err(anyhow::anyhow!("Circular dependency detected involving {}", name)); }
 58:         visiting.insert(name.clone());
 59:         if let Some(service) = self.services.get(name) {
 60:             if let Some(deps) = &service.depends_on {
 61:                 for dep in deps {
 62:                     if !self.services.contains_key(dep) {
 63:                          return Err(anyhow::anyhow!("Service '{}' depends on undefined service '{}'", name, dep));
 64:                     }
 65:                     self.visit(dep, visited, visiting, order)?;
 66:                 }
 67:             }
 68:             visiting.remove(name);
 69:             visited.insert(name.clone());
 70:             order.push((name.clone(), service.clone()));
 71:         }
 72:         Ok(())
 73:     }
 74: }
