 753: pub async fn list_vms(State(state): State<AppState>) -> Json<ListResponse> {
 754:     let instances: Vec<Arc<TokioMutex<VmInstance>>> = {
 755:         let vms_map = state.vms.lock().unwrap();
 756:         vms_map.values().cloned().collect()
 757:     };
 758:     let mut summaries = Vec::new();
 759:     for arc_inst in instances {
 760:         let inst = arc_inst.lock().await;
 761:         summaries.push(VmSummary {
 762:             id: inst.id.clone(),
 763:             ip_address: inst.ip_address.clone(),
