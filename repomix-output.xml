 775:     Command::new("git")
 776:         .args(&["config", "user.email", "ignite@daemon"])
 777:         .current_dir(path)
 778:         .output()?;
 779:     Command::new("git")
 780:         .args(&["config", "user.name", "Ignite Daemon"])
