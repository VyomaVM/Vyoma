 527: pub async fn snapshot_vm(
 528:     State(state): State<AppState>,
 529:     Path(id): Path<String>,
 530: ) -> Result<String, (StatusCode, String)> {
 531:     info!("Request to snapshot VM: {}", id);
 532:     let vm_arc = {
 533:         let vms = state.vms.lock().unwrap();
 534:         vms.get(&id).cloned()
 535:     };
 536:     if let Some(vm_mutex) = vm_arc {
 537:         let vm = vm_mutex.lock().await;
 538:         // Define paths
 539:         let home =
 540:             dirs::home_dir().ok_or((StatusCode::INTERNAL_SERVER_ERROR, "No home dir".into()))?;
 541:         let vm_dir = home.join(".ignite").join("vms").join(&id);
 542:         let snapshot_path = vm_dir.join("snapshot.snap");
 543:         let mem_path = vm_dir.join("memory.mem");
 544:         // 1. Pause VM (Required for snapshot)
 545:         vm.vmm.pause_instance().await.map_err(|e| {
 546:             (
 547:                 StatusCode::INTERNAL_SERVER_ERROR,
 548:                 format!("Failed to pause: {}", e),
 549:             )
 550:         })?;
 551:         // 2. Create Snapshot
 552:         let snap_result = vm
 553:             .vmm
 554:             .create_snapshot(
 555:                 snapshot_path.to_string_lossy().as_ref(),
 556:                 mem_path.to_string_lossy().as_ref(),
 557:             )
 558:             .await;
 559:         // 3. Resume VM (Always resume, even if snapshot failed)
 560:         if let Err(e) = vm.vmm.resume_instance().await {
 561:             error!("Failed to resume VM {} after snapshot: {}", id, e);
 562:         }
 563:         snap_result.map_err(|e| {
 564:             (
 565:                 StatusCode::INTERNAL_SERVER_ERROR,
 566:                 format!("Snapshot failed: {}", e),
 567:             )
 568:         })?;
 569:         // Commit snapshot to Git
 570:         if let Err(e) = git_commit(&vm_dir, &format!("Snapshot {}", id)) {
 571:             error!("Failed to git commit snapshot: {}", e);
 572:         }
 573:         Ok(format!("Snapshot created for VM {}", id))
 574:     } else {
 575:         Err((StatusCode::NOT_FOUND, "VM not found".to_string()))
 576:     }
 577: }
 578: #[derive(Deserialize)]
 579: pub struct RestoreRequest {
 580:     snapshot_path: String,
 581:     mem_path: String,
 582:     cow_path: String, // Path to the existing COW file to restore from
 583:     // For MVP, we presume the disk state (COW) is already in a known location or passed here.
 584:     #[allow(dead_code)]
 585:     original_vm_id: String, // To find the original disk resources
 586: }
 587: pub async fn restore_vm(
 588:     State(state): State<AppState>,
 589:     Json(payload): Json<RestoreRequest>,
 590: ) -> Result<Json<RunResponse>, (StatusCode, String)> {
 591:     info!(
 592:         "Request to restore VM from snapshot: {}",
 593:         payload.snapshot_path
 594:     );
 595:     // 1. Setup New VM State
 596:     // We need to CLONE the disk state or reusing it?
 597:     // "Teleportation" usually implies moving.
 598:     // "Restoration" (Backup) implies reusing.
 599:     // Let's implement a "Clone from Snapshot" flow.
 600:     let home = dirs::home_dir().ok_or((StatusCode::INTERNAL_SERVER_ERROR, "No home dir".into()))?;
 601:     let ignite_root = home.join(".ignite");
 602:     let images_root = ignite_root.join("images");
 603:     let vms_root = ignite_root.join("vms");
 604:     let safe_image_name = "alpine_latest";
 605:     let image_store_path = images_root.join(&safe_image_name);
 606:     let base_image_file = image_store_path.join("base.ext4");
 607:     let vm_id = uuid::Uuid::new_v4().to_string();
 608:     let vm_dir = vms_root.join(&vm_id);
 609:     std::fs::create_dir_all(&vm_dir)
 610:         .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 611:     let cow_file = vm_dir.join("diff.cow");
 612:     info!("Restoring disk state from {}", payload.cow_path);
 613:     std::fs::copy(&payload.cow_path, &cow_file).map_err(|e| {
 614:         (
 615:             StatusCode::INTERNAL_SERVER_ERROR,
 616:             format!("Failed to copy COW file: {}", e),
 617:         )
 618:     })?;
 619:     let base_loop = StorageManager::setup_loop_device(&base_image_file).map_err(|e| {
 620:         (
 621:             StatusCode::INTERNAL_SERVER_ERROR,
 622:             format!("Loop base: {}", e),
 623:         )
 624:     })?;
 625:     let cow_loop = StorageManager::setup_loop_device(&cow_file).map_err(|e| {
 626:         (
 627:             StatusCode::INTERNAL_SERVER_ERROR,
 628:             format!("Loop cow: {}", e),
 629:         )
 630:     })?;
 631:     let dm_name = format!("ign-{}", vm_id);
 632:     let size_mb = 2048;
 633:     let size_sectors = size_mb * 1024 * 1024 / 512;
 634:     let dm_path = StorageManager::create_dm_snapshot(&dm_name, &base_loop, &cow_loop, size_sectors)
 635:         .map_err(|e| {
 636:             (
 637:                 StatusCode::INTERNAL_SERVER_ERROR,
 638:                 format!("DM create: {}", e),
 639:             )
 640:         })?;
 641:     let bridge_name = "ign0";
 642:     let bridge_cidr = "172.16.0.1/24";
 643:     let tap_name = format!("tap{}", &vm_id[0..8]);
 644:     NetworkManager::setup_tap(&tap_name, bridge_name).map_err(|e| {
 645:         (
 646:             StatusCode::INTERNAL_SERVER_ERROR,
 647:             format!("TAP setup: {}", e),
 648:         )
 649:     })?;
 650:     let random_octet = rand::random::<u8>();
 651:     let safe_octet = std::cmp::max(2, std::cmp::min(254, random_octet));
 652:     let vm_ip = format!("172.16.0.{}", safe_octet);
 653:     let socket_path = format!("/tmp/firecracker_{}.socket", vm_id);
 654:     let mut vmm = VmmManager::new(&socket_path);
 655:     if let Err(e) = vmm.start_daemon("bin/firecracker", None, state.rootless) {
 656:         return Err((
 657:             StatusCode::INTERNAL_SERVER_ERROR,
 658:             format!("Failed to start FC: {}", e),
 659:         ));
 660:     }
 661:     if let Err(e) = vmm
 662:         .load_snapshot(&payload.snapshot_path, &payload.mem_path)
 663:         .await
 664:     {
 665:         let _ = vmm.kill();
 666:         return Err((
 667:             StatusCode::INTERNAL_SERVER_ERROR,
 668:             format!("Load snapshot: {}", e),
 669:         ));
 670:     }
 671:     if let Err(e) = vmm.add_drive("rootfs", &dm_path, true).await {
 672:         let _ = vmm.kill();
 673:         return Err((
 674:             StatusCode::INTERNAL_SERVER_ERROR,
 675:             format!("Add drive: {}", e),
 676:         ));
 677:     }
 678:     if let Err(e) = vmm.add_network_interface("eth0", &tap_name, None).await {
 679:         let _ = vmm.kill();
 680:         return Err((StatusCode::INTERNAL_SERVER_ERROR, format!("Add net: {}", e)));
 681:     }
 682:     if let Err(e) = vmm.resume_instance().await {
 683:         let _ = vmm.kill();
 684:         return Err((
 685:             StatusCode::INTERNAL_SERVER_ERROR,
 686:             format!("Resume instance: {}", e),
 687:         ));
 688:     }
 689:     let proxy_tasks = Vec::new();
 690:     let instance = VmInstance {
 691:         vmm,
 692:         id: vm_id.clone(),
 693:         tap_name: tap_name.clone(),
 694:         dm_name: dm_name.clone(),
 695:         slirp: None,
 696:         loop_devices: vec![base_loop, cow_loop],
 697:         cow_file_path: cow_file.to_string_lossy().to_string(),
 698:         ip_address: vm_ip.clone(),
 699:         proxy_tasks,
 700:         fs_managers: Vec::new(),
 701:         cgroup_path: None,
 702:         netns_path: None,
 703:         config_ports: vec![],
 704:         config_volumes: vec![],
 705:         hostname: None,
 706:         labels: HashMap::new(),
 707:         base_image_path: String::new(),
 708:         vcpu: 1,
 709:         mem_size_mib: 512,
 710:     };
 711:     {
 712:         let mut vms = state.vms.lock().unwrap();
 713:         vms.insert(vm_id.clone(), Arc::new(TokioMutex::new(instance)));
 714:     }
 715:     Ok(Json(RunResponse {
 716:         vm_id,
 717:         status: "Restored".to_string(),
 718:         ip_address: vm_ip,
 719:     }))
 720: }
