1244: pub async fn start_process_monitor(state: AppState) {
1245:     tokio::spawn(async move {
1246:         let mut interval = tokio::time::interval(std::time::Duration::from_secs(5));
1247:         loop {
1248:             interval.tick().await;
1249:             let ids: Vec<String> = {
1250:                 let map = state.vms.lock().unwrap();
1251:                 map.keys().cloned().collect()
1252:             };
1253:             for id in ids {
1254:                 let vm_arc = {
1255:                     let map = state.vms.lock().unwrap();
1256:                     map.get(&id).cloned()
1257:                 };
1258:                 if let Some(vm_mutex) = vm_arc {
1259:                     let mut vm = vm_mutex.lock().await;
1260:                     match vm.vmm.try_wait() {
1261:                         Ok(Some(status)) => {
1262:                             let mut msg = format!(
1263:                                 "Monitor: VM {} Firecracker process EXITED (Reaped): {}",
1264:                                 id, status
1265:                             );
1266:                             if let Ok(count) = state.cgroups.get_oom_kill_count(&id) {
1267:                                 if count > 0 {
1268:                                     msg.push_str(&format!(
1269:                                         " [WARNING: OOM Kill Detected: {}]",
1270:                                         count
1271:                                     ));
1272:                                 }
1273:                             }
1274:                             error!("{}", msg);
1275:                         }
1276:                         Err(e) => error!("Monitor Check Error for VMM {}: {}", id, e),
1277:                         Ok(None) => {}
1278:                     }
1279:                     let fs_count = vm.fs_managers.len();
1280:                     for idx in 0..fs_count {
1281:                         let exit_status = {
1282:                             let fs = &mut vm.fs_managers[idx];
1283:                             match fs.try_wait() {
1284:                                 Ok(Some(s)) => Some(s),
1285:                                 Err(e) => {
1286:                                     error!("Monitor Check Error for FS {}: {}", id, e);
1287:                                     None
1288:                                 }
1289:                                 Ok(None) => None,
1290:                             }
1291:                         };
1292:                         if let Some(status) = exit_status {
1293:                             warn!(
1294:                                 "Monitor: VM {} VirtioFS (vol{}) EXITED with {}. Restarting...",
1295:                                 id, idx, status
1296:                             );
1297:                             let host_path = vm.config_volumes.get(idx).map(|v| v.host_path.clone());
1298:                             if let Some(path) = host_path {
1299:                                 let fs = &mut vm.fs_managers[idx];
1300:                                 if let Err(e) = fs.start(&path) {
1301:                                     error!(
1302:                                         "Monitor: FAILED to auto-restart VirtioFS for VM {}: {}",
1303:                                         id, e
1304:                                     );
1305:                                 } else {
1306:                                     info!("Monitor: RESTARTED VirtioFS for VM {} (vol{})", id, idx);
1307:                                 }
1308:                             } else {
1309:                                 error!(
1310:                                     "Monitor: Cannot restart VirtioFS (vol{}), config not found.",
1311:                                     idx
1312:                                 );
1313:                             }
1314:                         }
1315:                     }
1316:                 }
1317:             }
1318:         }
1319:     });
1320: }
