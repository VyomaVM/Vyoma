53: chmod 0440 /etc/sudoers.d/ignite
54: systemctl daemon-reload
55: systemctl enable ignited
56: systemctl start ignited
57: echo "Ignite installed! Run 'sudo usermod -aG ignite \$USER' to use the CLI without root."
58: EOF
59: chmod 755 "${WORK_DIR}/DEBIAN/postinst"
60: mkdir -p dist
61: dpkg-deb --build "${WORK_DIR}" "dist/${PKG_NAME}_${VERSION}_${ARCH}.deb"
62: rm -f firecracker firecracker.tgz virtiofsd.zip virtiofsd_bin
63: rm -rf release-v1.7.0-x86_64
