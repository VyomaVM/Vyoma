 497:         let vm = vm_mutex.lock().await;
 498:         vm.vmm
 499:             .pause_instance()
 500:             .await
 501:             .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 502:         Ok(format!("VM {} paused", id))
 503:     } else {
 504:         Err((StatusCode::NOT_FOUND, "VM not found".to_string()))
 505:     }
 506: }
