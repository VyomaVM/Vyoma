 903: async fn build_image(context_path: &str, daemon_url: &str) -> Result<String> {
 904:     let context_path = Path::new(context_path);
 905:     if !context_path.exists() {
 906:         return Err(anyhow::anyhow!(
 907:             "Context path does not exist: {:?}",
 908:             context_path
 909:         ));
 910:     }
 911:     let temp_dir = tempfile::tempdir()?;
 912:     let tar_path = temp_dir.path().join("context.tar.gz");
 913:     let tar_file = File::create(&tar_path)?;
 914:     let enc = GzEncoder::new(tar_file, Compression::default());
 915:     let mut tar = tar::Builder::new(enc);
 916:     tar.append_dir_all(".", context_path)?;
 917:     tar.finish()?;
 918:     let file = tokio::fs::File::open(&tar_path).await?;
 919:     let stream = tokio_util::codec::FramedRead::new(file, tokio_util::codec::BytesCodec::new());
 920:     let body = reqwest::Body::wrap_stream(stream);
 921:     let client = Client::new();
 922:     let resp = client
 923:         .post(format!("{}/build", daemon_url))
 924:         .body(body)
 925:         .send()
 926:         .await?;
 927:     if !resp.status().is_success() {
 928:         let status = resp.status();
 929:         let text = resp.text().await.unwrap_or_default();
 930:         return Err(anyhow::anyhow!("Build failed ({}): {}", status, text));
 931:     }
 932:     let image_id = resp.text().await?;
 933:     info!("Build complete. Image ID: {}", image_id);
 934:     Ok(image_id)
 935: }
 936: fn export_vm(vm_id: &str, output_path: &str) -> Result<()> {
 937:     let home = dirs::home_dir().ok_or(anyhow::anyhow!("No home dir"))?;
 938:     let vm_dir = home.join(".ignite").join("vms").join(vm_id);
 939:     if !vm_dir.exists() {
 940:         return Err(anyhow::anyhow!("VM directory not found: {:?}", vm_dir));
 941:     }
 942:     let snap_path = vm_dir.join("snapshot.snap");
 943:     let mem_path = vm_dir.join("memory.mem");
 944:     let cow_path = vm_dir.join("diff.cow");
 945:     if !snap_path.exists() || !mem_path.exists() {
 946:         return Err(anyhow::anyhow!(
 947:             "Snapshot files missing. Did you run 'ign snapshot <id>' first?"
 948:         ));
 949:     }
 950:     let tar_file = File::create(output_path)?;
 951:     let enc = GzEncoder::new(tar_file, Compression::default());
 952:     let mut tar = tar::Builder::new(enc);
 953:     tar.append_path_with_name(&snap_path, "snapshot.snap")?;
 954:     tar.append_path_with_name(&mem_path, "memory.mem")?;
 955:     tar.append_path_with_name(&cow_path, "diff.cow")?;
 956:     tar.finish()?;
 957:     info!("Export complete: {}", output_path);
 958:     Ok(())
 959: }
 960: async fn import_vm(input_path: &str, daemon_url: &str) -> Result<()> {
 961:     let file = File::open(input_path)?;
 962:     let tar = GzDecoder::new(file);
 963:     let mut archive = Archive::new(tar);
 964:     let temp_dir = tempfile::tempdir()?;
 965:     info!("Unpacking to temporary location: {:?}", temp_dir.path());
 966:     archive.unpack(temp_dir.path())?;
 967:     let snap_path = temp_dir.path().join("snapshot.snap");
 968:     let mem_path = temp_dir.path().join("memory.mem");
 969:     let cow_path = temp_dir.path().join("diff.cow");
 970:     if !snap_path.exists() || !mem_path.exists() || !cow_path.exists() {
 971:         return Err(anyhow::anyhow!(
 972:             "Invalid export archive. Missing core files."
 973:         ));
 974:     }
 975:     let client = Client::new();
 976:     let payload = RestoreRequest {
 977:         snapshot_path: snap_path.to_string_lossy().to_string(),
 978:         mem_path: mem_path.to_string_lossy().to_string(),
 979:         cow_path: cow_path.to_string_lossy().to_string(),
 980:         original_vm_id: "imported".to_string(),
 981:     };
 982:     let resp = client
 983:         .post(format!("{}/restore", daemon_url))
 984:         .json(&payload)
 985:         .send()
 986:         .await;
 987:     handle_response(resp, daemon_url).await?;
 988:     Ok(())
 989: }
