 801: pub async fn stream_logs(
 802:     State(state): State<AppState>,
 803:     Path(id): Path<String>,
 804: ) -> Result<Sse<impl Stream<Item = Result<Event, Infallible>>>, (StatusCode, String)> {
 805:     info!("Request to stream logs for VM: {}", id);
 806:     let vm_arc = {
 807:         let vms = state.vms.lock().unwrap();
 808:         vms.get(&id).cloned()
 809:     };
 810:     if let Some(vm_mutex) = vm_arc {
 811:         let vm = vm_mutex.lock().await;
 812:         let rx = vm.vmm.subscribe_logs();
 813:         use tokio_stream::StreamExt;
 814:         let stream = BroadcastStream::new(rx).filter_map(|try_msg| {
 815:             match try_msg {
 816:                 Ok(msg) => Some(Ok(Event::default().data(msg))),
 817:                 Err(_) => None,
 818:             }
 819:         });
 820:         Ok(Sse::new(stream).keep_alive(axum::response::sse::KeepAlive::default()))
 821:     } else {
 822:         Err((StatusCode::NOT_FOUND, "VM not found".to_string()))
 823:     }
 824: }
