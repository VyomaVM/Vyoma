1018: async fn handle_response(resp: Result<reqwest::Response, reqwest::Error>, url: &str) -> Result<()> {
1019:     match resp {
1020:         Ok(response) => {
1021:             if response.status().is_success() {
1022:                 let body: RunResponse = response.json().await?;
1023:                 info!("Success! VM ID: {}, Status: {}", body.vm_id, body.status);
1024:             } else {
1025:                 let status = response.status();
1026:                 let text = response.text().await.unwrap_or_default();
1027:                 error!("Daemon returned error: {} - {}", status, text);
1028:             }
1029:         }
1030:         Err(e) => {
1031:             error!("Failed to connect to daemon at {}: {}", url, e);
1032:             info!("Is 'ignited' running?");
1033:         }
1034:     }
1035:     Ok(())
1036: }
