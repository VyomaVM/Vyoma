 868: pub async fn build_image(
 869:     State(_state): State<AppState>,
 870:     body: Body,
 871: ) -> Result<String, (StatusCode, String)> {
 872:     info!("Received build request");
 873:     let temp_dir =
 874:         tempfile::tempdir().map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 875:     let tar_path = temp_dir.path().join("context.tar.gz");
 876:     {
 877:         use futures::StreamExt;
 878:         let stream = body
 879:             .into_data_stream()
 880:             .map(|b| b.map_err(|e| std::io::Error::new(std::io::ErrorKind::Other, e)));
 881:         let mut reader = StreamReader::new(stream);
 882:         let mut file = tokio::fs::File::create(&tar_path)
 883:             .await
 884:             .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 885:         tokio::io::copy(&mut reader, &mut file)
 886:             .await
 887:             .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 888:     }
 889:     let tar_file = std::fs::File::open(&tar_path)
 890:         .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 891:     let decoder = GzDecoder::new(tar_file);
 892:     let mut archive = Archive::new(decoder);
 893:     let context_dir = temp_dir.path().join("context");
 894:     std::fs::create_dir(&context_dir)
 895:         .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 896:     archive.unpack(&context_dir).map_err(|e| {
 897:         (
 898:             StatusCode::INTERNAL_SERVER_ERROR,
 899:             format!("Unpack failed: {}", e),
 900:         )
 901:     })?;
 902:     let ignitefile_path = context_dir.join("Ignitefile");
 903:     if !ignitefile_path.exists() {
 904:         return Err((
 905:             StatusCode::BAD_REQUEST,
 906:             "Ignitefile not found in build context".to_string(),
 907:         ));
 908:     }
 909:     let ignite_file = IgniteFile::parse(&ignitefile_path)
 910:         .map_err(|e| (StatusCode::BAD_REQUEST, format!("Parse error: {}", e)))?;
 911:     let home = dirs::home_dir().ok_or((StatusCode::INTERNAL_SERVER_ERROR, "No home dir".into()))?;
 912:     let images_root = home.join(".ignite").join("images");
 913:     std::fs::create_dir_all(&images_root)
 914:         .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 915:     let build_id = uuid::Uuid::new_v4().to_string();
 916:     let image_store_path = images_root.join(&build_id);
 917:     std::fs::create_dir_all(&image_store_path)
 918:         .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 919:     let current_image_path = image_store_path.join("base.ext4");
 920:     let current_image_path = image_store_path.join("base.ext4");
 921:     let mut has_base = false;
 922:     let mut oci_config = ignite_core::oci::OciImageConfig::default();
 923:     for instr in ignite_file.instructions {
 924:         match instr {
 925:             Instruction::From(image) => {
 926:                 info!("Building FROM {}", image);
 927:                 let base_cache = ensure_image_locally(&image).await?;
 928:                 std::fs::copy(&base_cache, &current_image_path).map_err(|e| {
 929:                     (
 930:                         StatusCode::INTERNAL_SERVER_ERROR,
 931:                         format!("Failed to copy base: {}", e),
 932:                     )
 933:                 })?;
 934:                 has_base = true;
 935:             }
 936:             Instruction::Run(cmd) => {
 937:                 if !has_base {
 938:                     return Err((StatusCode::BAD_REQUEST, "RUN before FROM".to_string()));
 939:                 }
 940:                 info!("RUN: {}", cmd);
 941:                 let loop_device = StorageManager::setup_loop_device(&current_image_path)
 942:                     .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 943:                 let mount_point = tempfile::tempdir()
 944:                     .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 945:                 let mount_status = Command::new("sudo")
 946:                     .args(&["mount", &loop_device, mount_point.path().to_str().unwrap()])
 947:                     .status()
 948:                     .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 949:                 if !mount_status.success() {
 950:                     let _ = StorageManager::detach_loop_device(&loop_device);
 951:                     return Err((
 952:                         StatusCode::INTERNAL_SERVER_ERROR,
 953:                         "Failed to mount for RUN".to_string(),
 954:                     ));
 955:                 }
 956:                 let _ = std::fs::copy(
 957:                     "/etc/resolv.conf",
 958:                     mount_point.path().join("etc/resolv.conf"),
 959:                 );
 960:                 let chroot_status = Command::new("sudo")
 961:                     .args(&[
 962:                         "chroot",
 963:                         mount_point.path().to_str().unwrap(),
 964:                         "/bin/sh",
 965:                         "-c",
 966:                         &cmd,
 967:                     ])
 968:                     .status()
 969:                     .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 970:                 let umount_status = Command::new("sudo")
 971:                     .args(&["umount", mount_point.path().to_str().unwrap()])
 972:                     .status()
 973:                     .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 974:                 let _ = StorageManager::detach_loop_device(&loop_device);
 975:                 if !chroot_status.success() {
 976:                     return Err((
 977:                         StatusCode::BAD_REQUEST,
 978:                         format!("RUN command failed: {}", cmd),
 979:                     ));
 980:                 }
 981:             }
 982:             Instruction::Copy { src, dest } => {
 983:                 if !has_base {
 984:                     return Err((StatusCode::BAD_REQUEST, "COPY before FROM".to_string()));
 985:                 }
 986:                 info!("COPY {} -> {}", src, dest);
 987:                 let loop_device = StorageManager::setup_loop_device(&current_image_path)
 988:                     .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 989:                 let mount_point = tempfile::tempdir()
 990:                     .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 991:                 let mount_status = Command::new("sudo")
 992:                     .args(&["mount", &loop_device, mount_point.path().to_str().unwrap()])
 993:                     .status()
 994:                     .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 995:                 if !mount_status.success() {
 996:                     let _ = StorageManager::detach_loop_device(&loop_device);
 997:                     return Err((
 998:                         StatusCode::INTERNAL_SERVER_ERROR,
 999:                         "Failed to mount for COPY".to_string(),
1000:                     ));
1001:                 }
1002:                 let src_path = context_dir.join(&src);
1003:                 let safe_dest = dest.trim_start_matches('/');
1004:                 let dest_path = mount_point.path().join(safe_dest);
1005:                 if let Some(parent) = dest_path.parent() {
1006:                     let _ = std::fs::create_dir_all(parent);
1007:                 }
1008:                 if src_path.is_dir() {
1009:                     let cp_status = Command::new("cp")
1010:                         .arg("-r")
1011:                         .arg(&src_path)
1012:                         .arg(&dest_path)
1013:                         .status()
1014:                         .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
1015:                     if !cp_status.success() {
1016:                         let _ = Command::new("sudo")
1017:                             .args(&["umount", mount_point.path().to_str().unwrap()])
1018:                             .status();
1019:                         let _ = StorageManager::detach_loop_device(&loop_device);
1020:                         return Err((
1021:                             StatusCode::INTERNAL_SERVER_ERROR,
1022:                             "Failed to copy dir".to_string(),
1023:                         ));
1024:                     }
1025:                 } else {
1026:                     match std::fs::copy(&src_path, &dest_path) {
1027:                         Ok(_) => {}
1028:                         Err(e) => {
1029:                             let _ = Command::new("sudo")
1030:                                 .args(&["umount", mount_point.path().to_str().unwrap()])
1031:                                 .status();
1032:                             let _ = StorageManager::detach_loop_device(&loop_device);
1033:                             return Err((
1034:                                 StatusCode::INTERNAL_SERVER_ERROR,
1035:                                 format!("Failed copy file: {}", e),
1036:                             ));
1037:                         }
1038:                     }
1039:                 }
1040:                 let _ = Command::new("sudo")
1041:                     .args(&["umount", mount_point.path().to_str().unwrap()])
1042:                     .status();
1043:                 let _ = StorageManager::detach_loop_device(&loop_device);
1044:             }
1045:             Instruction::Cmd(args) => {
1046:                 info!("CMD {:?}", args);
1047:                 oci_config.cmd = Some(args);
1048:             }
1049:             Instruction::Entrypoint(args) => {
1050:                 info!("ENTRYPOINT {:?}", args);
1051:                 oci_config.entrypoint = Some(args);
1052:             }
1053:             Instruction::Env { key, value } => {
1054:                 info!("ENV {}={}", key, value);
1055:                 let current_envs = oci_config.env.get_or_insert_with(Vec::new);
1056:                 current_envs.push(format!("{}={}", key, value));
1057:             }
1058:         }
1059:     }
1060:     let config_path = image_store_path.join("ignite-config.json");
1061:     if let Ok(json_str) = serde_json::to_string_pretty(&oci_config) {
1062:         if let Err(e) = std::fs::write(&config_path, json_str) {
1063:             warn!("Failed to write ignite-config.json: {}", e);
1064:         }
1065:     }
1066:     Ok(build_id)
1067: }
1068: pub async fn ensure_image_locally(
1069:     image_name: &str,
1070: ) -> Result<std::path::PathBuf, (StatusCode, String)> {
1071:     let home = dirs::home_dir().ok_or((StatusCode::INTERNAL_SERVER_ERROR, "No home dir".into()))?;
1072:     let images_root = home.join(".ignite").join("images");
1073:     std::fs::create_dir_all(&images_root)
1074:         .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
1075:     let safe_image_name = image_name.replace('/', "_").replace(':', "_");
1076:     let image_store_path = images_root.join(&safe_image_name);
1077:     let base_image_file = image_store_path.join("base.ext4");
1078:     if !base_image_file.exists() {
1079:         info!("Image {} not found locally. Pulling...", image_name);
1080:         std::fs::create_dir_all(&image_store_path)
1081:             .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
1082:         let mut oci = OciManager::new();
1083:         let manifest_json = oci
1084:             .pull_manifest(image_name)
1085:             .await
1086:             .map_err(|e| (StatusCode::BAD_REQUEST, format!("Pull failed: {}", e)))?;
1087:         let layers = oci
1088:             .parse_layers(&manifest_json)
1089:             .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
1090:         if let Ok(config_digest) = oci.parse_config_digest(&manifest_json) {
1091:             info!("Fetching OCI config blob: {}", config_digest);
1092:             if let Ok(config) = oci.pull_config_blob(image_name, &config_digest).await {
1093:                 let config_path = image_store_path.join("ignite-config.json");
1094:                 if let Ok(json_str) = serde_json::to_string_pretty(&config) {
1095:                     if let Err(e) = std::fs::write(&config_path, json_str) {
1096:                         warn!("Failed to write ignite-config.json: {}", e);
1097:                     } else {
1098:                         info!("Saved OCI configuration to {:?}", config_path);
1099:                     }
1100:                 }
1101:             }
1102:         }
1103:         let temp_unpack_dir =
1104:             tempfile::tempdir().map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
1105:         for digest in layers {
1106:             let layer_data = oci.pull_layer(image_name, &digest).await.map_err(|e| {
1107:                 (
1108:                     StatusCode::BAD_GATEWAY,
1109:                     format!("Failed layer {}: {}", digest, e),
1110:                 )
1111:             })?;
1112:             LayerManager::unpack_layer(&layer_data, temp_unpack_dir.path()).map_err(|e| {
1113:                 (
1114:                     StatusCode::INTERNAL_SERVER_ERROR,
1115:                     format!("Unpack failed: {}", e),
1116:                 )
1117:             })?;
1118:         }
1119:         let size_mb = 2048;
1120:         StorageManager::create_empty_file(&base_image_file, size_mb)
1121:             .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
1122:         StorageManager::format_ext4(&base_image_file)
1123:             .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
1124:         StorageManager::populate_image(&base_image_file, temp_unpack_dir.path()).map_err(|e| {
1125:             (
1126:                 StatusCode::INTERNAL_SERVER_ERROR,
1127:                 format!("Populate failed: {}", e),
1128:             )
1129:         })?;
1130:     } else {
1131:         info!("Image found locally at {:?}", base_image_file);
1132:     }
1133:     Ok(base_image_file)
1134: }
1135: pub async fn initialize_state(state: &AppState) {
1136:     info!("Recovery: Scanning for existing VMs...");
1137:     let home = match dirs::home_dir() {
1138:         Some(h) => h,
1139:         None => return,
1140:     };
1141:     let vms_dir = home.join(".ignite").join("vms");
1142:     if !vms_dir.exists() {
1143:         return;
1144:     }
1145:     let entries = match std::fs::read_dir(vms_dir) {
1146:         Ok(e) => e,
1147:         Err(_) => return,
1148:     };
1149:     for entry in entries.flatten() {
1150:         if !entry.path().is_dir() {
1151:             continue;
1152:         }
1153:         let state_path = entry.path().join("state.json");
1154:         if !state_path.exists() {
1155:             continue;
1156:         }
1157:         let content = match std::fs::read_to_string(&state_path) {
1158:             Ok(c) => c,
1159:             Err(e) => {
1160:                 error!("Failed to read state for {:?}: {}", entry.path(), e);
1161:                 continue;
1162:             }
1163:         };
1164:         let vm_state: VmState = match serde_json::from_str(&content) {
1165:             Ok(s) => s,
1166:             Err(e) => {
1167:                 error!("Failed to parse state for {:?}: {}", entry.path(), e);
1168:                 continue;
1169:             }
1170:         };
1171:         let socket_path = format!("/tmp/firecracker_{}.socket", vm_state.id);
1172:         let vmm = VmmManager::new(&socket_path);
1173:         if vmm.check_alive().await {
1174:             info!("Recovery: VM {} is ALIVE. Adopting...", vm_state.id);
1175:             let mut proxy_tasks = Vec::new();
1176:             for p in &vm_state.ports {
1177:                 let t =
1178:                     ProxyManager::start_proxy(p.host_port, vm_state.ip_address.clone(), p.vm_port);
1179:                 proxy_tasks.push(t);
1180:             }
1181:             let mut fs_managers = Vec::new();
1182:             for (idx, _vol) in vm_state.volumes.iter().enumerate() {
1183:                 let tag = format!("vol{}", idx);
1184:                 let path = entry.path().join(format!("fs_{}.sock", idx));
1185:                 fs_managers.push(VirtioFsManager::new(&tag, path.to_string_lossy().as_ref()));
1186:             }
1187:             let instance = VmInstance {
1188:                 vmm,
1189:                 id: vm_state.id.clone(),
1190:                 tap_name: vm_state.tap_name,
1191:                 dm_name: vm_state.dm_name,
1192:                 loop_devices: vm_state.loop_devices,
1193:                 cow_file_path: vm_state.cow_file_path,
1194:                 ip_address: vm_state.ip_address,
1195:                 proxy_tasks,
1196:                 fs_managers,
1197:                 slirp: None,
1198:                 cgroup_path: vm_state.cgroup_path,
1199:                 netns_path: vm_state.netns_path,
1200:                 config_ports: vm_state.ports,
1201:                 config_volumes: vm_state.volumes,
1202:                 hostname: vm_state.hostname,
1203:                 labels: vm_state.labels.clone(),
1204:                 base_image_path: vm_state.base_image_path.clone(),
1205:                 vcpu: vm_state.vcpu,
1206:                 mem_size_mib: vm_state.mem_size_mib,
1207:             };
1208:             state
1209:                 .vms
1210:                 .lock()
1211:                 .unwrap()
1212:                 .insert(vm_state.id, Arc::new(TokioMutex::new(instance)));
1213:         } else {
1214:             info!(
1215:                 "Recovery: VM {} found but DEAD. cleaning up artifacts...",
1216:                 vm_state.id
1217:             );
1218:             let mut instance = VmInstance {
1219:                 vmm,
1220:                 id: vm_state.id.clone(),
1221:                 tap_name: vm_state.tap_name,
1222:                 dm_name: vm_state.dm_name,
1223:                 loop_devices: vm_state.loop_devices,
1224:                 cow_file_path: vm_state.cow_file_path,
1225:                 ip_address: vm_state.ip_address,
1226:                 proxy_tasks: vec![],
1227:                 fs_managers: vec![],
1228:                 slirp: None,
1229:                 cgroup_path: vm_state.cgroup_path,
1230:                 netns_path: vm_state.netns_path,
1231:                 config_ports: vec![],
1232:                 config_volumes: vec![],
1233:                 hostname: vm_state.hostname,
1234:                 labels: vm_state.labels,
1235:                 base_image_path: vm_state.base_image_path,
1236:                 vcpu: vm_state.vcpu,
1237:                 mem_size_mib: vm_state.mem_size_mib,
1238:             };
1239:             instance.cleanup(&state.cni_manager).await;
1240:             let _ = std::fs::remove_dir_all(entry.path());
1241:         }
1242:     }
