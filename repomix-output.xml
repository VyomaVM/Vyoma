14:     pub fn init(&self) -> Result<()> {
15:         let path = Path::new(&self.root_path);
16:         if !path.exists() {
17:             info!("Creating root cgroup slice: {}", self.root_path);
18:             fs::create_dir_all(path)?;
19:             let controllers_path = Path::new("/sys/fs/cgroup/cgroup.controllers");
20:             let available = fs::read_to_string(controllers_path).unwrap_or_default();
21:             let mut subtree_control = String::new();
22:             if available.contains("cpu") { subtree_control.push_str("+cpu "); }
23:             if available.contains("memory") { subtree_control.push_str("+memory "); }
24:             if available.contains("io") { subtree_control.push_str("+io "); }
25:             let control_path = path.join("cgroup.subtree_control");
26:             if control_path.exists() {
27:                  fs::write(control_path, subtree_control.trim())?;
28:             }
29:         }
30:         Ok(())
31:     }
32:     pub fn create_vm_cgroup(&self, vm_id: &str) -> Result<String> {
33:         let vm_cgroup_path = Path::new(&self.root_path).join(format!("ignite-{}", vm_id));
34:         if !vm_cgroup_path.exists() {
