 869: pub async fn build_image(
 870:     State(_state): State<AppState>,
 871:     body: Body,
 872: ) -> Result<String, (StatusCode, String)> {
 873:     info!("Received build request");
 874:     let temp_dir =
 875:         tempfile::tempdir().map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 876:     let tar_path = temp_dir.path().join("context.tar.gz");
 877:     {
 878:         use futures::StreamExt;
 879:         let stream = body
 880:             .into_data_stream()
 881:             .map(|b| b.map_err(|e| std::io::Error::new(std::io::ErrorKind::Other, e)));
 882:         let mut reader = StreamReader::new(stream);
 883:         let mut file = tokio::fs::File::create(&tar_path)
 884:             .await
 885:             .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 886:         tokio::io::copy(&mut reader, &mut file)
 887:             .await
 888:             .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 889:     }
 890:     let tar_file = std::fs::File::open(&tar_path)
 891:         .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 892:     let decoder = GzDecoder::new(tar_file);
 893:     let mut archive = Archive::new(decoder);
 894:     let context_dir = temp_dir.path().join("context");
 895:     std::fs::create_dir(&context_dir)
 896:         .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 897:     archive.unpack(&context_dir).map_err(|e| {
 898:         (
 899:             StatusCode::INTERNAL_SERVER_ERROR,
 900:             format!("Unpack failed: {}", e),
 901:         )
 902:     })?;
 903:     let ignitefile_path = context_dir.join("Ignitefile");
 904:     if !ignitefile_path.exists() {
 905:         return Err((
 906:             StatusCode::BAD_REQUEST,
 907:             "Ignitefile not found in build context".to_string(),
 908:         ));
 909:     }
 910:     let ignite_file = IgniteFile::parse(&ignitefile_path)
 911:         .map_err(|e| (StatusCode::BAD_REQUEST, format!("Parse error: {}", e)))?;
 912:     let home = dirs::home_dir().ok_or((StatusCode::INTERNAL_SERVER_ERROR, "No home dir".into()))?;
 913:     let images_root = home.join(".ignite").join("images");
 914:     std::fs::create_dir_all(&images_root)
 915:         .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 916:     let build_id = uuid::Uuid::new_v4().to_string();
 917:     let image_store_path = images_root.join(&build_id);
 918:     std::fs::create_dir_all(&image_store_path)
 919:         .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 920:     let current_image_path = image_store_path.join("base.ext4");
 921:     let mut has_base = false;
 922:     for instr in ignite_file.instructions {
 923:         match instr {
 924:             Instruction::From(image) => {
 925:                 info!("Building FROM {}", image);
 926:                 let base_cache = ensure_image_locally(&image).await?;
 927:                 std::fs::copy(&base_cache, &current_image_path).map_err(|e| {
 928:                     (
 929:                         StatusCode::INTERNAL_SERVER_ERROR,
 930:                         format!("Failed to copy base: {}", e),
 931:                     )
 932:                 })?;
 933:                 has_base = true;
 934:             }
 935:             Instruction::Run(cmd) => {
 936:                 if !has_base {
 937:                     return Err((StatusCode::BAD_REQUEST, "RUN before FROM".to_string()));
 938:                 }
 939:                 info!("RUN: {}", cmd);
 940:                 let loop_device = StorageManager::setup_loop_device(&current_image_path)
 941:                     .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 942:                 let mount_point = tempfile::tempdir()
 943:                     .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 944:                 let mount_status = Command::new("sudo")
 945:                     .args(&["mount", &loop_device, mount_point.path().to_str().unwrap()])
 946:                     .status()
 947:                     .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 948:                 if !mount_status.success() {
 949:                     let _ = StorageManager::detach_loop_device(&loop_device);
 950:                     return Err((
 951:                         StatusCode::INTERNAL_SERVER_ERROR,
 952:                         "Failed to mount for RUN".to_string(),
 953:                     ));
 954:                 }
 955:                 let _ = std::fs::copy(
 956:                     "/etc/resolv.conf",
 957:                     mount_point.path().join("etc/resolv.conf"),
 958:                 );
 959:                 let chroot_status = Command::new("sudo")
 960:                     .args(&[
 961:                         "chroot",
 962:                         mount_point.path().to_str().unwrap(),
 963:                         "/bin/sh",
 964:                         "-c",
 965:                         &cmd,
 966:                     ])
 967:                     .status()
 968:                     .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 969:                 let umount_status = Command::new("sudo")
 970:                     .args(&["umount", mount_point.path().to_str().unwrap()])
 971:                     .status()
 972:                     .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 973:                 let _ = StorageManager::detach_loop_device(&loop_device);
 974:                 if !chroot_status.success() {
 975:                     return Err((
 976:                         StatusCode::BAD_REQUEST,
 977:                         format!("RUN command failed: {}", cmd),
 978:                     ));
 979:                 }
 980:             }
 981:             Instruction::Copy { src, dest } => {
 982:                 if !has_base {
 983:                     return Err((StatusCode::BAD_REQUEST, "COPY before FROM".to_string()));
 984:                 }
 985:                 info!("COPY {} -> {}", src, dest);
 986:                 let loop_device = StorageManager::setup_loop_device(&current_image_path)
 987:                     .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 988:                 let mount_point = tempfile::tempdir()
 989:                     .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 990:                 let mount_status = Command::new("sudo")
 991:                     .args(&["mount", &loop_device, mount_point.path().to_str().unwrap()])
 992:                     .status()
 993:                     .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 994:                 if !mount_status.success() {
 995:                     let _ = StorageManager::detach_loop_device(&loop_device);
 996:                     return Err((
 997:                         StatusCode::INTERNAL_SERVER_ERROR,
 998:                         "Failed to mount for COPY".to_string(),
 999:                     ));
1000:                 }
1001:                 let src_path = context_dir.join(&src);
1002:                 let safe_dest = dest.trim_start_matches('/');
1003:                 let dest_path = mount_point.path().join(safe_dest);
1004:                 if let Some(parent) = dest_path.parent() {
1005:                     let _ = std::fs::create_dir_all(parent);
1006:                 }
1007:                 if src_path.is_dir() {
1008:                     let cp_status = Command::new("cp")
1009:                         .arg("-r")
1010:                         .arg(&src_path)
1011:                         .arg(&dest_path)
1012:                         .status()
1013:                         .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
1014:                     if !cp_status.success() {
1015:                         let _ = Command::new("sudo")
1016:                             .args(&["umount", mount_point.path().to_str().unwrap()])
1017:                             .status();
1018:                         let _ = StorageManager::detach_loop_device(&loop_device);
1019:                         return Err((
1020:                             StatusCode::INTERNAL_SERVER_ERROR,
1021:                             "Failed to copy dir".to_string(),
1022:                         ));
1023:                     }
1024:                 } else {
1025:                     match std::fs::copy(&src_path, &dest_path) {
1026:                         Ok(_) => {}
1027:                         Err(e) => {
1028:                             let _ = Command::new("sudo")
1029:                                 .args(&["umount", mount_point.path().to_str().unwrap()])
1030:                                 .status();
1031:                             let _ = StorageManager::detach_loop_device(&loop_device);
1032:                             return Err((
1033:                                 StatusCode::INTERNAL_SERVER_ERROR,
1034:                                 format!("Failed copy file: {}", e),
1035:                             ));
1036:                         }
1037:                     }
1038:                 }
1039:                 let _ = Command::new("sudo")
1040:                     .args(&["umount", mount_point.path().to_str().unwrap()])
1041:                     .status();
1042:                 let _ = StorageManager::detach_loop_device(&loop_device);
1043:             }
1044:         }
1045:     }
1046:     Ok(build_id)
1047: }
1048: pub async fn ensure_image_locally(
1049:     image_name: &str,
1050: ) -> Result<std::path::PathBuf, (StatusCode, String)> {
1051:     let home = dirs::home_dir().ok_or((StatusCode::INTERNAL_SERVER_ERROR, "No home dir".into()))?;
1052:     let images_root = home.join(".ignite").join("images");
1053:     std::fs::create_dir_all(&images_root)
1054:         .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
1055:     let safe_image_name = image_name.replace('/', "_").replace(':', "_");
1056:     let image_store_path = images_root.join(&safe_image_name);
1057:     let base_image_file = image_store_path.join("base.ext4");
1058:     if !base_image_file.exists() {
1059:         info!("Image {} not found locally. Pulling...", image_name);
1060:         std::fs::create_dir_all(&image_store_path)
1061:             .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
1062:         let mut oci = OciManager::new();
1063:         let manifest_json = oci
1064:             .pull_manifest(image_name)
1065:             .await
1066:             .map_err(|e| (StatusCode::BAD_REQUEST, format!("Pull failed: {}", e)))?;
1067:         let layers = oci
1068:             .parse_layers(&manifest_json)
1069:             .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
1070:         let temp_unpack_dir =
1071:             tempfile::tempdir().map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
1072:         for digest in layers {
1073:             let layer_data = oci.pull_layer(image_name, &digest).await.map_err(|e| {
1074:                 (
1075:                     StatusCode::BAD_GATEWAY,
1076:                     format!("Failed layer {}: {}", digest, e),
1077:                 )
1078:             })?;
1079:             LayerManager::unpack_layer(&layer_data, temp_unpack_dir.path()).map_err(|e| {
1080:                 (
1081:                     StatusCode::INTERNAL_SERVER_ERROR,
1082:                     format!("Unpack failed: {}", e),
1083:                 )
1084:             })?;
1085:         }
1086:         let size_mb = 2048;
1087:         StorageManager::create_empty_file(&base_image_file, size_mb)
1088:             .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
1089:         StorageManager::format_ext4(&base_image_file)
1090:             .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
1091:         StorageManager::populate_image(&base_image_file, temp_unpack_dir.path()).map_err(|e| {
1092:             (
1093:                 StatusCode::INTERNAL_SERVER_ERROR,
1094:                 format!("Populate failed: {}", e),
1095:             )
1096:         })?;
1097:     } else {
1098:         info!("Image found locally at {:?}", base_image_file);
1099:     }
1100:     Ok(base_image_file)
1101: }
1102: pub async fn initialize_state(state: &AppState) {
1103:     info!("Recovery: Scanning for existing VMs...");
1104:     let home = match dirs::home_dir() {
1105:         Some(h) => h,
1106:         None => return,
1107:     };
1108:     let vms_dir = home.join(".ignite").join("vms");
1109:     if !vms_dir.exists() {
1110:         return;
1111:     }
1112:     let entries = match std::fs::read_dir(vms_dir) {
1113:         Ok(e) => e,
1114:         Err(_) => return,
1115:     };
1116:     for entry in entries.flatten() {
1117:         if !entry.path().is_dir() {
1118:             continue;
1119:         }
1120:         let state_path = entry.path().join("state.json");
1121:         if !state_path.exists() {
1122:             continue;
1123:         }
1124:         let content = match std::fs::read_to_string(&state_path) {
1125:             Ok(c) => c,
1126:             Err(e) => {
1127:                 error!("Failed to read state for {:?}: {}", entry.path(), e);
1128:                 continue;
1129:             }
1130:         };
1131:         let vm_state: VmState = match serde_json::from_str(&content) {
1132:             Ok(s) => s,
1133:             Err(e) => {
1134:                 error!("Failed to parse state for {:?}: {}", entry.path(), e);
1135:                 continue;
1136:             }
1137:         };
1138:         let socket_path = format!("/tmp/firecracker_{}.socket", vm_state.id);
1139:         let vmm = VmmManager::new(&socket_path);
1140:         if vmm.check_alive().await {
1141:             info!("Recovery: VM {} is ALIVE. Adopting...", vm_state.id);
1142:             let mut proxy_tasks = Vec::new();
1143:             for p in &vm_state.ports {
1144:                 let t =
1145:                     ProxyManager::start_proxy(p.host_port, vm_state.ip_address.clone(), p.vm_port);
1146:                 proxy_tasks.push(t);
1147:             }
1148:             let mut fs_managers = Vec::new();
1149:             for (idx, _vol) in vm_state.volumes.iter().enumerate() {
1150:                 let tag = format!("vol{}", idx);
1151:                 let path = entry.path().join(format!("fs_{}.sock", idx));
1152:                 fs_managers.push(VirtioFsManager::new(&tag, path.to_string_lossy().as_ref()));
1153:             }
1154:             let instance = VmInstance {
1155:                 vmm,
1156:                 id: vm_state.id.clone(),
1157:                 tap_name: vm_state.tap_name,
1158:                 dm_name: vm_state.dm_name,
1159:                 loop_devices: vm_state.loop_devices,
1160:                 cow_file_path: vm_state.cow_file_path,
1161:                 ip_address: vm_state.ip_address,
1162:                 proxy_tasks,
1163:                 fs_managers,
1164:                 slirp: None,
1165:                 cgroup_path: vm_state.cgroup_path,
1166:                 netns_path: vm_state.netns_path,
1167:                 config_ports: vm_state.ports,
1168:                 config_volumes: vm_state.volumes,
1169:                 hostname: vm_state.hostname,
1170:                 labels: vm_state.labels.clone(),
1171:                 base_image_path: vm_state.base_image_path.clone(),
1172:                 vcpu: vm_state.vcpu,
1173:                 mem_size_mib: vm_state.mem_size_mib,
1174:             };
1175:             state
1176:                 .vms
1177:                 .lock()
1178:                 .unwrap()
1179:                 .insert(vm_state.id, Arc::new(TokioMutex::new(instance)));
1180:         } else {
1181:             info!(
1182:                 "Recovery: VM {} found but DEAD. cleaning up artifacts...",
1183:                 vm_state.id
1184:             );
1185:             let mut instance = VmInstance {
1186:                 vmm,
1187:                 id: vm_state.id.clone(),
1188:                 tap_name: vm_state.tap_name,
1189:                 dm_name: vm_state.dm_name,
1190:                 loop_devices: vm_state.loop_devices,
1191:                 cow_file_path: vm_state.cow_file_path,
1192:                 ip_address: vm_state.ip_address,
1193:                 proxy_tasks: vec![],
1194:                 fs_managers: vec![],
1195:                 slirp: None,
1196:                 cgroup_path: vm_state.cgroup_path,
1197:                 netns_path: vm_state.netns_path,
1198:                 config_ports: vec![],
1199:                 config_volumes: vec![],
1200:                 hostname: vm_state.hostname,
1201:                 labels: vm_state.labels,
1202:                 base_image_path: vm_state.base_image_path,
1203:                 vcpu: vm_state.vcpu,
1204:                 mem_size_mib: vm_state.mem_size_mib,
1205:             };
1206:             instance.cleanup(&state.cni_manager).await;
1207:             let _ = std::fs::remove_dir_all(entry.path());
1208:         }
1209:     }
1210: }
1211: pub async fn start_process_monitor(state: AppState) {
1212:     tokio::spawn(async move {
1213:         let mut interval = tokio::time::interval(std::time::Duration::from_secs(5));
1214:         loop {
1215:             interval.tick().await;
1216:             let ids: Vec<String> = {
1217:                 let map = state.vms.lock().unwrap();
1218:                 map.keys().cloned().collect()
1219:             };
1220:             for id in ids {
1221:                 let vm_arc = {
1222:                     let map = state.vms.lock().unwrap();
1223:                     map.get(&id).cloned()
1224:                 };
1225:                 if let Some(vm_mutex) = vm_arc {
1226:                     let mut vm = vm_mutex.lock().await;
1227:                     match vm.vmm.try_wait() {
1228:                         Ok(Some(status)) => {
1229:                             let mut msg = format!(
1230:                                 "Monitor: VM {} Firecracker process EXITED (Reaped): {}",
1231:                                 id, status
1232:                             );
1233:                             if let Ok(count) = state.cgroups.get_oom_kill_count(&id) {
1234:                                 if count > 0 {
1235:                                     msg.push_str(&format!(
1236:                                         " [WARNING: OOM Kill Detected: {}]",
1237:                                         count
1238:                                     ));
1239:                                 }
1240:                             }
1241:                             error!("{}", msg);
1242:                         }
1243:                         Err(e) => error!("Monitor Check Error for VMM {}: {}", id, e),
1244:                         Ok(None) => {}
1245:                     }
1246:                     let fs_count = vm.fs_managers.len();
1247:                     for idx in 0..fs_count {
1248:                         let exit_status = {
1249:                             let fs = &mut vm.fs_managers[idx];
1250:                             match fs.try_wait() {
1251:                                 Ok(Some(s)) => Some(s),
1252:                                 Err(e) => {
1253:                                     error!("Monitor Check Error for FS {}: {}", id, e);
1254:                                     None
1255:                                 }
1256:                                 Ok(None) => None,
1257:                             }
1258:                         };
1259:                         if let Some(status) = exit_status {
1260:                             warn!(
1261:                                 "Monitor: VM {} VirtioFS (vol{}) EXITED with {}. Restarting...",
1262:                                 id, idx, status
1263:                             );
1264:                             let host_path = vm.config_volumes.get(idx).map(|v| v.host_path.clone());
1265:                             if let Some(path) = host_path {
1266:                                 let fs = &mut vm.fs_managers[idx];
1267:                                 if let Err(e) = fs.start(&path) {
1268:                                     error!(
1269:                                         "Monitor: FAILED to auto-restart VirtioFS for VM {}: {}",
1270:                                         id, e
1271:                                     );
1272:                                 } else {
1273:                                     info!("Monitor: RESTARTED VirtioFS for VM {} (vol{})", id, idx);
1274:                                 }
1275:                             } else {
1276:                                 error!(
