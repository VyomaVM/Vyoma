 813:     println!(
 814:         "{}",
 815:         "Ignite Doctor - System Health Check".bold().underline()
 816:     );
 817:     println!();
 818:     let mut all_passed = true;
 819:     let check = |name: &str, result: Result<bool>, required: bool| -> bool {
 820:         match result {
 821:             Ok(true) => {
 822:                 println!("{} {}", "[OK]".green().bold(), name);
 823:                 true
 824:             }
 825:             Ok(false) => {
 826:                 if required {
 827:                     println!("{} {}", "[FAIL]".red().bold(), name);
 828:                     false
 829:                 } else {
 830:                     println!("{} {}", "[WARN]".yellow().bold(), name);
 831:                     true
 832:                 }
 833:             }
 834:             Err(e) => {
 835:                 if required {
 836:                     println!("{} {} ({})", "[FAIL]".red().bold(), name, e);
 837:                     false
 838:                 } else {
 839:                     println!("{} {} ({})", "[WARN]".yellow().bold(), name, e);
 840:                     true
 841:                 }
 842:             }
 843:         }
 844:     };
 845:     if !check("KVM Device Access (/dev/kvm)", check_kvm(), true) {
 846:         all_passed = false;
 847:     }
 848:     if !check("Cgroups v2 (/sys/fs/cgroup)", check_cgroups(), true) {
 849:         all_passed = false;
 850:     }
 851:     if !check("Firecracker Binary", check_binary("firecracker"), true) {
 852:         all_passed = false;
 853:     }
 854:     if !check("Virtiofsd Binary", check_binary("virtiofsd"), true) {
 855:         all_passed = false;
 856:     }
 857:     if !check("Ignite Bridge (ign0)", check_bridge(), false) {}
 858:     if !check("debugfs (e2fsprogs)", check_binary("debugfs"), false) {}
 859:     println!();
 860:     if all_passed {
 861:         println!("{}", "Your system is ready for Ignite!".green().bold());
 862:     } else {
 863:         println!(
 864:             "{}",
 865:             "Some checks failed. Please review the errors above."
 866:                 .red()
 867:                 .bold()
 868:         );
 869:     }
 870:     Ok(())
 871: }
 872: fn check_kvm() -> Result<bool> {
 873:     use std::fs::OpenOptions;
 874:     let path = Path::new("/dev/kvm");
 875:     if !path.exists() {
 876:         return Ok(false);
 877:     }
 878:     OpenOptions::new().read(true).write(true).open(path)?;
 879:     Ok(true)
 880: }
 881: fn check_cgroups() -> Result<bool> {
 882:     let path = Path::new("/sys/fs/cgroup/cgroup.controllers");
 883:     Ok(path.exists())
 884: }
 885: fn check_binary(name: &str) -> Result<bool> {
 886:     use std::path::Path;
 887:     if Path::new(&format!("/opt/ignite/bin/{}", name)).exists() {
 888:         return Ok(true);
 889:     }
 890:     if Path::new(&format!("/usr/libexec/ignite/{}", name)).exists() {
 891:         return Ok(true);
 892:     }
 893:     if Path::new(&format!("bin/{}", name)).exists() {
 894:         return Ok(true);
 895:     }
 896:     let status = std::process::Command::new("which")
 897:         .arg(name)
 898:         .output()?
 899:         .status;
 900:     Ok(status.success())
 901: }
 902: fn check_bridge() -> Result<bool> {
 903:     let output = std::process::Command::new("ip")
 904:         .arg("link")
 905:         .arg("show")
 906:         .arg("ign0")
 907:         .output()?;
 908:     Ok(output.status.success())
 909: }
 910: async fn build_image(context_path: &str, daemon_url: &str) -> Result<String> {
 911:     let context_path = Path::new(context_path);
 912:     if !context_path.exists() {
 913:         return Err(anyhow::anyhow!(
 914:             "Context path does not exist: {:?}",
 915:             context_path
 916:         ));
 917:     }
 918:     let temp_dir = tempfile::tempdir()?;
 919:     let tar_path = temp_dir.path().join("context.tar.gz");
 920:     let tar_file = File::create(&tar_path)?;
 921:     let enc = GzEncoder::new(tar_file, Compression::default());
 922:     let mut tar = tar::Builder::new(enc);
 923:     tar.append_dir_all(".", context_path)?;
 924:     tar.finish()?;
 925:     let file = tokio::fs::File::open(&tar_path).await?;
 926:     let stream = tokio_util::codec::FramedRead::new(file, tokio_util::codec::BytesCodec::new());
 927:     let body = reqwest::Body::wrap_stream(stream);
 928:     let client = Client::new();
 929:     let resp = client
 930:         .post(format!("{}/build", daemon_url))
 931:         .body(body)
 932:         .send()
 933:         .await?;
 934:     if !resp.status().is_success() {
 935:         let status = resp.status();
 936:         let text = resp.text().await.unwrap_or_default();
 937:         return Err(anyhow::anyhow!("Build failed ({}): {}", status, text));
 938:     }
 939:     let image_id = resp.text().await?;
 940:     info!("Build complete. Image ID: {}", image_id);
 941:     Ok(image_id)
 942: }
 943: fn export_vm(vm_id: &str, output_path: &str) -> Result<()> {
 944:     let home = dirs::home_dir().ok_or(anyhow::anyhow!("No home dir"))?;
 945:     let vm_dir = home.join(".ignite").join("vms").join(vm_id);
 946:     if !vm_dir.exists() {
 947:         return Err(anyhow::anyhow!("VM directory not found: {:?}", vm_dir));
 948:     }
 949:     let snap_path = vm_dir.join("snapshot.snap");
 950:     let mem_path = vm_dir.join("memory.mem");
 951:     let cow_path = vm_dir.join("diff.cow");
 952:     if !snap_path.exists() || !mem_path.exists() {
 953:         return Err(anyhow::anyhow!(
 954:             "Snapshot files missing. Did you run 'ign snapshot <id>' first?"
 955:         ));
 956:     }
 957:     let tar_file = File::create(output_path)?;
 958:     let enc = GzEncoder::new(tar_file, Compression::default());
 959:     let mut tar = tar::Builder::new(enc);
 960:     tar.append_path_with_name(&snap_path, "snapshot.snap")?;
 961:     tar.append_path_with_name(&mem_path, "memory.mem")?;
 962:     tar.append_path_with_name(&cow_path, "diff.cow")?;
 963:     tar.finish()?;
 964:     info!("Export complete: {}", output_path);
 965:     Ok(())
 966: }
 967: async fn import_vm(input_path: &str, daemon_url: &str) -> Result<()> {
 968:     let file = File::open(input_path)?;
 969:     let tar = GzDecoder::new(file);
 970:     let mut archive = Archive::new(tar);
 971:     let temp_dir = tempfile::tempdir()?;
 972:     info!("Unpacking to temporary location: {:?}", temp_dir.path());
 973:     archive.unpack(temp_dir.path())?;
 974:     let snap_path = temp_dir.path().join("snapshot.snap");
 975:     let mem_path = temp_dir.path().join("memory.mem");
 976:     let cow_path = temp_dir.path().join("diff.cow");
 977:     if !snap_path.exists() || !mem_path.exists() || !cow_path.exists() {
 978:         return Err(anyhow::anyhow!(
 979:             "Invalid export archive. Missing core files."
 980:         ));
 981:     }
 982:     let client = Client::new();
 983:     let payload = RestoreRequest {
 984:         snapshot_path: snap_path.to_string_lossy().to_string(),
 985:         mem_path: mem_path.to_string_lossy().to_string(),
 986:         cow_path: cow_path.to_string_lossy().to_string(),
 987:         original_vm_id: "imported".to_string(),
 988:     };
 989:     let resp = client
 990:         .post(format!("{}/restore", daemon_url))
 991:         .json(&payload)
 992:         .send()
 993:         .await;
 994:     handle_response(resp, daemon_url).await?;
 995:     Ok(())
 996: }
