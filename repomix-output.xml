 762:                 if let Ok(list) = r.json::<ListResponse>().await {
 763:                     for vm in list.vms {
 764:                         if let Some(s) = vm.labels.get("ignite.stack") {
 765:                             if s == &stack_name {
 766:                                 if let Some(svc) = vm.labels.get("ignite.service") {
 767:                                     current_state.entry(svc.clone()).or_default().push(vm.id);
 768:                                 }
 769:                             }
 770:                         }
 771:                     }
 772:                 }
 773:             }
 774:             for (svc_name, target_count) in scale_map {
 775:                 let running_list = current_state.get(&svc_name).cloned().unwrap_or_default();
 776:                 let running_count = running_list.len();
 777:                 info!(
 778:                     "Scaling {} from {} to {}",
 779:                     svc_name, running_count, target_count
 780:                 );
 781:                 if target_count > running_count {
 782:                     let needed = target_count - running_count;
 783:                     let service = compose.services.get(&svc_name).unwrap();
 784:                     for i in 0..needed {
 785:                         info!("Starting replica {}/{}", i + 1, needed);
 786:                         start_service_helper(&client, daemon_url, &stack_name, &svc_name, service)
 787:                             .await?;
 788:                     }
 789:                 } else if running_count > target_count {
 790:                     let remove_count = running_count - target_count;
 791:                     for i in 0..remove_count {
 792:                         if let Some(id) = running_list.get(running_count - 1 - i) {
 793:                             info!("Stopping replica {} (VM {})", running_count - i, id);
 794:                             let resp = client
 795:                                 .post(format!("{}/stop/{}", daemon_url, id))
 796:                                 .send()
 797:                                 .await;
 798:                             handle_simple_response(resp, daemon_url).await?;
 799:                         }
 800:                     }
 801:                 } else {
 802:                     println!(
 803:                         "Service {} is already at target scale ({}).",
 804:                         svc_name, target_count
 805:                     );
 806:                 }
 807:             }
 808:         }
 809:     }
 810:     Ok(())
 811: }
 812: async fn run_doctor() -> Result<()> {
 813:     println!(
 814:         "{}",
 815:         "Ignite Doctor - System Health Check".bold().underline()
 816:     );
 817:     println!();
 818:     let mut all_passed = true;
 819:     let check = |name: &str, result: Result<bool>, required: bool| -> bool {
 820:         match result {
 821:             Ok(true) => {
 822:                 println!("{} {}", "[OK]".green().bold(), name);
 823:                 true
 824:             }
 825:             Ok(false) => {
 826:                 if required {
 827:                     println!("{} {}", "[FAIL]".red().bold(), name);
 828:                     false
 829:                 } else {
 830:                     println!("{} {}", "[WARN]".yellow().bold(), name);
 831:                     true
 832:                 }
 833:             }
 834:             Err(e) => {
 835:                 if required {
 836:                     println!("{} {} ({})", "[FAIL]".red().bold(), name, e);
 837:                     false
 838:                 } else {
 839:                     println!("{} {} ({})", "[WARN]".yellow().bold(), name, e);
 840:                     true
 841:                 }
 842:             }
 843:         }
 844:     };
 845:     if !check("KVM Device Access (/dev/kvm)", check_kvm(), true) {
 846:         all_passed = false;
 847:     }
 848:     if !check("Cgroups v2 (/sys/fs/cgroup)", check_cgroups(), true) {
 849:         all_passed = false;
 850:     }
 851:     if !check("Firecracker Binary", check_binary("firecracker"), true) {
 852:         all_passed = false;
 853:     }
 854:     if !check("Virtiofsd Binary", check_binary("virtiofsd"), true) {
 855:         all_passed = false;
 856:     }
 857:     if !check("Ignite Bridge (ign0)", check_bridge(), false) {}
 858:     if !check("debugfs (e2fsprogs)", check_binary("debugfs"), false) {}
 859:     println!();
 860:     if all_passed {
 861:         println!("{}", "Your system is ready for Ignite!".green().bold());
 862:     } else {
 863:         println!(
 864:             "{}",
 865:             "Some checks failed. Please review the errors above."
 866:                 .red()
 867:                 .bold()
 868:         );
 869:     }
 870:     Ok(())
 871: }
 872: fn check_kvm() -> Result<bool> {
