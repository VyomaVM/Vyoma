1178: ### 4.3 Replace Git-Based Time Travel with Proper Snapshot Tree
1179: 
1180: **Crate**: `crates/ignite-storage/src/snapshot_tree.rs`  
1181: **Priority**: P1 — git is an external dep, wrong abstraction, and breaks CoW delta efficiency.
1182: 
1183: The git-based approach (ADR in the codebase) must be removed and replaced with a proper snapshot graph backed by sled.
1184: 
1185: #### 4.3.1 Snapshot Tree Data Model
1186: 
1187: ```rust
1188: // crates/ignite-storage/src/snapshot_tree.rs
1189: 
1190: #[derive(Debug, Clone, Serialize, Deserialize)]
1191: pub struct SnapshotNode {
1192:     pub id: String,           // UUID
1193:     pub vm_id: String,
1194:     pub parent_id: Option<String>,  // None = root snapshot
1195:     pub created_at: u64,            // Unix timestamp
1196:     pub label: Option<String>,      // User-defined e.g. "pre-deploy"
1197:     pub tag: Option<String>,        // e.g. "snap:6"
1198:     pub memory_path: PathBuf,       // Firecracker .mem file
1199:     pub snapshot_path: PathBuf,     // Firecracker .snap file
1200:     pub cow_delta_path: PathBuf,    // COW diff since parent
1201:     pub cow_delta_size: u64,        // Bytes
1202:     pub memory_size: u64,
1203: }
1204: 
1205: pub struct SnapshotTree {
1206:     db: sled::Tree,
1207: }
1208: 
1209: impl SnapshotTree {
1210:     /// Create a new snapshot, optionally parenting off another
1211:     pub fn create(&self, node: &SnapshotNode) -> Result<()> {
1212:         let key = node.id.as_bytes().to_vec();
1213:         let value = serde_json::to_vec(node)?;
1214:         self.db.insert(key, value)?;
1215:         self.db.flush()?;
1216:         Ok(())
1217:     }
1218: 
1219:     /// List all snapshots for a VM in chronological order
1220:     pub fn history(&self, vm_id: &str) -> Result<Vec<SnapshotNode>> {
1221:         let mut nodes: Vec<SnapshotNode> = self.db
1222:             .iter()
1223:             .filter_map(|r| r.ok())
1224:             .filter_map(|(_, v)| serde_json::from_slice(&v).ok())
1225:             .filter(|n: &SnapshotNode| n.vm_id == vm_id)
1226:             .collect();
1227:         
1228:         nodes.sort_by_key(|n| n.created_at);
1229:         Ok(nodes)
1230:     }
1231: 
1232:     /// Fork a new VM from a historical snapshot (like git checkout -b)
1233:     pub fn branch(&self, snap_id: &str, new_vm_id: &str) -> Result<SnapshotNode> {
1234:         let parent = self.get(snap_id)?;
1235:         
1236:         // Create a new COW layer that reads from the snapshot's state
1237:         // The new VM will start from the snapshot's disk + memory state
1238:         let new_node = SnapshotNode {
1239:             id: uuid::Uuid::new_v4().to_string(),
1240:             vm_id: new_vm_id.to_string(),
1241:             parent_id: Some(snap_id.to_string()),
1242:             created_at: unix_now(),
1243:             label: Some(format!("branched-from-{}", snap_id)),
1244:             ..parent.clone()
1245:         };
1246:         
1247:         self.create(&new_node)?;
1248:         Ok(new_node)
1249:     }
1250: 
1251:     /// Compute filesystem diff between two snapshots
1252:     pub fn diff(&self, snap_a: &str, snap_b: &str) -> Result<SnapshotDiff> {
1253:         // Mount both COW layers read-only and run a recursive diff
1254:         let a = self.get(snap_a)?;
1255:         let b = self.get(snap_b)?;
1256:         
1257:         // Use debugfs to list changed inodes without mounting
1258:         compute_ext4_diff(&a.cow_delta_path, &b.cow_delta_path)
1259:     }
1260: }
1261: ```
