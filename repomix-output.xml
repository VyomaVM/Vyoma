40:         let path = Path::new(&self.root_path).join(format!("ignite-{}", vm_id));
41:         let period = 100000;
42:         let quota = vcpu_percentage * 1000;
43:         let file_path = path.join("cpu.max");
44:         fs::write(file_path, format!("{} {}", quota, period))?;
45:         Ok(())
46:     }
