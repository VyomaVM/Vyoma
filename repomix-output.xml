 927: ### 3.7 Implement `ign commit`, `ign save`, `ign load`
 928: 
 929: **Crate**: `crates/ign/src/commands/image.rs`, `crates/ignited/src/api/images.rs`  
 930: **Priority**: P2
 931: 
 932: #### 3.7.1 `ign commit <vm-id> <new-image-tag>`
 933: 
 934: Pauses the VM, flushes the COW delta to the base image layer to create a new read-only image, then resumes.
 935: 
 936: ```rust
 937: // crates/ignited/src/api/images.rs
 938: 
 939: pub async fn commit_vm(vm_id: &str, tag: &str, vm_manager: &VmManager) -> Result<ImageId> {
 940:     // 1. Pause VM via Firecracker API
 941:     vm_manager.pause_vm(vm_id).await?;
 942:     
 943:     // 2. Merge COW layer into new base image
 944:     //    Use dmsetup to read the merged snapshot into a new ext4 file
 945:     let src_dm = vm_manager.get_dm_device(vm_id)?;
 946:     let new_image_path = images_dir().join(format!("{}.ext4", tag_to_path(tag)));
 947:     
 948:     // dd the device mapper device into a new file
 949:     Command::new("dd")
 950:         .args([
 951:             &format!("if={}", src_dm),
 952:             &format!("of={}", new_image_path.display()),
 953:             "bs=4M",
 954:         ])
 955:         .status()?;
 956:     
 957:     // 3. Write ignite-config.json for the new image
 958:     let config = vm_manager.get_vm_config(vm_id)?;
 959:     std::fs::write(
 960:         new_image_path.with_extension("json"),
 961:         serde_json::to_vec_pretty(&config)?,
 962:     )?;
 963:     
 964:     // 4. Resume VM
 965:     vm_manager.resume_vm(vm_id).await?;
 966:     
 967:     // 5. Register in local image store
 968:     let image_id = register_local_image(tag, &new_image_path)?;
 969:     Ok(image_id)
 970: }
 971: ```
 972: 
 973: #### 3.7.2 `ign save <image> -o <file.tar.gz>` and `ign load -i <file.tar.gz>`
 974: 
 975: Bundle the ext4 image file + ignite-config.json into a compressed tar. This is a simpler version of the existing `ign export` / `ign import` which operates on VM snapshots.
 976: 
 977: ```rust
 978: // crates/ign/src/commands/image.rs
 979: 
 980: pub async fn cmd_save(image: &str, output: &Path, client: &Client) -> Result<()> {
 981:     let resp = client.get_image_export(image).await?;
 982:     let file = File::create(output)?;
 983:     let gz = GzEncoder::new(file, Compression::default());
 984:     let mut tar = TarBuilder::new(gz);
 985:     
 986:     tar.append_data(&mut resp.ext4_reader(), "rootfs.ext4")?;
 987:     tar.append_data(&mut Cursor::new(&resp.config_json), "ignite-config.json")?;
 988:     tar.append_data(&mut Cursor::new(&resp.manifest_json), "manifest.json")?;
 989:     
 990:     tar.finish()?;
 991:     println!("Saved {} to {}", image, output.display());
 992:     Ok(())
 993: }
 994: 
 995: pub async fn cmd_load(input: &Path, client: &Client) -> Result<()> {
 996:     let file = File::open(input)?;
 997:     let gz = GzDecoder::new(file);
 998:     let mut archive = Archive::new(gz);
 999:     
1000:     let resp = client.post_image_import(archive.entries()?).await?;
1001:     println!("Loaded image: {}", resp.tag);
1002:     Ok(())
1003: }
1004: ```
