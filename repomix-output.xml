1899:                     prune_old_snapshots(&self.vm_id, self.retain_count, &tree).await;
1900:                 }
1901:                 Err(e) => tracing::warn!("Auto-snapshot failed for {}: {}", self.vm_id, e),
1902:             }
1903:         }
1904:     }
