10:     let addr = format!("{}:53", gateway_ip);
11:     info!("Starting DNS Server on {}", addr);
12:     tokio::spawn(async move {
13:         let socket = loop {
14:             match UdpSocket::bind(&addr).await {
15:                 Ok(s) => {
16:                     info!("DNS Server successfully bound to {}", addr);
17:                     break s;
18:                 },
19:                 Err(e) => {
20:                     warn!("DNS bind failed (interface might not be ready): {}. Retrying in 5s...", e);
21:                     tokio::time::sleep(std::time::Duration::from_secs(5)).await;
22:                 }
23:             }
24:         };
25:         let mut buf = [0u8; 512];
26:         loop {
27:             match socket.recv_from(&mut buf).await {
28:                 Ok((len, src)) => {
29:                     match handle_conn(&buf[..len], &state).await {
30:                         Ok(response) => {
31:                             if !response.is_empty() {
32:                                 let _ = socket.send_to(&response, src).await;
33:                             }
34:                         },
35:                         Err(e) => {
36:                             debug!("DNS Handle error: {}", e);
37:                         }
38:                     }
39:                 },
40:                 Err(e) => {
41:                     error!("DNS Receive Error: {}", e);
42:                 }
43:             }
44:         }
45:     });
46: }
47: async fn handle_conn(buf: &[u8], state: &AppState) -> anyhow::Result<Vec<u8>> {
48:     let packet = Packet::parse(buf)?;
49:     if packet.has_flags(simple_dns::PacketFlag::RESPONSE) {
50:         return Ok(vec![]);
51:     }
52:     let mut reply = Packet::new_reply(packet.id());
53:     for question in packet.questions {
54:         let name_str = question.qname.to_string();
55:         if question.qtype == QTYPE::TYPE(TYPE::A) && (name_str.ends_with(".ignite") || !name_str.contains('.')) {
56:              let search_name = name_str.trim_end_matches(".ignite").trim_end_matches('.').to_string();
57:              let candidates = {
58:                  let vms = state.vms.lock().unwrap();
59:                  if let Some(vm_arc) = vms.get(&search_name) {
60:                      vec![vm_arc.clone()]
61:                  } else {
62:                      vms.values().cloned().collect()
63:                  }
64:              };
65:              let mut ips = Vec::new();
66:              for vm_arc in candidates {
67:                  let vm = vm_arc.lock().await;
68:                  if vm.id == search_name || vm.hostname.as_deref() == Some(search_name.as_str()) {
69:                       let ip_str = &vm.ip_address;
70:                       let ip_clean = ip_str.split('/').next().unwrap_or(ip_str);
71:                       if let Ok(ipv4) = ip_clean.parse::<Ipv4Addr>() {
72:                           ips.push(ipv4);
73:                       }
74:                  }
75:              }
76:              for ipv4 in ips {
77:                  let rdata = RData::A(A { address: ipv4.into() });
78:                  let rr = ResourceRecord::new(question.qname.clone(), CLASS::IN, 10, rdata);
79:                  reply.answers.push(rr);
80:              }
81:         }
82:     }
83:     if reply.answers.is_empty() {
84:          return forward_query(buf).await;
85:     }
86:     Ok(reply.build_bytes_vec().map_err(|e| anyhow::anyhow!("Build failed: {:?}", e))?)
87: }
88: async fn forward_query(buf: &[u8]) -> anyhow::Result<Vec<u8>> {
89:     let upstream = "1.1.1.1:53";
90:     let socket = UdpSocket::bind("0.0.0.0:0").await?;
91:     socket.send_to(buf, upstream).await?;
92:     let mut resp_buf = [0u8; 512];
93:     let (len, _) = tokio::time::timeout(std::time::Duration::from_millis(500), socket.recv_from(&mut resp_buf))
94:         .await
95:         .map_err(|_| anyhow::anyhow!("Upstream timeout"))??;
96:     Ok(resp_buf[..len].to_vec())
97: }
</file>

