<file path="crates/ignite-core/src/builder.rs">
 1: use serde::{Deserialize, Serialize};
 2: use anyhow::{Result, anyhow};
 3: use std::path::Path;
 4: use std::fs::File;
 5: use std::io::{BufRead, BufReader};
 6: #[derive(Debug, Clone, Serialize, Deserialize)]
 7: pub enum Instruction {
 8:     From(String),
 9:     Run(String),
10:     Copy { src: String, dest: String },
11: }
12: #[derive(Debug, Clone, Serialize, Deserialize)]
13: pub struct IgniteFile {
14:     pub instructions: Vec<Instruction>,
15: }
16: impl IgniteFile {
17:     pub fn parse(path: &Path) -> Result<Self> {
18:         let file = File::open(path)?;
19:         let reader = BufReader::new(file);
20:         let mut instructions = Vec::new();
21:         for line in reader.lines() {
22:             let line = line?;
23:             let trimmed = line.trim();
24:             if trimmed.is_empty() || trimmed.starts_with('#') {
25:                 continue;
26:             }
27:             let parts: Vec<&str> = trimmed.splitn(2, ' ').collect();
28:             if parts.is_empty() {
29:                 continue;
30:             }
31:             match parts[0].to_uppercase().as_str() {
32:                 "FROM" => {
33:                     if parts.len() < 2 { return Err(anyhow!("FROM requires an argument")); }
34:                     instructions.push(Instruction::From(parts[1].trim().to_string()));
35:                 },
36:                 "RUN" => {
37:                     if parts.len() < 2 { return Err(anyhow!("RUN requires an argument")); }
38:                     instructions.push(Instruction::Run(parts[1].trim().to_string()));
39:                 },
40:                 "COPY" => {
41:                      if parts.len() < 2 { return Err(anyhow!("COPY requires arguments")); }
42:                      let args = parts[1].trim();
43:                      let copy_parts: Vec<&str> = args.split_whitespace().collect();
44:                      if copy_parts.len() < 2 { return Err(anyhow!("COPY requires src and dest")); }
45:                      instructions.push(Instruction::Copy {
46:                          src: copy_parts[0].to_string(),
47:                          dest: copy_parts[1].to_string(),
48:                      });
49:                 },
50:                 _ => {
51:                     return Err(anyhow!("Unknown instruction: {}", parts[0]));
52:                 }
53:             }
54:         }
55:         Ok(Self { instructions })
56:     }
57: }
