2092: ### 6.4 Trusted Boot Chain
2093: 
2094: **Crate**: `crates/ignited/src/` and `crates/ignite-image/src/signing.rs`  
2095: **Priority**: P3
2096: 
2097: ```rust
2098: // crates/ignite-image/src/signing.rs
2099: 
2100: use ed25519_dalek::{SigningKey, VerifyingKey, Signer, Verifier, Signature};
2101: use sha2::{Sha256, Digest};
2102: 
2103: /// Sign a VMIF manifest with an Ed25519 key
2104: pub fn sign_manifest(manifest: &VmifManifest, key: &SigningKey) -> Result<SignedManifest> {
2105:     let manifest_bytes = serde_json::to_vec(manifest)?;
2106:     let signature = key.sign(&manifest_bytes);
2107:     
2108:     Ok(SignedManifest {
2109:         manifest: manifest.clone(),
2110:         signature: signature.to_bytes().to_vec(),
2111:         public_key: key.verifying_key().to_bytes().to_vec(),
2112:     })
2113: }
2114: 
2115: /// Verify a signed VMIF manifest before booting
2116: pub fn verify_manifest(signed: &SignedManifest, trusted_key: &VerifyingKey) -> Result<()> {
2117:     let manifest_bytes = serde_json::to_vec(&signed.manifest)?;
2118:     let signature = Signature::from_bytes(&signed.signature.as_slice().try_into()?);
2119:     
2120:     trusted_key.verify(&manifest_bytes, &signature)
2121:         .map_err(|e| anyhow!("Image signature verification failed: {}", e))
2122: }
2123: ```
