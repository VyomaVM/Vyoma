1736: // crates/ignite-image/src/vmif.rs
1737: 
1738: /// VMIF (VM Image Format) — the stable on-disk format for Ignite images
1739: /// Layout (OCI-compatible artifact stored in any OCI registry):
1740: ///   ignite.toml  — image metadata
1741: ///   rootfs.sqfs  — squashfs root filesystem (read-only, compressed)
1742: ///   kernel.vmlinuz — guest kernel (optional, uses bundled default if absent)
1743: #[derive(Debug, Clone, Serialize, Deserialize)]
1744: pub struct VmifManifest {
1745:     pub schema_version: u32,        // 1
1746:     pub created: String,            // RFC3339 timestamp
1747:     pub arch: String,               // "amd64", "arm64"
1748:     pub kernel: Option<String>,     // OCI digest of kernel layer
1749:     pub rootfs: String,             // OCI digest of rootfs layer
1750:     pub config: OciImageConfig,     // CMD, ENTRYPOINT, ENV, etc.
1751:     pub labels: HashMap<String, String>,
1752:     pub size_bytes: u64,            // Uncompressed rootfs size
1753: }
