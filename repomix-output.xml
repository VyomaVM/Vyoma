1059: async fn start_service_helper(
1060:     client: &Client,
1061:     daemon_url: &str,
1062:     stack_name: &str,
1063:     name: &str,
1064:     service: &ignite_compose::Service,
1065: ) -> Result<()> {
1066:     let image_target = if let Some(ref build) = service.build {
1067:         let context = match build {
1068:             ignite_compose::BuildSource::Path(p) => p.clone(),
1069:             ignite_compose::BuildSource::Config(c) => c.context.clone(),
1070:         };
1071:         info!("Building service '{}' from {}", name, context);
1072:         build_image(&context, daemon_url).await?
1073:     } else if let Some(ref img) = service.image {
1074:         img.clone()
1075:     } else {
1076:         error!("Service '{}' has no image or build context", name);
1077:         return Ok(());
1078:     };
1079:     let mut port_mappings = Vec::new();
1080:     if let Some(ref ports) = service.ports {
1081:         for p in ports {
1082:             let parts: Vec<&str> = p.split(':').collect();
1083:             if parts.len() == 2 {
1084:                 let h = parts[0].parse().unwrap_or(0);
1085:                 let v = parts[1].parse().unwrap_or(0);
1086:                 port_mappings.push(PortMapping {
1087:                     host_port: h,
1088:                     vm_port: v,
1089:                 });
1090:             }
1091:         }
1092:     }
1093:     let mut volume_mounts = Vec::new();
1094:     if let Some(ref vols) = service.volumes {
1095:         for v in vols {
1096:             let parts: Vec<&str> = v.split(':').collect();
1097:             if parts.len() == 2 {
1098:                 volume_mounts.push(VolumeMount {
1099:                     host_path: parts[0].to_string(),
1100:                     vm_path: parts[1].to_string(),
1101:                     read_only: false,
1102:                 });
1103:             }
1104:         }
1105:     }
1106:     let payload = RunRequest {
1107:         image: image_target,
1108:         vcpu: service.cpus.unwrap_or(1),
1109:         mem_size_mib: service.memory.unwrap_or(512),
1110:         ports: port_mappings,
1111:         volumes: volume_mounts,
1112:         hostname: Some(name.to_string()),
1113:         labels: {
1114:             let mut l = HashMap::new();
1115:             l.insert("ignite.stack".to_string(), stack_name.to_string());
1116:             l.insert("ignite.service".to_string(), name.to_string());
1117:             l
1118:         },
1119:     };
1120:     let resp = client
1121:         .post(format!("{}/run", daemon_url))
1122:         .json(&payload)
1123:         .send()
1124:         .await;
1125:     match resp {
1126:         Ok(r) => {
1127:             if r.status().is_success() {
1128:                 let body: RunResponse = r.json().await?;
1129:                 info!("Service '{}' started as VM {}", name, body.vm_id);
1130:             } else {
1131:                 error!("Failed to start service '{}': {}", name, r.status());
1132:             }
1133:         }
1134:         Err(e) => error!("Failed to request start for '{}': {}", name, e),
1135:     }
1136:     Ok(())
1137: }
