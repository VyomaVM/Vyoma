  90:     "crates/ign",             # CLI binary
  91:     "crates/ignited",         # Daemon binary
  92:     "crates/ignite-core",     # VM lifecycle, OCI, storage, network, vmm
  93:     "crates/ignite-compose",  # Compose YAML schema + orchestrator
  94:     "crates/ignite-net",      # Network management (Phase 1 refactor)
  95:     "crates/ignite-storage",  # Storage layer refactor (Phase 2)
  96:     "crates/ignite-image",    # VMIF format + OCI bridge (Phase 3)
  97:     "crates/ignite-agent",    # In-VM agent binary, musl target (Phase 4)
  98:     "crates/ignite-teleport", # Pre-copy live migration (Phase 3)
  99:     "crates/ignite-proto",    # Protobuf definitions for gRPC (Phase 3)
