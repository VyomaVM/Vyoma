<file path="tests/e2e/common.sh">
 1: RED='\033[0;31m'
 2: GREEN='\033[0;32m'
 3: NC='\033[0m'
 4: LOG_DIR="/tmp/ignite-tests-$(date +%s)"
 5: mkdir -p $LOG_DIR
 6: export IGNITED_BIN="$(pwd)/target/release/ignited"
 7: export IGN_BIN="$(pwd)/target/release/ign"
 8: export REAL_HOME=$HOME
 9: if [ ! -f "$IGNITED_BIN" ]; then
10:     echo "Error: Binary not found at $IGNITED_BIN. Run 'cargo build --release' first."
11:     exit 1
12: fi
13: check_root() {
14:     if [ "$EUID" -ne 0 ]; then
15:         echo -e "${RED}Error: Tests must be run as root (for Firecracker/CNI).${NC}"
16:         sudo -n true 2>/dev/null || { echo "Please run with sudo or provide password."; exit 1; }
17:     fi
18: }
19: setup_env() {
20:     export TEST_HOME=$(mktemp -d)
21:     export HOME=$TEST_HOME
22:     echo "Test Environment: $TEST_HOME"
23:     mkdir -p $TEST_HOME/.ignite/cni/bin
24:     if [ -d "$REAL_HOME/.ignite/cni/bin" ] && [ "$(ls -A $REAL_HOME/.ignite/cni/bin)" ]; then
25:          echo "Copying CNI plugins from $REAL_HOME..."
26:          cp $REAL_HOME/.ignite/cni/bin/* $TEST_HOME/.ignite/cni/bin/
27:     fi
28:     if [ -d "/usr/lib/cni" ]; then
29:         cp /usr/lib/cni/* $TEST_HOME/.ignite/cni/bin/
30:     elif [ -d "/opt/cni/bin" ]; then
31:         cp /opt/cni/bin/* $TEST_HOME/.ignite/cni/bin/
32:     else
33:         echo -e "${RED}CNI Plugins not found. Downloading...${NC}"
34:         curl -sL https://github.com/containernetworking/plugins/releases/download/v1.3.0/cni-plugins-linux-amd64-v1.3.0.tgz | tar -xz -C $TEST_HOME/.ignite/cni/bin
35:     fi
36: }
37: cleanup_env() {
38:     local pid=$1
39:     if [ -n "$pid" ]; then
40:         kill $pid || true
41:         wait $pid || true
42:     fi
43:     pkill -P $$ ignited || true
44:     sudo dmsetup remove_all || true
45:     losetup -D || true
46:     rm -rf $TEST_HOME
47: }
48: handle_error() {
49:     echo -e "${RED}Test Error - Cleaning up...${NC}"
50:     pkill ignited || true
51:     rm -rf /tmp/ignite-tests-*
52: }
53: assert_success() {
54:     if [ $? -ne 0 ]; then
55:         echo -e "${RED}Test Failed: $1${NC}"
56:         exit 1
57:     else
58:         echo -e "${GREEN}Pass: $1${NC}"
59:     fi
60: }
</file>

