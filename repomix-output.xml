 800: pub async fn stream_logs(
 801:     State(state): State<AppState>,
 802:     Path(id): Path<String>,
 803: ) -> Result<Sse<impl Stream<Item = Result<Event, Infallible>>>, (StatusCode, String)> {
 804:     info!("Request to stream logs for VM: {}", id);
 805:     let vm_arc = {
 806:         let vms = state.vms.lock().unwrap();
 807:         vms.get(&id).cloned()
 808:     };
 809:     if let Some(vm_mutex) = vm_arc {
 810:         let vm = vm_mutex.lock().await;
 811:         let rx = vm.vmm.subscribe_logs();
 812:         use tokio_stream::StreamExt;
 813:         let stream = BroadcastStream::new(rx).filter_map(|try_msg| {
 814:             match try_msg {
 815:                 Ok(msg) => Some(Ok(Event::default().data(msg))),
 816:                 Err(_) => None,
 817:             }
 818:         });
 819:         Ok(Sse::new(stream).keep_alive(axum::response::sse::KeepAlive::default()))
 820:     } else {
 821:         Err((StatusCode::NOT_FOUND, "VM not found".to_string()))
 822:     }
 823: }
