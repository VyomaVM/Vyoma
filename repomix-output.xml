<file path="crates/ignite-core/src/cni.rs">
  1: use anyhow::{anyhow, Context, Result};
  2: use serde::{Deserialize, Serialize};
  3: use std::collections::HashMap;
  4: use std::path::PathBuf;
  5: use std::process::{Command, Stdio};
  6: use tracing::{debug, info};
  7: #[derive(Serialize, Deserialize, Debug)]
  8: pub struct CniConfig {
  9:     #[serde(rename = "cniVersion")]
 10:     pub cni_version: String,
 11:     pub name: String,
 12:     #[serde(rename = "type")]
 13:     pub plugin_type: String,
 14:     #[serde(flatten)]
 15:     pub args: HashMap<String, serde_json::Value>,
 16: }
 17: pub struct CniManager {
 18:     plugin_path: PathBuf,
 19:     config_dir: PathBuf,
 20: }
 21: impl CniManager {
 22:     pub fn new(plugin_path: PathBuf, config_dir: PathBuf) -> Self {
 23:         Self {
 24:             plugin_path,
 25:             config_dir,
 26:         }
 27:     }
 28:     pub fn add(
 29:         &self,
 30:         network_name: Option<&str>,
 31:         container_id: &str,
 32:         netns: &str,
 33:         ifname: &str,
 34:     ) -> Result<serde_json::Value> {
 35:         let res = self.exec("ADD", network_name, container_id, netns, ifname)?;
 36:         res.ok_or_else(|| anyhow!("CNI Plugin returned no output for ADD"))
 37:     }
 38:     pub fn del(
 39:         &self,
 40:         network_name: Option<&str>,
 41:         container_id: &str,
 42:         netns: &str,
 43:         ifname: &str,
 44:     ) -> Result<()> {
 45:         self.exec("DEL", network_name, container_id, netns, ifname)
 46:             .map(|_| ())
 47:     }
 48:     fn exec(
 49:         &self,
 50:         command: &str,
 51:         network_name: Option<&str>,
 52:         container_id: &str,
 53:         netns: &str,
 54:         ifname: &str,
 55:     ) -> Result<Option<serde_json::Value>> {
 56:         let config_file = self.find_config(network_name)?;
 57:         let config_bytes = std::fs::read(&config_file).context("Failed to read CNI config")?;
 58:         let config: CniConfig =
 59:             serde_json::from_slice(&config_bytes).context("Failed to parse CNI config")?;
 60:         let plugin_binary = self.plugin_path.join(&config.plugin_type);
 61:         if !plugin_binary.exists() {
 62:             return Err(anyhow!("CNI plugin not found: {:?}", plugin_binary));
 63:         }
 64:         info!(
 65:             "CNI {}: Invoking plugin {:?} for {} (Net: {})",
 66:             command, config.plugin_type, container_id, config.name
 67:         );
 68:         let envs = vec![
 69:             ("CNI_COMMAND", command),
 70:             ("CNI_CONTAINERID", container_id),
 71:             ("CNI_NETNS", netns),
 72:             ("CNI_IFNAME", ifname),
 73:             ("CNI_PATH", self.plugin_path.to_str().unwrap()),
 74:         ];
 75:         let mut child = Command::new(&plugin_binary)
 76:             .envs(envs)
 77:             .stdin(Stdio::piped())
 78:             .stdout(Stdio::piped())
 79:             .stderr(Stdio::piped())
 80:             .spawn()
 81:             .context("Failed to spawn CNI plugin")?;
 82:         if let Some(mut stdin) = child.stdin.take() {
 83:             use std::io::Write;
 84:             stdin.write_all(&config_bytes)?;
 85:         }
 86:         let output = child.wait_with_output()?;
 87:         if !output.status.success() {
 88:             let stderr = String::from_utf8_lossy(&output.stderr);
 89:             return Err(anyhow!("CNI plugin failed: {}", stderr));
 90:         }
 91:         if command == "ADD" {
 92:             let stdout_str = String::from_utf8_lossy(&output.stdout);
 93:             debug!("CNI ADD Output: {}", stdout_str);
 94:             let res: serde_json::Value =
 95:                 serde_json::from_slice(&output.stdout).context("Failed to parse CNI output")?;
 96:             return Ok(Some(res));
 97:         }
 98:         Ok(None)
 99:     }
100:     fn find_config(&self, name_filter: Option<&str>) -> Result<PathBuf> {
101:         let mut entries: Vec<_> = std::fs::read_dir(&self.config_dir)?
102:             .filter_map(|e| e.ok())
103:             .map(|e| e.path())
104:             .filter(|p| {
105:                 p.extension().map_or(false, |ext| {
106:                     ext == "conf" || ext == "conflist" || ext == "json"
107:                 })
108:             })
109:             .collect();
110:         entries.sort();
111:         if let Some(target_name) = name_filter {
112:             for path in &entries {
113:                 if let Ok(content) = std::fs::read(path) {
114:                     if let Ok(config) = serde_json::from_slice::<CniConfig>(&content) {
115:                         if config.name == target_name {
116:                             return Ok(path.clone());
117:                         }
118:                     }
119:                 }
120:             }
121:             Err(anyhow!("Network config named '{}' not found", target_name))
122:         } else {
123:             entries
124:                 .first()
125:                 .cloned()
126:                 .ok_or_else(|| anyhow!("No CNI config found in {:?}", self.config_dir))
127:         }
128:     }
129:     pub fn list_networks(&self) -> Result<Vec<String>> {
130:         let mut names = Vec::new();
131:         for entry in std::fs::read_dir(&self.config_dir)? {
132:             let entry = entry?;
133:             let path = entry.path();
134:             if path
135:                 .extension()
136:                 .map_or(false, |e| e == "conf" || e == "json")
137:             {
138:                 let content = std::fs::read(&path)?;
139:                 if let Ok(config) = serde_json::from_slice::<CniConfig>(&content) {
140:                     names.push(config.name);
141:                 }
142:             }
143:         }
144:         Ok(names)
145:     }
146:     pub fn create_network(&self, name: &str, subnet: &str) -> Result<()> {
147:         let bridge_name = format!("ign-{}", name);
148:         let config = serde_json::json!({
149:             "cniVersion": "0.3.1",
150:             "name": name,
151:             "type": "bridge",
152:             "bridge": bridge_name,
153:             "isGateway": true,
154:             "ipMasq": true,
155:             "ipam": {
156:                 "type": "host-local",
157:                 "subnet": subnet,
158:                 "routes": [{ "dst": "0.0.0.0/0" }]
159:             }
160:         });
161:         let path = self.config_dir.join(format!("{}.conf", name));
162:         if path.exists() {
163:             return Err(anyhow!("Network config file exists"));
164:         }
165:         let f = std::fs::File::create(&path)?;
166:         serde_json::to_writer_pretty(f, &config)?;
167:         Ok(())
168:     }
169:     pub fn create_overlay_network(&self, name: &str, _subnet: &str) -> Result<()> {
170:         let config = serde_json::json!({
171:             "cniVersion": "0.4.0",
172:             "name": name,
173:             "type": "flannel",
174:             "delegate": {
175:                 "isDefaultGateway": true,
176:                 "hairpinMode": true
177:             }
178:         });
179:         let path = self.config_dir.join(format!("{}.conf", name));
180:         if path.exists() {
181:             return Err(anyhow!("Network config file exists"));
182:         }
183:         let f = std::fs::File::create(&path)?;
184:         serde_json::to_writer_pretty(f, &config)?;
185:         Ok(())
186:     }
187:     pub fn delete_network(&self, name: &str) -> Result<()> {
188:         for entry in std::fs::read_dir(&self.config_dir)? {
189:             let entry = entry?;
190:             let path = entry.path();
191:             if path
192:                 .extension()
193:                 .map_or(false, |e| e == "conf" || e == "json")
194:             {
195:                 let content = std::fs::read(&path)?;
196:                 if let Ok(config) = serde_json::from_slice::<CniConfig>(&content) {
197:                     if config.name == name {
198:                         std::fs::remove_file(path)?;
199:                         return Ok(());
200:                     }
201:                 }
202:             }
203:         }
204:         Err(anyhow!("Network not found"))
205:     }
206: }
