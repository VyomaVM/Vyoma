 821: #### 3.5.2 networks: Top-Level Key — Network Segmentation
 822: 
 823: When a compose stack specifies `networks:`, create a separate Linux bridge per named network. Services without an explicit network assignment go on the default bridge.
 824: 
 825: ```rust
 826: // crates/ignite-compose/src/orchestrator.rs
 827: 
 828: async fn provision_compose_networks(
 829:     compose: &ComposeFile,
 830:     daemon_client: &DaemonClient,
 831: ) -> Result<HashMap<String, CreatedNetwork>> {
 832:     let mut created = HashMap::new();
 833:     
 834:     for (name, config) in &compose.networks {
 835:         let driver = config.driver.as_deref().unwrap_or("bridge");
 836:         
 837:         let req = CreateNetworkRequest {
 838:             name: format!("{}_{}_{}", stack_name, name, random_suffix()),
 839:             driver: driver.to_string(),
 840:             internal: config.internal,
 841:             subnet: config.ipam.as_ref()
 842:                 .and_then(|i| i.config.first())
 843:                 .and_then(|c| c.subnet.clone()),
 844:         };
 845:         
 846:         let net = daemon_client.create_network(req).await?;
 847:         created.insert(name.clone(), net);
 848:     }
 849:     
 850:     // Ensure default network exists for services without explicit network config
 851:     if !created.contains_key("default") {
 852:         let default_net = daemon_client.create_network(CreateNetworkRequest {
 853:             name: format!("{}_default", stack_name),
 854:             driver: "bridge".to_string(),
 855:             ..Default::default()
 856:         }).await?;
 857:         created.insert("default".to_string(), default_net);
 858:     }
 859:     
 860:     Ok(created)
 861: }
 862: ```
