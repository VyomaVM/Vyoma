58:     }
59:     pub fn remove_vm_cgroup(&self, vm_id: &str) -> Result<()> {
60:          let path = Path::new(&self.root_path).join(format!("ignite-{}", vm_id));
61:          if path.exists() {
62:              fs::remove_dir(&path)?;
63:          }
64:          Ok(())
65:     }
66:     pub fn get_oom_kill_count(&self, vm_id: &str) -> Result<u64> {
67:         let path = Path::new(&self.root_path).join(format!("ignite-{}", vm_id)).join("memory.events");
68:         if !path.exists() {
69:              return Ok(0);
70:         }
71:         let content = fs::read_to_string(path)?;
72:         for line in content.lines() {
73:             if line.starts_with("oom_kill ") {
74:                  if let Some(val_str) = line.split_whitespace().nth(1) {
75:                      return Ok(val_str.parse().unwrap_or(0));
76:                  }
77:             }
78:         }
79:         Ok(0)
80:     }
