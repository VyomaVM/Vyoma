12:     let path = if path.is_empty() { "index.html" } else { path };
13:     match Assets::get(path) {
14:         Some(content) => {
15:             let mime = mime_guess::from_path(path).first_or_octet_stream();
16:             Response::builder()
17:                 .header(header::CONTENT_TYPE, mime.as_ref())
18:                 .body(Body::from(content.data))
19:                 .unwrap()
20:         }
21:         None => {
22:             if path.contains('.') {
23:                 return (StatusCode::NOT_FOUND, "404 Not Found").into_response();
24:             }
25:              match Assets::get("index.html") {
26:                 Some(content) => {
27:                     Response::builder()
28:                         .header(header::CONTENT_TYPE, "text/html")
29:                         .body(Body::from(content.data))
30:                         .unwrap()
31:                 },
32:                 None => (StatusCode::NOT_FOUND, "index.html missing").into_response(),
33:             }
34:         }
35:     }
