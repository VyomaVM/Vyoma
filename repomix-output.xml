 785: fn git_commit(path: &std::path::Path, message: &str) -> std::io::Result<()> {
 786:     Command::new("git")
 787:         .arg("add")
 788:         .arg(".")
 789:         .current_dir(path)
 790:         .output()?;
 791:     Command::new("git")
 792:         .arg("commit")
 793:         .arg("--allow-empty")
 794:         .arg("-m")
 795:         .arg(message)
 796:         .current_dir(path)
 797:         .output()?;
