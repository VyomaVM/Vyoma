2046:     }
2047:     
2048:     return &pb.RunPodSandboxResponse{PodSandboxId: resp.VmId}, nil
2049: }
2050: 
2051: // CreateContainer — called for each container in a pod
2052: // Containers within a pod share the same VM via namespaces
2053: func (s *IgniteCriServer) CreateContainer(
2054:     ctx context.Context,
2055:     req *pb.CreateContainerRequest,
2056: ) (*pb.CreateContainerResponse, error) {
2057:     // The VM is already running (from RunPodSandbox).
2058:     // "Containers" within a pod are processes inside the VM.
2059:     // We use `ign exec` semantics to run the container command.
2060:     
2061:     vm_id := req.PodSandboxId
2062:     cmd := append(req.Config.Command, req.Config.Args...)
2063:     
2064:     execReq := &ignite.ExecRequest{
2065:         VmId:    vm_id,
2066:         Command: cmd,
2067:         Env:     req.Config.Envs,
2068:         WorkDir: req.Config.WorkingDir,
2069:     }
2070:     
2071:     execResp, err := s.client.StartExec(ctx, execReq)
2072:     // Returns a container ID = "vmid/process_id"
2073:     return &pb.CreateContainerResponse{ContainerId: execResp.ExecId}, nil
2074: }
2075: ```
