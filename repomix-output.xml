 17:     pub instructions: Vec<Instruction>,
 18: }
 19: impl IgniteFile {
 20:     pub fn parse(path: &Path) -> Result<Self> {
 21:         let file = File::open(path)?;
 22:         let reader = BufReader::new(file);
 23:         let mut instructions = Vec::new();
 24:         for line in reader.lines() {
 25:             let line = line?;
 26:             let trimmed = line.trim();
 27:             if trimmed.is_empty() || trimmed.starts_with('#') {
 28:                 continue;
 29:             }
 30:             let parts: Vec<&str> = trimmed.splitn(2, ' ').collect();
 31:             if parts.is_empty() {
 32:                 continue;
 33:             }
 34:             match parts[0].to_uppercase().as_str() {
 35:                 "FROM" => {
 36:                     if parts.len() < 2 { return Err(anyhow!("FROM requires an argument")); }
 37:                     instructions.push(Instruction::From(parts[1].trim().to_string()));
 38:                 },
 39:                 "RUN" => {
 40:                     if parts.len() < 2 { return Err(anyhow!("RUN requires an argument")); }
 41:                     instructions.push(Instruction::Run(parts[1].trim().to_string()));
 42:                 },
 43:                 "COPY" => {
 44:                      if parts.len() < 2 { return Err(anyhow!("COPY requires arguments")); }
 45:                      let args = parts[1].trim();
 46:                      let copy_parts: Vec<&str> = args.split_whitespace().collect();
 47:                      if copy_parts.len() < 2 { return Err(anyhow!("COPY requires src and dest")); }
 48:                      instructions.push(Instruction::Copy {
 49:                          src: copy_parts[0].to_string(),
 50:                          dest: copy_parts[1].to_string(),
 51:                      });
 52:                 },
 53:                 "CMD" => {
 54:                     if parts.len() < 2 { return Err(anyhow!("CMD requires arguments")); }
 55:                     let value = parts[1].trim();
 56:                     let args = if value.starts_with('[') && value.ends_with(']') {
 57:                         serde_json::from_str::<Vec<String>>(value).unwrap_or_else(|_| vec![value.to_string()])
 58:                     } else {
 59:                         vec![value.to_string()]
 60:                     };
 61:                     instructions.push(Instruction::Cmd(args));
 62:                 },
 63:                 "ENTRYPOINT" => {
 64:                     if parts.len() < 2 { return Err(anyhow!("ENTRYPOINT requires arguments")); }
 65:                     let value = parts[1].trim();
 66:                     let args = if value.starts_with('[') && value.ends_with(']') {
 67:                         serde_json::from_str::<Vec<String>>(value).unwrap_or_else(|_| vec![value.to_string()])
 68:                     } else {
 69:                         vec![value.to_string()]
 70:                     };
 71:                     instructions.push(Instruction::Entrypoint(args));
 72:                 },
 73:                 "ENV" => {
 74:                     if parts.len() < 2 { return Err(anyhow!("ENV requires arguments")); }
 75:                     let value = parts[1].trim();
 76:                     if let Some((k, v)) = value.split_once('=') {
 77:                         instructions.push(Instruction::Env {
 78:                             key: k.trim().to_string(),
 79:                             value: v.trim().to_string()
 80:                         });
 81:                     } else {
 82:                         let env_parts: Vec<&str> = value.split_whitespace().collect();
 83:                         if env_parts.len() >= 2 {
 84:                              instructions.push(Instruction::Env {
 85:                                  key: env_parts[0].to_string(),
 86:                                  value: env_parts[1..].join(" "),
 87:                              });
 88:                         }
 89:                     }
 90:                 },
 91:                 _ => {
 92:                     return Err(anyhow!("Unknown instruction: {}", parts[0]));
 93:                 }
 94:             }
 95:         }
 96:         Ok(Self { instructions })
 97:     }
 98: }
 99: #[cfg(test)]
100: mod tests {
101:     use super::*;
102:     use std::io::Write;
103:     use tempfile::NamedTempFile;
104:     #[test]
105:     fn test_parse_ignitefile() {
106:         let mut file = NamedTempFile::new().unwrap();
107:         writeln!(file, "FROM alpine:latest").unwrap();
108:         writeln!(file, "RUN apk add curl").unwrap();
109:         writeln!(file, "COPY . /app").unwrap();
110:         writeln!(file, "# This is a comment").unwrap();
111:         writeln!(file, "").unwrap(); // Empty line
112:         let ignite_file = IgniteFile::parse(file.path()).unwrap();
113:         assert_eq!(ignite_file.instructions.len(), 3);
114:         match &ignite_file.instructions[0] {
115:             Instruction::From(img) => assert_eq!(img, "alpine:latest"),
116:             _ => panic!("Expected FROM"),
117:         }
118:         match &ignite_file.instructions[1] {
119:             Instruction::Run(cmd) => assert_eq!(cmd, "apk add curl"),
120:             _ => panic!("Expected RUN"),
121:         }
122:         match &ignite_file.instructions[2] {
123:             Instruction::Copy { src, dest } => {
124:                 assert_eq!(src, ".");
125:                 assert_eq!(dest, "/app");
126:             },
127:             _ => panic!("Expected COPY"),
128:         }
129:     }
130: }
