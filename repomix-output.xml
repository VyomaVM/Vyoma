127:     async fn fetch_token(&self, realm: &str, service: Option<&str>, scope: Option<&str>, registry_host: &str) -> Result<String> {
128:         let mut url = realm.to_string();
129:         let mut query = vec![];
130:         if let Some(s) = service { query.push(format!("service={}", s)); }
131:         if let Some(s) = scope { query.push(format!("scope={}", s)); }
132:         if !query.is_empty() {
133:              url = format!("{}?{}", url, query.join("&"));
134:         }
135:         let mut req = self.client.get(&url);
136:         if let Some((user, pass)) = self.load_docker_creds(registry_host) {
137:              info!("Using authenticated access for {}", registry_host);
138:              req = req.basic_auth(user, Some(pass));
139:         }
140:         let resp = req.send().await?;
141:         if !resp.status().is_success() {
142:              return Err(anyhow!("Token request failed for {}: {}", registry_host, resp.status()));
143:         }
144:         let token_resp: TokenResponse = resp.json().await?;
145:         Ok(token_resp.token)
146:     }
147:     pub async fn pull_manifest(&mut self, image: &str) -> Result<String> {
148:         let (registry, repository, tag) = self.parse_image_ref(image);
149:         let proto = if registry.starts_with("localhost") { "http" } else { "https" };
150:         let manifest_url = format!("{}://{}/v2/{}/manifests/{}", proto, registry, repository, tag);
151:         info!("Fetching manifest from: {}", manifest_url);
152:         let cache_key = format!("{}/{}", registry, repository);
153:         let token = self.token_cache.get(&cache_key).cloned();
154:         let mut req = self.client.get(&manifest_url)
155:             .header("Accept", "application/vnd.docker.distribution.manifest.v2+json, application/vnd.oci.image.manifest.v1+json, application/vnd.oci.image.index.v1+json, application/vnd.docker.distribution.manifest.list.v2+json");
156:         if let Some(t) = &token {
157:              req = req.header("Authorization", format!("Bearer {}", t));
158:         }
159:         let resp = req.send().await?;
160:         let resp = if resp.status() == reqwest::StatusCode::UNAUTHORIZED {
161:              debug!("401 Unauthorized. Attempting auth negotiation...");
162:              let auth_header = resp.headers().get("www-authenticate")
163:                  .ok_or_else(|| anyhow!("401 Unauthorized but missing Www-Authenticate header"))?
164:                  .to_str()?;
165:              let realm = extract_field(auth_header, "realm").ok_or_else(|| anyhow!("Missing realm"))?;
166:              let service = extract_field(auth_header, "service");
167:              let scope = extract_field(auth_header, "scope");
168:              let new_token = self.fetch_token(&realm, service.as_deref(), scope.as_deref(), &registry).await?;
169:              self.token_cache.insert(cache_key.clone(), new_token.clone());
170:              self.client.get(&manifest_url)
171:                  .header("Authorization", format!("Bearer {}", new_token))
172:                  .header("Accept", "application/vnd.docker.distribution.manifest.v2+json, application/vnd.oci.image.manifest.v1+json, application/vnd.oci.image.index.v1+json, application/vnd.docker.distribution.manifest.list.v2+json")
173:                  .send().await?
174:         } else {
175:              resp
176:         };
177:         if !resp.status().is_success() {
178:              return Err(anyhow!("Failed to fetch manifest: {}", resp.status()));
179:         }
180:         let content_type = resp.headers().get("content-type")
181:             .and_then(|h| h.to_str().ok())
182:             .unwrap_or("unknown")
183:             .to_string();
184:         let body = resp.text().await?;
185:         if content_type.contains("list") || content_type.contains("index") {
186:              info!("Received Manifest List/Index. Resolving for linux/amd64...");
187:              let list: ManifestList = serde_json::from_str(&body)?;
188:              let target = list.manifests.iter().find(|m|
189:                  (m.platform.architecture == "amd64" || m.platform.architecture == "x86_64")
190:                  && m.platform.os == "linux"
191:              ).ok_or_else(|| anyhow!("No linux/amd64 manifest found in list"))?;
192:              info!("Resolved linux/amd64 digest: {}", target.digest);
193:              let resolved_url = format!("{}://{}/v2/{}/manifests/{}", proto, registry, repository, target.digest);
194:              let mut req = self.client.get(&resolved_url)
195:                   .header("Accept", "application/vnd.docker.distribution.manifest.v2+json, application/vnd.oci.image.manifest.v1+json");
196:              if let Some(t) = self.token_cache.get(&cache_key) {
197:                   req = req.header("Authorization", format!("Bearer {}", t));
198:              }
199:              let resolved_resp = req.send().await?;
200:              return Ok(resolved_resp.text().await?);
