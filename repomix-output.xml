  5: pub struct StorageManager;
  6: impl StorageManager {
  7:     pub fn create_empty_file(path: &Path, size_mb: u64) -> Result<()> {
  8:         info!("Creating {}MB file at {:?}", size_mb, path);
  9:         let size_arg = format!("{}M", size_mb);
 10:         let status = Command::new("truncate")
 11:             .arg("-s")
 12:             .arg(size_arg)
 13:             .arg(path)
 14:             .status()
 15:             .map_err(|e| anyhow!("Failed to execute truncate: {}", e))?;
 16:         if !status.success() {
 17:             return Err(anyhow!("truncate failed with status: {}", status));
 18:         }
 19:         Ok(())
 20:     }
 21:     pub fn create_cow_file(path: &Path, size_mb: u64) -> Result<()> {
 22:         info!("Creating COW file (sparse) of {}MB at {:?}", size_mb, path);
 23:         Self::create_empty_file(path, size_mb)
 24:     }
 25:     pub fn format_ext4(path: &Path) -> Result<()> {
 26:         info!("Formatting {:?} as ext4", path);
 27:         let status = Command::new("mkfs.ext4")
 28:             .arg("-F")
 29:             .arg(path)
 30:             .status()
 31:             .map_err(|e| anyhow!("Failed to execute mkfs.ext4: {}", e))?;
 32:         if !status.success() {
 33:             return Err(anyhow!("mkfs.ext4 failed with status: {}", status));
 34:         }
 35:         Ok(())
 36:     }
 37:     pub fn populate_image(image_path: &Path, source_dir: &Path) -> Result<()> {
 38:         if !crate::rootless::RootlessManager::is_root() {
 39:             return Self::populate_image_rootless(image_path, source_dir);
 40:         }
 41:         let mount_point = tempfile::tempdir()?;
 42:         let mount_path = mount_point.path();
 43:         info!("Mounting {:?} to {:?}", image_path, mount_path);
 44:         let status = Command::new("sudo")
 45:             .arg("mount")
 46:             .arg("-o")
 47:             .arg("loop")
 48:             .arg(image_path)
 49:             .arg(mount_path)
 50:             .status()
 51:             .map_err(|e| anyhow!("Failed to execute sudo mount: {}", e))?;
 52:         if !status.success() {
 53:              return Err(anyhow!("Mount failed. Do you have sudo permissions? Status: {}", status));
 54:         }
 55:         info!("Copying files from {:?} to {:?}", source_dir, mount_path);
 56:         let src_pattern = format!("{}/.", source_dir.to_string_lossy());
 57:         let status = Command::new("sudo")
 58:             .arg("cp")
 59:             .arg("-a")
 60:             .arg(&src_pattern)
 61:             .arg(mount_path)
 62:             .status()?;
 63:         if !status.success() {
 64:              let _ = Command::new("sudo").arg("umount").arg(mount_path).status();
 65:              return Err(anyhow!("Failed to copy files"));
 66:         }
 67:         info!("Unmounting...");
 68:         let status = Command::new("sudo")
 69:             .arg("umount")
 70:             .arg(mount_path)
 71:             .status()?;
 72:         if !status.success() {
 73:             warn!("Failed to unmount {:?}. You may need to do it manually.", mount_path);
 74:         }
 75:         Ok(())
 76:     }
 77:     pub fn populate_image_rootless(image_path: &Path, source_dir: &Path) -> Result<()> {
 78:          info!("Populating {:?} using debugfs (rootless)", image_path);
 79:         let mut script = String::new();
 80:         let mut stack = vec![source_dir.to_path_buf()];
 81:         while let Some(current_path) = stack.pop() {
 82:             for entry in std::fs::read_dir(&current_path)? {
 83:                  let entry = entry?;
 84:                  let path = entry.path();
 85:                  let rel_path = path.strip_prefix(source_dir)?.to_string_lossy().into_owned();
 86:                  let vm_path = format!("/{}", rel_path);
 87:                  let file_type = entry.file_type()?;
 88:                  if file_type.is_dir() {
 89:                      script.push_str(&format!("mkdir \"{}\"\n", vm_path));
 90:                      stack.push(path);
 91:                  } else if file_type.is_file() {
 92:                      script.push_str(&format!("write \"{}\" \"{}\"\n", path.to_string_lossy(), vm_path));
 93:                  } else if file_type.is_symlink() {
 94:                       let target = std::fs::read_link(&path)?;
 95:                       script.push_str(&format!("symlink \"{}\" \"{}\"\n", vm_path, target.to_string_lossy()));
 96:                  }
 97:             }
 98:         }
 99:         use std::io::Write;
100:         let mut temp_script = tempfile::Builder::new().suffix(".debugfs").tempfile()?;
101:         write!(temp_script, "{}", script)?;
102:         let script_path = temp_script.path().to_owned();
103:         let status = Command::new("debugfs")
104:             .arg("-w")
105:             .arg("-f")
106:             .arg(&script_path)
107:             .arg(image_path)
108:             .stdout(std::process::Stdio::null())
109:             .status()
110:             .map_err(|e| anyhow!("Failed to execute debugfs: {}", e))?;
111:         if !status.success() {
112:              return Err(anyhow!("debugfs failed with status: {}", status));
113:         }
114:         Ok(())
115:     }
116:     pub fn setup_loop_device(path: &Path) -> Result<String> {
117:         info!("Setting up loop device for {:?}", path);
118:         let output = Command::new("sudo")
119:             .arg("losetup")
120:             .arg("--find")
121:             .arg("--show")
122:             .arg(path)
123:             .output()
124:             .map_err(|e| anyhow!("Failed to execute losetup: {}", e))?;
125:         if !output.status.success() {
126:             return Err(anyhow!("losetup failed: {}", String::from_utf8_lossy(&output.stderr)));
127:         }
128:         let device = String::from_utf8(output.stdout)?.trim().to_string();
129:         info!("Attached {:?} to {}", path, device);
130:         Ok(device)
131:     }
132:     pub fn detach_loop_device(device_path: &str) -> Result<()> {
133:         info!("Detaching loop device {}", device_path);
134:         let status = Command::new("sudo")
135:             .arg("losetup")
136:             .arg("-d")
137:             .arg(device_path)
138:             .status()
139:             .map_err(|e| anyhow!("Failed to execute losetup -d: {}", e))?;
140:         if !status.success() {
141:              return Err(anyhow!("losetup -d failed with status: {}", status));
142:         }
143:         Ok(())
144:     }
145:     pub fn create_dm_snapshot(name: &str, base_dev: &str, cow_dev: &str, size_sectors: u64) -> Result<String> {
146:         info!("Creating Device Mapper snapshot '{}'", name);
147:         let table = format!("0 {} snapshot {} {} N 8", size_sectors, base_dev, cow_dev);
148:         let mut child = Command::new("sudo")
149:             .arg("dmsetup")
150:             .arg("create")
151:             .arg(name)
152:             .stdin(std::process::Stdio::piped())
153:             .spawn()
154:             .map_err(|e| anyhow!("Failed to spawn dmsetup: {}", e))?;
155:         if let Some(mut stdin) = child.stdin.take() {
156:             use std::io::Write;
157:             stdin.write_all(table.as_bytes())?;
158:         }
159:         let status = child.wait()?;
160:         if !status.success() {
161:              return Err(anyhow!("dmsetup create failed for {}", name));
162:         }
163:         let device_path = format!("/dev/mapper/{}", name);
164:         info!("Created DM device: {}", device_path);
165:         Ok(device_path)
166:     }
167:     pub fn remove_dm_device(name: &str) -> Result<()> {
168:         info!("Removing DM device '{}'", name);
169:         let status = Command::new("sudo")
170:             .arg("dmsetup")
171:             .arg("remove")
172:             .arg("--retry")
173:             .arg(name)
174:             .status()
175:             .map_err(|e| anyhow!("Failed to execute dmsetup remove: {}", e))?;
176:         if !status.success() {
177:             return Err(anyhow!("dmsetup remove failed for {}", name));
178:         }
179:         Ok(())
180:     }
181: }
