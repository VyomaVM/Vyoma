  6:     pub fn setup_bridge(name: &str, ip_cidr: &str) -> Result<()> {
  7:         info!("Setting up bridge '{}' with IP {}", name, ip_cidr);
  8:         let check_status = Command::new("sudo")
  9:              .args(&["ip", "link", "show", name])
 10:              .stdout(std::process::Stdio::null())
 11:              .stderr(std::process::Stdio::null())
 12:              .status();
 13:         let exists = match check_status {
 14:             Ok(s) => s.success(),
 15:             Err(_) => false,
 16:         };
 17:         if !exists {
 18:             let status = Command::new("sudo")
 19:                 .args(&["ip", "link", "add", "name", name, "type", "bridge"])
 20:                 .status()?;
 21:             if !status.success() {
 22:                  return Err(anyhow!("Failed to create bridge {}. Status: {}", name, status));
 23:             }
 24:         } else {
 25:              info!("Bridge {} already exists, skipping creation.", name);
 26:         }
 27:         let status = Command::new("sudo")
 28:             .args(&["ip", "addr", "add", ip_cidr, "dev", name])
 29:             .stdout(std::process::Stdio::null())
 30:             .stderr(std::process::Stdio::null())
 31:             .status()?;
 32:         if !status.success() {
 33:              let check = Command::new("ip")
 34:                 .args(&["addr", "show", "dev", name])
 35:                 .output()?;
 36:              let output = String::from_utf8_lossy(&check.stdout);
 37:              let ip_only = ip_cidr.split('/').next().unwrap_or(ip_cidr);
 38:              if !output.contains(ip_only) {
 39:                   let _ = Self::remove_interface(name);
 40:                   return Err(anyhow!("Failed to assign IP to bridge. Status: {}", status));
 41:              } else {
 42:                  info!("IP {} already assigned to {}", ip_only, name);
 43:              }
 44:         }
 45:         let status = Command::new("sudo")
 46:             .args(&["ip", "link", "set", "dev", name, "up"])
 47:             .status()?;
 48:         if !status.success() {
 49:              let _ = Self::remove_interface(name);
 50:              return Err(anyhow!("Failed to set bridge UP. Status: {}", status));
 51:         }
 52:         Ok(())
 53:     }
 54:     pub fn setup_tap(tap_name: &str, master_bridge: &str) -> Result<()> {
 55:         info!("Creating TAP '{}' attached to '{}'", tap_name, master_bridge);
 56:         let status = Command::new("sudo")
 57:             .args(&["ip", "tuntap", "add", "dev", tap_name, "mode", "tap"])
 58:             .status()?;
 59:         if !status.success() {
 60:              return Err(anyhow!("Failed to create TAP {}. Status: {}", tap_name, status));
 61:         }
 62:         let status = Command::new("sudo")
 63:             .args(&["ip", "link", "set", "dev", tap_name, "master", master_bridge])
 64:             .status()?;
 65:         if !status.success() {
 66:              let _ = Self::remove_interface(tap_name);
 67:              return Err(anyhow!("Failed to attach TAP to bridge. Status: {}", status));
 68:         }
 69:         let status = Command::new("sudo")
 70:             .args(&["ip", "link", "set", "dev", tap_name, "up"])
 71:             .status()?;
 72:         if !status.success() {
 73:              let _ = Self::remove_interface(tap_name);
 74:              return Err(anyhow!("Failed to set TAP UP. Status: {}", status));
 75:         }
 76:         Ok(())
 77:     }
 78:     pub fn remove_interface(name: &str) -> Result<()> {
 79:         info!("Removing network interface '{}'", name);
 80:         let status = Command::new("sudo")
 81:             .args(&["ip", "link", "delete", name])
 82:             .status()?;
 83:         if !status.success() {
 84:              warn!("Failed to delete interface {}. Status: {}", name, status);
 85:         }
 86:         Ok(())
 87:     }
 88:     pub fn setup_nat(bridge_cidr: &str) -> Result<()> {
 89:         info!("Enabling NAT/Masquerade for source {}", bridge_cidr);
 90:         let check_status = Command::new("sudo")
 91:             .args(&[
 92:                 "iptables", "-t", "nat", "-C", "POSTROUTING",
 93:                 "-s", bridge_cidr,
 94:                 "!", "-d", bridge_cidr,
 95:                 "-j", "MASQUERADE"
 96:             ])
 97:             .stdout(std::process::Stdio::null())
 98:             .stderr(std::process::Stdio::null())
 99:             .status();
100:         let exists = match check_status {
101:             Ok(s) => s.success(),
102:             Err(_) => false,
103:         };
104:         if !exists {
105:             let output = Command::new("sudo")
106:                 .args(&[
107:                     "iptables", "-t", "nat", "-A", "POSTROUTING",
108:                     "-s", bridge_cidr,
109:                     "!", "-d", bridge_cidr,
110:                     "-j", "MASQUERADE"
111:                 ])
112:                 .output()?;
113:             if !output.status.success() {
114:                  let stderr = String::from_utf8_lossy(&output.stderr);
115:                  return Err(anyhow!("Failed to setup iptables NAT. Output: {}", stderr));
116:             }
117:         } else {
118:             info!("NAT rule for {} already exists.", bridge_cidr);
119:         }
120:         let output = Command::new("sudo")
121:             .args(&["sysctl", "-w", "net.ipv4.ip_forward=1"])
122:             .output()?;
123:         if !output.status.success() {
124:              let stderr = String::from_utf8_lossy(&output.stderr);
125:              warn!("Failed to enable ip_forward: {}", stderr);
126:         }
127:         Ok(())
128:     }
129:     pub fn setup_tc_redirect(if_ingress: &str, if_egress: &str) -> Result<()> {
130:         info!("Setting up TC redirect: {} <-> {}", if_ingress, if_egress);
131:         let run_tc = |args: &[&str]| -> Result<()> {
132:             let out = Command::new("sudo")
133:                 .arg("tc")
134:                 .args(args)
135:                 .output()?;
136:             if !out.status.success() {
137:                  let stderr = String::from_utf8_lossy(&out.stderr);
138:                  if !stderr.contains("File exists") {
139:                      return Err(anyhow!("TC failed ({:?}): {}", args, stderr));
140:                  }
141:             }
142:             Ok(())
143:         };
144:         run_tc(&["qdisc", "add", "dev", if_ingress, "ingress"])?;
145:         run_tc(&["filter", "add", "dev", if_ingress, "parent", "ffff:", "protocol", "all", "u32", "match", "u32", "0", "0", "action", "mirred", "egress", "redirect", "dev", if_egress])?;
146:         run_tc(&["qdisc", "add", "dev", if_egress, "ingress"])?;
147:         run_tc(&["filter", "add", "dev", if_egress, "parent", "ffff:", "protocol", "all", "u32", "match", "u32", "0", "0", "action", "mirred", "egress", "redirect", "dev", if_ingress])?;
148:         Ok(())
149:     }
150: }
