<file path="crates/ignite-core/src/fs.rs">
 1: use anyhow::{anyhow, Result};
 2: use std::process::{Command, Child};
 3: use std::path::Path;
 4: use tracing::info;
 5: #[derive(Debug)]
 6: pub struct VirtioFsManager {
 7:     process: Option<Child>,
 8:     socket_path: String,
 9:     tag: String,
10: }
11: impl VirtioFsManager {
12:     pub fn new(tag: &str, socket_path: &str) -> Self {
13:         Self {
14:             tag: tag.to_string(),
15:             socket_path: socket_path.to_string(),
16:             process: None,
17:         }
18:     }
19:     pub fn start(&mut self, source_path: &str) -> Result<()> {
20:         info!("Starting virtiofsd for tag {} on socket {}", self.tag, self.socket_path);
21:         if Path::new(&self.socket_path).exists() {
22:             std::fs::remove_file(&self.socket_path)?;
23:         }
24:         let binary = if Path::new("/opt/ignite/bin/virtiofsd").exists() {
25:             "/opt/ignite/bin/virtiofsd"
26:         } else if Path::new("/usr/libexec/ignite/virtiofsd").exists() {
27:             "/usr/libexec/ignite/virtiofsd"
28:         } else if Path::new("bin/virtiofsd").exists() {
29:             "bin/virtiofsd"
30:         } else {
31:             "virtiofsd"
32:         };
33:         let child = Command::new(binary)
34:             .arg(format!("--socket-path={}", self.socket_path))
35:             .arg(format!("--shared-dir={}", source_path))
36:             .arg("--sandbox=none")
37:             .arg("--seccomp=none")
38:             .spawn()
39:             .map_err(|e| anyhow!("Failed to spawn virtiofsd (is it installed?): {}", e))?;
40:         self.process = Some(child);
41:         let loop_delay = std::time::Duration::from_millis(50);
42:         for _ in 0..20 {
43:             if Path::new(&self.socket_path).exists() {
44:                 return Ok(());
45:             }
46:             std::thread::sleep(loop_delay);
47:         }
48:         Err(anyhow!("Timed out waiting for virtiofsd socket"))
49:     }
50:     pub fn kill(&mut self) -> Result<()> {
51:         if let Some(mut child) = self.process.take() {
52:             info!("Killing virtiofsd for tag {}", self.tag);
53:             child.kill()?;
54:             child.wait()?;
55:         }
56:         if Path::new(&self.socket_path).exists() {
57:             let _ = std::fs::remove_file(&self.socket_path);
58:         }
59:         Ok(())
60:     }
61:     pub fn try_wait(&mut self) -> Result<Option<std::process::ExitStatus>> {
62:         if let Some(child) = self.process.as_mut() {
63:              child.try_wait().map_err(|e| anyhow!("Failed to wait on child: {}", e))
64:         } else {
65:              Ok(None)
66:         }
67:     }
68: }
69: impl Drop for VirtioFsManager {
70:     fn drop(&mut self) {
71:         let _ = self.kill();
72:     }
73: }
