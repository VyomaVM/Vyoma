101:         let config: DockerConfig = serde_json::from_str(&content).ok()?;
102:         let keys_to_try = vec![
103:             registry.to_string(),
104:             format!("https://{}", registry),
105:             "https://index.docker.io/v1/".to_string(),
106:         ];
107:         use base64::prelude::*;
108:         for key in keys_to_try {
109:             if let Some(auth_entry) = config.auths.get(&key) {
110:                 if let Ok(decoded_bytes) = BASE64_STANDARD.decode(&auth_entry.auth) {
111:                     if let Ok(decoded_str) = String::from_utf8(decoded_bytes) {
112:                         if let Some((u, p)) = decoded_str.split_once(':') {
113:                             return Some((u.to_string(), p.to_string()));
114:                         }
115:                     }
116:                 }
117:             }
118:         }
119:         None
120:     }
121:     pub fn new() -> Self {
