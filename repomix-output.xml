1066: async fn start_service_helper(
1067:     client: &Client,
1068:     daemon_url: &str,
1069:     stack_name: &str,
1070:     name: &str,
1071:     service: &ignite_compose::Service,
1072: ) -> Result<()> {
1073:     let image_target = if let Some(ref build) = service.build {
1074:         let context = match build {
1075:             ignite_compose::BuildSource::Path(p) => p.clone(),
1076:             ignite_compose::BuildSource::Config(c) => c.context.clone(),
1077:         };
1078:         info!("Building service '{}' from {}", name, context);
1079:         build_image(&context, daemon_url).await?
1080:     } else if let Some(ref img) = service.image {
1081:         img.clone()
1082:     } else {
1083:         error!("Service '{}' has no image or build context", name);
1084:         return Ok(());
1085:     };
1086:     let mut port_mappings = Vec::new();
1087:     if let Some(ref ports) = service.ports {
1088:         for p in ports {
1089:             let parts: Vec<&str> = p.split(':').collect();
1090:             if parts.len() == 2 {
1091:                 let h = parts[0].parse().unwrap_or(0);
1092:                 let v = parts[1].parse().unwrap_or(0);
1093:                 port_mappings.push(PortMapping {
1094:                     host_port: h,
1095:                     vm_port: v,
1096:                 });
1097:             }
1098:         }
1099:     }
1100:     let mut volume_mounts = Vec::new();
1101:     if let Some(ref vols) = service.volumes {
1102:         for v in vols {
1103:             let parts: Vec<&str> = v.split(':').collect();
1104:             if parts.len() == 2 {
1105:                 volume_mounts.push(VolumeMount {
1106:                     host_path: parts[0].to_string(),
1107:                     vm_path: parts[1].to_string(),
1108:                     read_only: false,
1109:                 });
1110:             }
1111:         }
1112:     }
1113:     let payload = RunRequest {
1114:         image: image_target,
1115:         vcpu: service.cpus.unwrap_or(1),
1116:         mem_size_mib: service.memory.unwrap_or(512),
1117:         ports: port_mappings,
1118:         volumes: volume_mounts,
1119:         hostname: Some(name.to_string()),
1120:         labels: {
1121:             let mut l = HashMap::new();
1122:             l.insert("ignite.stack".to_string(), stack_name.to_string());
1123:             l.insert("ignite.service".to_string(), name.to_string());
1124:             l
1125:         },
1126:     };
1127:     let resp = client
1128:         .post(format!("{}/run", daemon_url))
1129:         .json(&payload)
1130:         .send()
1131:         .await;
1132:     match resp {
1133:         Ok(r) => {
1134:             if r.status().is_success() {
1135:                 let body: RunResponse = r.json().await?;
1136:                 info!("Service '{}' started as VM {}", name, body.vm_id);
1137:             } else {
1138:                 error!("Failed to start service '{}': {}", name, r.status());
1139:             }
1140:         }
1141:         Err(e) => error!("Failed to request start for '{}': {}", name, e),
1142:     }
1143:     Ok(())
1144: }
