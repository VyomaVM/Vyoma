 537: pub async fn snapshot_vm(
 538:     State(state): State<AppState>,
 539:     Path(id): Path<String>,
 540: ) -> Result<String, (StatusCode, String)> {
 541:     info!("Request to snapshot VM: {}", id);
 542:     let vm_arc = {
 543:         let vms = state.vms.lock().unwrap();
 544:         vms.get(&id).cloned()
 545:     };
 546:     if let Some(vm_mutex) = vm_arc {
 547:         let vm = vm_mutex.lock().await;
 548:         let home =
 549:             dirs::home_dir().ok_or((StatusCode::INTERNAL_SERVER_ERROR, "No home dir".into()))?;
 550:         let vm_dir = home.join(".ignite").join("vms").join(&id);
 551:         let snapshot_path = vm_dir.join("snapshot.snap");
 552:         let mem_path = vm_dir.join("memory.mem");
 553:         vm.vmm.pause_instance().await.map_err(|e| {
 554:             (
 555:                 StatusCode::INTERNAL_SERVER_ERROR,
 556:                 format!("Failed to pause: {}", e),
 557:             )
 558:         })?;
 559:         let snap_result = vm
 560:             .vmm
 561:             .create_snapshot(
 562:                 snapshot_path.to_string_lossy().as_ref(),
 563:                 mem_path.to_string_lossy().as_ref(),
 564:             )
 565:             .await;
 566:         if let Err(e) = vm.vmm.resume_instance().await {
 567:             error!("Failed to resume VM {} after snapshot: {}", id, e);
 568:         }
 569:         snap_result.map_err(|e| {
 570:             (
 571:                 StatusCode::INTERNAL_SERVER_ERROR,
 572:                 format!("Snapshot failed: {}", e),
 573:             )
 574:         })?;
 575:         if let Err(e) = git_commit(&vm_dir, &format!("Snapshot {}", id)) {
 576:             error!("Failed to git commit snapshot: {}", e);
 577:         }
 578:         Ok(format!("Snapshot created for VM {}", id))
 579:     } else {
 580:         Err((StatusCode::NOT_FOUND, "VM not found".to_string()))
 581:     }
 582: }
