 109: pub async fn run_vm(
 110:     State(state): State<AppState>,
 111:     Json(payload): Json<RunRequest>,
 112: ) -> Result<Json<RunResponse>, (StatusCode, String)> {
 113:     info!("Received request to run image: {}", payload.image);
 114:     // 1. Setup Directories
 115:     let home = dirs::home_dir().ok_or((StatusCode::INTERNAL_SERVER_ERROR, "No home dir".into()))?;
 116:     let ignite_root = home.join(".ignite");
 117:     let images_root = ignite_root.join("images");
 118:     let vms_root = ignite_root.join("vms");
 119:     std::fs::create_dir_all(&images_root)
 120:         .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 121:     std::fs::create_dir_all(&vms_root)
 122:         .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 123:     // Helper to parse CNI IP
 124:     fn parse_cni_ip(res: &serde_json::Value) -> anyhow::Result<String> {
 125:         let ips = res
 126:             .get("ips")
 127:             .and_then(|v| v.as_array())
 128:             .ok_or(anyhow::anyhow!("No IPs in CNI result"))?;
 129:         let first = ips.first().ok_or(anyhow::anyhow!("Empty IP list"))?;
 130:         let addr = first
 131:             .get("address")
 132:             .and_then(|v| v.as_str())
 133:             .ok_or(anyhow::anyhow!("No address field"))?;
 134:         // addr is CIDR (e.g. 172.16.0.5/24). Split it.
 135:         let ip = addr.split('/').next().unwrap_or(addr);
 136:         Ok(ip.to_string())
 137:     }
 138:     // 2. Pull Image & Prepare Base
 139:     let base_image_file = ensure_image_locally(&payload.image).await?;
 140:     let base_image_path_str = base_image_file.to_string_lossy().to_string();
 141:     info!("Using base image at {:?}", base_image_file);
 142:     // 3. VM Specific Setup
 143:     let vm_id = uuid::Uuid::new_v4().to_string();
 144:     let vm_dir = vms_root.join(&vm_id);
 145:     std::fs::create_dir_all(&vm_dir)
 146:         .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 147:     // Initialize Git Repo for Time Travel
 148:     if let Err(e) = git_init(&vm_dir) {
 149:         error!("Failed to init git repo in {:?}: {}", vm_dir, e);
 150:     }
 151:     // Storage Setup
 152:     let (dm_path, loop_devices, cow_file_str) = if state.rootless {
 153:         // Rootless: Simple Copy (No DM/Loop)
 154:         let vm_disk = vm_dir.join("disk.ext4");
 155:         info!("Rootless: Copying base image to {:?}", vm_disk);
 156:         std::fs::copy(&base_image_file, &vm_disk).map_err(|e| {
 157:             (
 158:                 StatusCode::INTERNAL_SERVER_ERROR,
 159:                 format!("Rootless copy: {}", e),
 160:             )
 161:         })?;
 162:         // We use the disk file as the "dm_path" (Firecracker treats it as root block device)
 163:         (
 164:             vm_disk.to_string_lossy().to_string(),
 165:             Vec::new(),
 166:             vm_disk.to_string_lossy().to_string(),
 167:         )
 168:     } else {
 169:         // Privileged: DM Snapshot (COW)
 170:         let cow_file = vm_dir.join("diff.cow");
 171:         let size_mb = 2048;
 172:         StorageManager::create_cow_file(&cow_file, size_mb)
 173:             .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 174:         let base_loop = StorageManager::setup_loop_device(&base_image_file).map_err(|e| {
 175:             (
 176:                 StatusCode::INTERNAL_SERVER_ERROR,
 177:                 format!("Loop base: {}", e),
 178:             )
 179:         })?;
 180:         let cow_loop = StorageManager::setup_loop_device(&cow_file).map_err(|e| {
 181:             (
 182:                 StatusCode::INTERNAL_SERVER_ERROR,
 183:                 format!("Loop cow: {}", e),
 184:             )
 185:         })?;
 186:         let dm_name = format!("ign-{}", vm_id);
 187:         let size_sectors = size_mb * 1024 * 1024 / 512;
 188:         let dm_path =
 189:             StorageManager::create_dm_snapshot(&dm_name, &base_loop, &cow_loop, size_sectors)
 190:                 .map_err(|e| {
 191:                     (
 192:                         StatusCode::INTERNAL_SERVER_ERROR,
 193:                         format!("DM create: {}", e),
 194:                     )
 195:                 })?;
 196:         (
 197:             dm_path,
 198:             vec![base_loop, cow_loop],
 199:             cow_file.to_string_lossy().to_string(),
 200:         )
 201:     };
 202:     // Legacy bindings for compilation compatibility if needed
 203:     let dm_name = if state.rootless {
 204:         "rootless".to_string()
 205:     } else {
 206:         format!("ign-{}", vm_id)
 207:     };
 208:     // --- Inject OCI Config via debugfs ---
 209:     let config_path = base_image_file.parent().unwrap().join("ignite-config.json");
 210:     let mut envs = vec![];
 211:     let mut oci_cmd = vec!["/bin/sh".to_string()];
 212:     let mut workdir = "/".to_string();
 213:     if let Ok(config_str) = std::fs::read_to_string(&config_path) {
 214:         if let Ok(oci_config) = serde_json::from_str::<ignite_core::oci::OciImageConfig>(&config_str) {
 215:             oci_cmd = oci_config.full_command();
 216:             if let Some(e) = oci_config.env {
 217:                 envs = e;
 218:             }
 219:             if let Some(wd) = oci_config.working_dir {
 220:                 if !wd.is_empty() {
 221:                     workdir = wd;
 222:                 }
 223:             }
 224:         }
 225:     }
 226:     let mut init_script = String::new();
 227:     init_script.push_str("#!/bin/sh\n");
 228:     init_script.push_str("set -e\n"); // break on errors
 229:     init_script.push_str("mount -t proc proc /proc || true\n");
 230:     init_script.push_str("mount -t sysfs sys /sys || true\n");
 231:     init_script.push_str("mount -t devtmpfs dev /dev || true\n");
 232:     for e in &envs {
 233:         init_script.push_str(&format!("export \"{}\"\n", e.replace('"', "\\\"")));
 234:     }
 235:     init_script.push_str(&format!("mkdir -p {}\n", workdir));
 236:     init_script.push_str(&format!("cd {}\n", workdir));
 237:     let cmd_str = oci_cmd.into_iter().map(|s| format!("\"{}\"", s.replace('"', "\\\""))).collect::<Vec<_>>().join(" ");
 238:     init_script.push_str(&format!("exec {}\n", cmd_str));
 239:     let temp_init_path = vm_dir.join("ignite-init.sh");
 240:     if let Err(e) = std::fs::write(&temp_init_path, init_script) {
 241:         warn!("Failed to write ignite-init.sh: {}", e);
 242:     } else {
 243:         let write_debugfs = format!("cd /sbin\nrm ignite-init\nwrite {} ignite-init\nsif ignite-init mode 0755\n", temp_init_path.to_string_lossy());
 244:         let _ = Command::new("sudo")
 245:             .args(&["debugfs", "-w", "-R", &write_debugfs.replace('\n', " -R "), &dm_path])
 246:             .status();
 247:         info!("Injected /sbin/ignite-init for {}. CMD: {}", vm_id, cmd_str);
 248:     }
 249:     let (vm_ip, tap_name, netns_path_final) = if state.rootless {
 250:         ("10.0.2.15".to_string(), "tap0".to_string(), None)
 251:     } else {
 252:         let netns_name = format!("vm-{}", vm_id);
 253:         let netns_path = format!("/var/run/netns/{}", netns_name);
 254:         std::fs::create_dir_all("/var/run/netns")
 255:             .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, e.to_string()))?;
 256:         let _ = Command::new("ip")
 257:             .args(&["netns", "add", &netns_name])
 258:             .output()
 259:             .map_err(|e| {
 260:                 (
 261:                     StatusCode::INTERNAL_SERVER_ERROR,
 262:                     format!("Failed to create netns: {}", e),
 263:                 )
 264:             })?;
 265:         let ifname = "eth0";
 266:         let cni_result = state
 267:             .cni_manager
 268:             .add(None, &vm_id, &netns_path, ifname)
 269:             .map_err(|e| {
 270:                 (
 271:                     StatusCode::INTERNAL_SERVER_ERROR,
 272:                     format!("CNI ADD failed: {}", e),
 273:                 )
 274:             })?;
 275:         let ip = parse_cni_ip(&cni_result).unwrap_or_else(|e| {
 276:             error!("Failed to parse CNI IP: {}", e);
 277:             "172.16.0.0".to_string()
 278:         });
 279:         info!("CNI assigned IP: {}", ip);
 280:         let tap_legacy = format!("tap{}", &vm_id[0..8]);
 281:         (ip, tap_legacy, Some(netns_path))
 282:     };
 283:     let cgroup_path = match state.cgroups.create_vm_cgroup(&vm_id) {
 284:         Ok(p) => Some(p),
 285:         Err(e) => {
 286:             error!("Failed to create cgroup: {}", e);
 287:             None
 288:         }
 289:     };
 290:     if let Some(_) = &cgroup_path {
 291:         let quota = payload.vcpu * 100;
 292:         if let Err(e) = state.cgroups.set_cpu_limit(&vm_id, quota) {
 293:             error!("Failed to set cpu limit: {}", e);
 294:         }
 295:         let mem_bytes = (payload.mem_size_mib as u64) * 1024 * 1024;
 296:         if let Err(e) = state.cgroups.set_memory_limit(&vm_id, mem_bytes) {
 297:             error!("Failed to set memory limit: {}", e);
 298:         }
 299:     }
 300:     let mut proxy_tasks = Vec::new();
 301:     if !state.rootless {
 302:         for mapping in &payload.ports {
 303:             let handle =
 304:                 ProxyManager::start_proxy(mapping.host_port, vm_ip.clone(), mapping.vm_port);
 305:             proxy_tasks.push(handle);
 306:         }
 307:     } else {
 308:         info!("Rootless: Skipping ProxyManager. Ports are mapped by slirp4netns.");
 309:     }
 310:     let boot_args = format!("console=ttyS0 reboot=k panic=1 pci=off root=/dev/vda rw ip={}::{}:255.255.255.0:{}:eth0:off:{} init=/sbin/ignite-init",
 311:         vm_ip, "172.16.0.1", vm_id, "172.16.0.1");
 312:     let socket_path = format!("/tmp/firecracker_{}.socket", vm_id);
 313:     let mut vmm = VmmManager::new(&socket_path);
 314:     let kernel_path = "bin/vmlinux";
 315:     if !std::path::Path::new(kernel_path).exists() {
 316:         return Err((
 317:             StatusCode::INTERNAL_SERVER_ERROR,
 318:             "Kernel binary (bin/vmlinux) not found".into(),
 319:         ));
 320:     }
 321:     let mut slirp_mgr = None;
 322:     if state.rootless {
 323:         info!("Spawning Firecracker in Rootless Mode (unshare -r -n)...");
 324:         if let Err(e) = vmm.start_daemon("bin/firecracker", None, true) {
 325:             return Err((
 326:                 StatusCode::INTERNAL_SERVER_ERROR,
 327:                 format!("Failed to start FC (Rootless): {}", e),
 328:             ));
 329:         }
 330:         let pid = vmm
 331:             .get_pid()
 332:             .ok_or((StatusCode::INTERNAL_SERVER_ERROR, "FC PID not found".into()))?;
 333:         let socket_path = vm_dir.join("slirp.sock");
 334:         let mut slirp =
 335:             ignite_core::slirp::SlirpManager::new(socket_path.to_string_lossy().as_ref());
 336:         if let Err(e) = slirp.spawn(pid, "tap0", &payload.ports) {
 337:             let _ = vmm.kill();
 338:             return Err((
 339:                 StatusCode::INTERNAL_SERVER_ERROR,
 340:                 format!("Failed to start slirp: {}", e),
 341:             ));
 342:         }
 343:         slirp_mgr = Some(slirp);
 344:         if let Err(e) = vmm.set_boot_source(kernel_path, &boot_args).await {
 345:             let _ = vmm.kill();
 346:             return Err((
 347:                 StatusCode::INTERNAL_SERVER_ERROR,
 348:                 format!("Boot source: {}", e),
 349:             ));
 350:         }
 351:         if let Err(e) = vmm.add_drive("rootfs", &dm_path, true).await {
 352:             let _ = vmm.kill();
 353:             return Err((
 354:                 StatusCode::INTERNAL_SERVER_ERROR,
 355:                 format!("Add drive: {}", e),
 356:             ));
 357:         }
 358:         if let Err(e) = vmm.add_network_interface("eth0", "tap0", None).await {
 359:             let _ = vmm.kill();
 360:             return Err((
 361:                 StatusCode::INTERNAL_SERVER_ERROR,
 362:                 format!("Add net (rootless): {}", e),
 363:             ));
 364:         }
 365:     } else {
 366:         if let Err(e) = vmm.start_daemon("bin/firecracker", None, false) {
 367:             return Err((
 368:                 StatusCode::INTERNAL_SERVER_ERROR,
 369:                 format!("Failed to start FC: {}", e),
 370:             ));
 371:         }
 372:         if let Err(e) = vmm.set_boot_source(kernel_path, &boot_args).await {
 373:             let _ = vmm.kill();
 374:             return Err((
 375:                 StatusCode::INTERNAL_SERVER_ERROR,
 376:                 format!("Boot source: {}", e),
 377:             ));
 378:         }
 379:         if let Err(e) = vmm.add_drive("rootfs", &dm_path, true).await {
 380:             let _ = vmm.kill();
 381:             return Err((
 382:                 StatusCode::INTERNAL_SERVER_ERROR,
 383:                 format!("Add drive: {}", e),
 384:             ));
 385:         }
 386:         if let Err(e) = vmm.add_network_interface("eth0", &tap_name, None).await {
 387:             let _ = vmm.kill();
 388:             return Err((StatusCode::INTERNAL_SERVER_ERROR, format!("Add net: {}", e)));
 389:         }
 390:     }
 391:     let mut fs_managers = Vec::new();
 392:     for (idx, vol) in payload.volumes.iter().enumerate() {
 393:         let tag = format!("vol{}", idx);
 394:         let socket_path = vm_dir.join(format!("fs_{}.sock", idx));
 395:         let mut fs_mgr = VirtioFsManager::new(&tag, socket_path.to_string_lossy().as_ref());
 396:         if let Err(e) = fs_mgr.start(&vol.host_path) {
 397:             let _ = vmm.kill();
 398:             return Err((
 399:                 StatusCode::INTERNAL_SERVER_ERROR,
 400:                 format!("Failed to start virtiofsd for {}: {}", vol.host_path, e),
 401:             ));
 402:         }
 403:         if let Err(e) = vmm
 404:             .add_file_system(&tag, socket_path.to_string_lossy().as_ref(), &tag)
 405:             .await
 406:         {
 407:             let _ = vmm.kill();
 408:             let _ = fs_mgr.kill();
 409:             return Err((StatusCode::INTERNAL_SERVER_ERROR, format!("Add fs: {}", e)));
 410:         }
 411:         fs_managers.push(fs_mgr);
 412:     }
 413:     if let Err(e) = vmm
 414:         .set_machine_config(payload.vcpu, payload.mem_size_mib)
 415:         .await
 416:     {
 417:         let _ = vmm.kill();
 418:         return Err((
 419:             StatusCode::INTERNAL_SERVER_ERROR,
 420:             format!("Machine config: {}", e),
 421:         ));
 422:     }
 423:     if let Err(e) = vmm.start_instance().await {
 424:         let _ = vmm.kill();
 425:         return Err((
 426:             StatusCode::INTERNAL_SERVER_ERROR,
 427:             format!("Start instance: {}", e),
 428:         ));
 429:     }
 430:     let instance = VmInstance {
 431:         vmm,
 432:         id: vm_id.clone(),
 433:         tap_name: if state.rootless {
 434:             String::new()
 435:         } else {
 436:             tap_name.to_string()
 437:         },
 438:         dm_name: dm_name.clone(),
 439:         loop_devices,
 440:         cow_file_path: cow_file_str,
 441:         ip_address: vm_ip.clone(),
 442:         proxy_tasks,
 443:         fs_managers,
 444:         slirp: slirp_mgr,
 445:         cgroup_path,
 446:         netns_path: netns_path_final,
 447:         config_ports: payload.ports.clone(),
 448:         config_volumes: payload.volumes.clone(),
 449:         hostname: payload.hostname.clone(),
 450:         labels: payload.labels.clone(),
 451:         base_image_path: base_image_path_str,
 452:         vcpu: payload.vcpu,
 453:         mem_size_mib: payload.mem_size_mib,
 454:     };
 455:     instance.save_state().map_err(|e| {
 456:         (
 457:             StatusCode::INTERNAL_SERVER_ERROR,
 458:             format!("Failed to save state: {}", e),
 459:         )
 460:     })?;
 461:     {
 462:         let mut vms = state.vms.lock().unwrap();
 463:         vms.insert(vm_id.clone(), Arc::new(TokioMutex::new(instance)));
 464:     }
 465:     let _ = state.events_tx.send(serde_json::json!({
 466:         "type": "vm_start",
 467:         "id": vm_id,
 468:         "name": payload.labels.get("ignite.service").unwrap_or(&vm_id)
 469:     }).to_string());
 470:     Ok(Json(RunResponse {
 471:         vm_id,
 472:         status: "Running".to_string(),
 473:         ip_address: vm_ip,
 474:     }))
 475: }
 476: pub async fn stop_vm(
 477:     State(state): State<AppState>,
 478:     Path(id): Path<String>,
 479: ) -> Result<String, (StatusCode, String)> {
 480:     info!("Request to stop VM: {}", id);
 481:     let vm_arc = {
 482:         let mut vms = state.vms.lock().unwrap();
 483:         vms.remove(&id)
 484:     };
 485:     if let Some(vm_mutex) = vm_arc {
 486:         let mut vm = vm_mutex.lock().await;
 487:         vm.cleanup(&state.cni_manager).await;
 488:         let _ = state.events_tx.send(serde_json::json!({
 489:             "type": "vm_stop",
 490:             "id": id
 491:         }).to_string());
 492:         Ok(format!("VM {} stopped and cleaned up", id))
 493:     } else {
 494:         Err((StatusCode::NOT_FOUND, "VM not found".to_string()))
 495:     }
 496: }
