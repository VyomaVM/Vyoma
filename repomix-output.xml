 564: ### 3.4 WAL + Crash Recovery
 565: 
 566: **Crate**: `crates/ignited/src/state/` (new module)  
 567: **Priority**: P1 — prevents data loss on daemon crash
 568: 
 569: #### 3.4.1 WAL Design
 570: 
 571: Use `sled` embedded database for the WAL. Sled is pure Rust, has atomic batch writes, and does not require a separate process.
 572: 
 573: ```toml
 574: # crates/ignited/Cargo.toml
 575: [dependencies]
 576: sled = "0.34"
 577: ```
 578: 
 579: #### 3.4.2 WAL Entries
 580: 
 581: Every mutation to daemon state writes a WAL entry before changing in-memory state:
 582: 
 583: ```rust
 584: // crates/ignited/src/state/wal.rs
 585: 
 586: use sled::{Db, Tree};
 587: use serde::{Serialize, Deserialize};
 588: 
 589: #[derive(Debug, Clone, Serialize, Deserialize)]
 590: pub enum WalEntry {
 591:     VmCreating { vm_id: String, config: VmConfig },
 592:     VmStarted  { vm_id: String, pid: u32, ip: String, fc_socket: String },
 593:     VmStopping { vm_id: String },
 594:     VmStopped  { vm_id: String },
 595:     VmDestroyed { vm_id: String },
 596:     SnapshotCreated { vm_id: String, snap_id: String, path: String },
 597:     VolumeAttached  { vm_id: String, host_path: String, vm_path: String },
 598:     NetworkCreated  { net_id: String, name: String, subnet: String, bridge: String },
 599:     NetworkDeleted  { net_id: String },
 600: }
 601: 
 602: pub struct Wal {
 603:     db: Db,
 604:     log: Tree,
 605:     state: Tree,
 606: }
 607: 
 608: impl Wal {
 609:     pub fn open(data_dir: &Path) -> Result<Self> {
 610:         let db = sled::open(data_dir.join("wal.db"))?;
 611:         let log = db.open_tree("log")?;
 612:         let state = db.open_tree("state")?;
 613:         Ok(Self { db, log, state })
 614:     }
 615: 
 616:     /// Append an entry to the log and flush synchronously (O_SYNC semantics)
 617:     pub fn append(&self, entry: &WalEntry) -> Result<u64> {
 618:         let seq = self.db.generate_id()?;
 619:         let key = seq.to_be_bytes();
 620:         let value = serde_json::to_vec(entry)?;
 621:         self.log.insert(key, value)?;
 622:         self.log.flush()?;  // fsync — critical for crash safety
 623:         Ok(seq)
 624:     }
 625: 
 626:     /// Write committed state (used after a transition is complete)
 627:     pub fn commit_state(&self, vm_id: &str, state: &VmState) -> Result<()> {
 628:         let value = serde_json::to_vec(state)?;
 629:         self.state.insert(vm_id.as_bytes(), value)?;
 630:         self.state.flush()?;
 631:         Ok(())
 632:     }
 633: 
 634:     /// Remove a VM from committed state
 635:     pub fn remove_state(&self, vm_id: &str) -> Result<()> {
 636:         self.state.remove(vm_id.as_bytes())?;
 637:         self.state.flush()?;
 638:         Ok(())
 639:     }
 640: 
 641:     /// Iterate all committed states — called on daemon startup for recovery
 642:     pub fn all_states(&self) -> Result<Vec<VmState>> {
 643:         self.state
 644:             .iter()
 645:             .map(|r| {
 646:                 let (_, v) = r?;
 647:                 Ok(serde_json::from_slice(&v)?)
 648:             })
 649:             .collect()
 650:     }
 651: }
 652: ```
 653: 
 654: #### 3.4.3 Recovery on Startup
 655: 
 656: ```rust
 657: // crates/ignited/src/state/recovery.rs
 658: 
 659: pub struct RecoveryResult {
 660:     pub adopted: Vec<String>,   // VMs successfully re-adopted
 661:     pub orphaned: Vec<String>,  // VMs whose Firecracker process is gone
 662:     pub cleaned: Vec<String>,   // Resources cleaned up
 663: }
 664: 
 665: pub async fn recover_from_wal(wal: &Wal, fc_manager: &mut VmManager) -> Result<RecoveryResult> {
 666:     let mut result = RecoveryResult::default();
 667:     
 668:     for state in wal.all_states()? {
 669:         match state.status {
 670:             VmStatus::Running { pid, fc_socket, ip } => {
 671:                 // Check if the Firecracker process is still alive
 672:                 if process_exists(pid) {
 673:                     // Re-adopt the running VM — reconnect to Firecracker socket
 674:                     match fc_manager.adopt(state.vm_id.clone(), pid, fc_socket, ip).await {
 675:                         Ok(_) => result.adopted.push(state.vm_id),
 676:                         Err(e) => {
 677:                             tracing::warn!("Failed to adopt VM {}: {}", state.vm_id, e);
 678:                             cleanup_orphan(&state, wal).await?;
 679:                             result.orphaned.push(state.vm_id);
 680:                         }
 681:                     }
 682:                 } else {
 683:                     // Process is gone — clean up DM, TAP, COW resources
 684:                     cleanup_orphan(&state, wal).await?;
 685:                     result.orphaned.push(state.vm_id);
 686:                 }
 687:             }
 688:             VmStatus::Creating => {
 689:                 // Was in the middle of creation — incomplete, clean up
 690:                 cleanup_orphan(&state, wal).await?;
 691:                 result.cleaned.push(state.vm_id);
 692:             }
 693:             VmStatus::Stopped => {
 694:                 // Just restore stopped VM metadata into memory (no process to adopt)
 695:                 fc_manager.restore_stopped_metadata(state);
 696:             }
 697:         }
 698:     }
 699:     
 700:     Ok(result)
 701: }
 702: 
 703: fn process_exists(pid: u32) -> bool {
 704:     Path::new(&format!("/proc/{}", pid)).exists()
 705: }
 706: ```
