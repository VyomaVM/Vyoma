2137: ### 6.5 ignite-agent — In-VM Binary
2138: 
2139: **Crate**: `crates/ignite-agent/`  
2140: **Target**: `x86_64-unknown-linux-musl` — static binary, ~400KB  
2141: **Priority**: P2
2142: 
2143: ```rust
2144: // crates/ignite-agent/src/main.rs
2145: // This binary is injected into every VMIF image at build time.
2146: // It runs as PID 2 (alongside the actual workload) via a wrapper init.
2147: 
2148: use vsock::{VsockListener, VMADDR_CID_HOST};
2149: 
2150: const VSOCK_PORT: u32 = 9999;
2151: 
2152: #[tokio::main]
2153: async fn main() -> Result<()> {
2154:     // Listen on vsock for daemon communication
2155:     let listener = VsockListener::bind(&VsockAddr::new(VMADDR_CID_HOST, VSOCK_PORT))?;
2156:     
2157:     loop {
2158:         let (stream, _) = listener.accept()?;
2159:         tokio::spawn(handle_connection(stream));
2160:     }
2161: }
2162: 
2163: async fn handle_connection(stream: VsockStream) -> Result<()> {
2164:     let mut framed = LengthDelimitedCodec::new().framed(stream);
2165:     
2166:     while let Some(frame) = framed.next().await {
2167:         let request: AgentRequest = serde_json::from_slice(&frame?)?;
2168:         
2169:         let response = match request {
2170:             AgentRequest::ProcessList => {
2171:                 AgentResponse::ProcessList(collect_process_tree().await?)
2172:             }
2173:             AgentRequest::ExecCommand { cmd, env, workdir } => {
2174:                 AgentResponse::ExecStarted(exec_command(cmd, env, workdir).await?)
2175:             }
2176:             AgentRequest::GetMetrics => {
2177:                 AgentResponse::Metrics(collect_metrics().await?)
2178:             }
2179:             AgentRequest::FileRead { path } => {
2180:                 AgentResponse::FileContent(std::fs::read(&path)?)
2181:             }
2182:         };
2183:         
2184:         framed.send(Bytes::from(serde_json::to_vec(&response)?)).await?;
2185:     }
2186:     
2187:     Ok(())
2188: }
2189: 
2190: /// Collect /proc stats and return structured metrics
2191: async fn collect_metrics() -> Result<VmMetrics> {
2192:     Ok(VmMetrics {
2193:         cpu_user_ms:   read_proc_stat()?.user_time,
2194:         cpu_system_ms: read_proc_stat()?.system_time,
2195:         mem_used_kb:   read_proc_meminfo()?.mem_total - read_proc_meminfo()?.mem_free,
2196:         mem_total_kb:  read_proc_meminfo()?.mem_total,
2197:         load_avg_1:    read_loadavg()?.one,
2198:         process_count: read_proc_count()?,
2199:     })
2200: }
2201: ```
